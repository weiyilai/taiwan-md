---
import '../styles/global.css';
interface Props {
  title?: string;
}
const { title = 'Harvest · Taiwan.md' } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta
      name="description"
      content="Taiwan.md Harvest engine dashboard — Phase 2 Web UI."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-bg-base text-text-primary">
    <slot />
  </body>
</html>
