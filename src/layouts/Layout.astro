            d = function (a) {
              var b, e, g;
              if (0 === arguments.length || ('string' === typeof a && a)) {
                var d = (a || '').match(v) || [];
                if ((b = h[c] ? (' ' + h[c] + ' ').replace(w, ' ') : '')) {
