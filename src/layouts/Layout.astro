  <body class={jfClass}>
    <Banner />
    <Header />

    <script is:inline>
      var _searchIdx = null;
      async function _loadSearchIndex() {
        if (_searchIdx) return _searchIdx;
        try {
          var res = await fetch('/api/search-index.json');
          if (res.ok) _searchIdx = await res.json();
          else _searchIdx = [];
        } catch (e) {
          _searchIdx = [];
        }
        return _searchIdx;
      }
      function initSearch() {
        var isEn = document.documentElement.lang === 'en';
        var lang = isEn ? 'en' : 'zh-TW';
        var input = document.getElementById('search-input');
        if (!input) return;
        var results = document.getElementById('search-results');
        var modal = document.getElementById('search-modal');

        // Preload search index when modal opens
        _loadSearchIndex();

        input.addEventListener('input', async function () {
          var q = this.value.trim().toLowerCase();
          if (!q) {
            results.innerHTML =
              '<div class="search-hint">' +
              (isEn
                ? 'Type to search across all articles'
                : '輸入關鍵字搜尋所有文章') +
              '</div>';
            return;
          }
          var idx = await _loadSearchIndex();
          var matches = idx.filter(function (item) {
            return (
              item.t.toLowerCase().indexOf(q) !== -1 ||
              item.d.toLowerCase().indexOf(q) !== -1 ||
              item.tags.some(function (tag) {
                return String(tag).toLowerCase().indexOf(q) !== -1;
              })
            );
          });
          // Prefer current language, then show others
          matches.sort(function (a, b) {
            var aLang = a.lang === lang ? 0 : 1;
            var bLang = b.lang === lang ? 0 : 1;
            return aLang - bLang;
          });
          if (matches.length === 0) {
            results.innerHTML =
              '<div class="search-hint">' +
              (isEn ? 'No results found' : '找不到相關文章') +
              '</div>';
            return;
          }
          var html = matches
            .slice(0, 12)
            .map(function (item) {
              var langBadge = item.lang === 'en' ? 'EN' : '中';
              return (
                '<a class="search-item" href="' +
                item.u +
                '">' +
                '<span class="search-item-lang">' +
                langBadge +
                '</span>' +
                '<div class="search-item-text">' +
                '<span class="search-item-title">' +
                item.t +
                '</span>' +
                (item.d
                  ? '<span class="search-item-desc">' + item.d + '</span>'
                  : '') +
                '</div>' +
                '</a>'
              );
            })
            .join('');
          if (matches.length > 12) {
            html +=
              '<div class="search-hint">' +
              (isEn
                ? '...and ' + (matches.length - 12) + ' more'
                : '...還有 ' + (matches.length - 12) + ' 篇') +
              '</div>';
          }
          results.innerHTML = html;
        });

        // ESC to close
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && modal.classList.contains('open')) {
            modal.classList.remove('open');
          }
          // Cmd/Ctrl+K to open
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            modal.classList.toggle('open');
            if (modal.classList.contains('open')) {
              setTimeout(function () {
                input.focus();
              }, 100);
            }
          }
        });
      }
      // Bind search after DOM is ready — handles both SSR and CSR timing
      function _tryInit() {
        if (document.getElementById('search-input')) {
          initSearch();
        } else {
          setTimeout(_tryInit, 50);
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', _tryInit);
      } else {
        _tryInit();
      }
    </script>

    <main role="main">
      <slot />
    </main>

    <Footer />

    <!-- Floating .md button -->
    <a
      id="md-btn"
      class="floating-md"
      title="查看 Raw Markdown 版本"
      target="_blank"
    >
      .md
    </a>

    <script is:inline>
      // Set .md button href based on current path
      const btn = document.getElementById('md-btn');
      const pathname = window.location.pathname;
      const ghBase = 'https://github.com/frank890417/taiwan-md/blob/main';

      let target = '/README.md'; // Default fallback

      // Handle special pages
      if (
        pathname === '/' ||
        pathname === '/en' ||
        pathname === '/en/' ||
        pathname === '/index.html'
      ) {
        target = '/README.md';
      } else if (pathname.includes('/contribute')) {
        target = '/CONTRIBUTING.md';
      } else if (pathname.includes('/resources')) {
        target = '/knowledge/About/台灣官方網站資源.md';
      } else if (pathname.includes('/graph')) {
        target = '/src/pages/graph.astro';
      } else if (pathname.includes('/map')) {
        target = pathname.startsWith('/en')
          ? '/src/pages/en/map.astro'
          : '/src/pages/map.astro';
      } else if (pathname.includes('/about')) {
        target = '/src/pages/about.astro';
      } else {
        // Content pages (Categories or Articles)
        const isEn = pathname.startsWith('/en/');
        // Remove /en/ prefix and leading/trailing slashes
        const cleanPath = pathname
          .replace(/^\/en/, '')
          .replace(/^\//, '')
          .replace(/\/$/, '')
          .replace('index.html', '');
        const parts = cleanPath.split('/');

        if (parts.length > 0 && parts[0]) {
          const cat = parts[0];
          // Capitalize first letter of category (history -> History)
          const catFolder = cat.charAt(0).toUpperCase() + cat.slice(1);

          // ZH source is in knowledge/Category, EN source is in knowledge/en/Category
          const prefix = isEn ? '/knowledge/en' : '/knowledge';

          if (parts.length === 1) {
            // Category Hub: knowledge/History/_History Hub.md
            target = `${prefix}/${catFolder}/_${catFolder} Hub.md`;
          } else {
            // Article: knowledge/History/article-name.md
            const slug = decodeURIComponent(parts.slice(1).join('/'));
            target = `${prefix}/${catFolder}/${slug}.md`;
          }
        }
      }

      btn.href = ghBase + target;

      // Hash-based active state can only be detected client-side
      if (window.location.hash === '#categories') {
        document
          .querySelectorAll('.nav-link[href$="/#categories"]')
          .forEach((l) => l.classList.add('active'));
      }
    </script>
  </body>
</html>

<style is:global>
  html {
    font-size: 118%;
    overflow-x: hidden;
  }

  html,
  body {
    max-width: 100vw;
    overflow-x: hidden;
  }
  :root {
    --container-wide: 1380px;
    --container-page: 1180px;
    --container-reading: 1080px;
    --space-page-x: clamp(1rem, 2vw, 2rem);
    --space-section-y: clamp(3.5rem, 7vw, 6rem);
    --space-1: 0.5rem;
    --space-2: 0.75rem;
    --space-3: 1rem;
    --space-4: 1.5rem;
    --space-5: 2rem;
    --space-6: 2.5rem;
    --space-7: 3rem;
    --space-8: 4rem;
    --space-9: 5rem;
    --radius-chip: 16px;
    --radius-card: 20px;
    --radius-pill: 999px;
    --shadow-soft: 0 8px 30px rgba(15, 23, 42, 0.06);
    --shadow-card: 0 16px 40px rgba(15, 23, 42, 0.08);
    --border-soft: 1px solid rgba(148, 163, 184, 0.2);
    /* === Taiwan Typography System === */
    --font-title: 'Noto Serif TC', 'Source Han Serif TC', 'PMingLiU', serif;
    --font-reading:
      'jf-jinxuanlatte', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
    --font-interface:
      'Noto Sans TC', 'Source Han Sans TC', 'PingFang TC', sans-serif;
    --font-quote: 'jf-lanyangming', 'Noto Serif TC', serif;
    --font-mono:
      'SF Mono', 'Fira Code', 'Source Code Pro', 'Consolas', monospace;
    /* Legacy compatibility */
    --font-editorial: var(--font-title);
    --title-display-size: clamp(2.25rem, 5vw, 3.2rem);
    --title-section-size: clamp(1.95rem, 4vw, 2.5rem);
    --title-subsection-size: clamp(1.3rem, 2.4vw, 1.7rem);
    --title-minor-size: 1.1rem;
    --title-line-height: 1.2;
    --title-letter-spacing: 0;
    --copy-intro-size: clamp(1rem, 1.6vw, 1.08rem);
    --copy-intro-line: 1.75;
    --copy-intro-color: #64748b;
    --copy-intro-width: 42rem;
  }
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* Focus styles for keyboard accessibility */
  *:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  button:focus-visible,
  a:focus-visible,
  input:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  /* ===== justfont Webfont — Phase 1 v2 ===== */
  /* 1. jf-jinxuanlatte (400) → 內文（金萱那提四分糖）*/
  /* 2. jf-lanyanghei (W8=800, W10=920) → UI/標題 */
  /* 3. jf-lanyangming (W3/300) → 引言 blockquote */
  /* 4. jf-kamabit (700) → 柑仔蜜：Hero 標題 + 美食分類 */
  /* 5. jf-jinxuan (medium/500) → 特殊強調 */
  /* 6. rixingsong-semibold (600) → 歷史分類標題 */

  body {
    /* 霞鶩文楷：文藝風格的台灣字體 */
    font-family: var(--font-reading);
    font-weight: 400;
    line-height: 1.75;
    color: #1a1a2e;
    background:
      radial-gradient(
        circle at top,
        rgba(226, 232, 240, 0.35),
        transparent 30%
      ),
      linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    /* 優化中文字體顯示 */
    font-feature-settings:
      'kern' 1,
      'liga' 1;
    width: 100%;
    max-width: 100vw;
  }

  /* Taiwan Typography: 標題字體層級 */
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: var(--font-title);
    letter-spacing: -0.02em;
    line-height: 1.3;
  }
  h1 {
    font-weight: 900;
    letter-spacing: -0.03em;
  }
  h2 {
    font-weight: 800;
  }
  h3,
  h4 {
    font-weight: 700;
  }
  h5,
  h6 {
    font-weight: 600;
  }

  /* Blockquote — 霞鶩文楷（文藝引言） */
  main blockquote {
    font-family: var(--font-quote);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.01em;
    line-height: 1.8;
  }

  /* Interface — Noto Sans TC 現代界面 */
  nav,
  button,
  .btn-primary,
  .btn-secondary,
  .btn-cta,
  [class*='btn'],
  .meta-item,
  .tag,
  .category-badge,
  .search-input {
    font-family: var(--font-interface);
    font-weight: 600;
  }

  /* Category-specific title fonts */
  .jf-food h1 {
    font-family: 'jf-kamabit', 'Noto Sans TC', sans-serif;
    font-weight: 700;
  }
  .jf-history h1 {
    font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;
    font-weight: 600;
  }

  /* justfont loading transition — smooth font swap */
  .jf-active *,
  .jf-inactive * {
    transition: opacity 0.3s ease-out;
  }

  /* Main - full width */
  main {
    min-height: calc(100vh - 60px);
    width: 100%;
    max-width: 100vw;
    overflow-x: hidden;
  }
  main img {
    max-width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
  }

  /* Global link styles */
  main
    a:not(.nav-link):not([class*='btn']):not(.card-link):not(.logo):not(
      .category-card
    ):not(.floating-md):not(.search-item):not(.reading-step):not(.update-item) {
    color: #475569;
    text-decoration: none;
    border-bottom: 1px solid #cbd5e1;
    padding-bottom: 1px;
    transition: all 0.2s ease;
  }
  main
    a:not(.nav-link):not([class*='btn']):not(.card-link):not(.logo):not(
      .category-card
    ):not(.floating-md):not(.search-item):not(.reading-step):not(
      .update-item
    ):hover {
    color: #1a1a2e;
    border-bottom-color: #64748b;
  }
  /* External links (with target="_blank") get an icon */
  main
    a[target='_blank']:not(.nav-link):not([class*='btn']):not(.card-link):not(
      .logo
    ):not(.category-card):not(.floating-md):not(.contributor-card)::after {
    content: '↗';
    font-size: 0.8em;
    margin-left: 0.2em;
    opacity: 0.7;
  }

  /* Floating .md button */
  .floating-md {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 48px;
    height: 48px;
    background: #1a1a2e;
    color: #3b82f6;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
