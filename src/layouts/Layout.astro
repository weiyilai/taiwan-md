---
import SEO from '../components/SEO.astro';
import Banner from '../components/Banner.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh-TW' | 'en';
  image?: string;
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
}

const { lang = 'zh-TW' } = Astro.props;
const {
  title,
  description = lang === 'en'
    ? 'Open-source knowledge base about Taiwan'
    : '讓全世界完整認識台灣',
  image,
  type,
  datePublished,
  dateModified,
  content,
  tags,
  category,
  noindex,
} = Astro.props;

// Search index now loaded via /api/search-index.json (fetch API)
const isEn = lang === 'en';
const categorySlug = category?.toLowerCase() || '';
// justfont: only put the body font class on <body> to avoid rate-limit.
// Other font classes go on specific elements (h1-h6, blockquote, nav, etc.)
const jfClass = [
  'jf-jinxuanlatte-regular',
  categorySlug ? `jf-${categorySlug}` : '',
]
  .filter(Boolean)
  .join(' ');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Taiwan Typography System -->
    <!-- Google Fonts: Noto Sans/Serif TC for fallback -->
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700;800;900&family=Noto+Serif+TC:wght@400;600;700;900&display=swap"
      rel="preload"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <!-- justfont 蘭陽明體 已透過 justfont SDK 載入，無需額外 import -->
    <!-- Fallback for critical text -->
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700;800;900&family=Noto+Serif+TC:wght@400;600;700;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{title} | Taiwan.md</title>
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Taiwan.md RSS"
      href="/rss.xml"
    />
    <SEO
      title={title}
      description={description}
      lang={lang}
      image={image}
      type={type}
      datePublished={datePublished}
      dateModified={dateModified}
      content={content}
      tags={tags}
      category={category}
    />
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-JGC5W00N7T"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-JGC5W00N7T');
    </script>
