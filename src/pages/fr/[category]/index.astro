---
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';
import Layout from '../../../layouts/Layout.astro';
import { marked } from 'marked';

import { useTranslations, getLangFromUrl } from '../../../i18n/utils';
import {
  categoryList as categories,
  getCategoryConfigs,
  type CategoryKey,
} from '../../../utils/categoryConfig';

const safeMatter = (fileContent: string) => {
  try {
    return matter(fileContent);
  } catch {
    const stripped = fileContent.replace(/^---\s*\n[\s\S]*?\n---\s*\n/, '');
    return { data: {}, content: stripped };
  }
};

export async function getStaticPaths() {
  const safeMatter = (fileContent: string) => {
    try {
      return matter(fileContent);
    } catch {
      const stripped = fileContent.replace(/^---\s*\n[\s\S]*?\n---\s*\n/, '');
      return { data: {}, content: stripped };
    }
  };

  const categoryMapping: Record<string, string> = {
    history: 'History',
    geography: 'Geography',
    culture: 'Culture',
    food: 'Food',
    art: 'Art',
    music: 'Music',
    technology: 'Technology',
    nature: 'Nature',
    people: 'People',
    society: 'Society',
    economy: 'Economy',
    lifestyle: 'Lifestyle',
  };

  const paths = [];

  for (const category of categories) {
    const folderName = categoryMapping[category];
    if (!folderName) continue;
    const articles = [];

    // ── Load _translations.json for ja article lookup ──────────────────────
    // URL convention: /fr/<cat>/<en-slug>. The index page must list articles
    // using the SAME en-slug that ja/[category]/[slug].astro generates,
    // otherwise clicking an article card leads to 404. We iterate en/ files,
    // filter by ja translation existence, and read ja frontmatter for display.
    let translations: Record<string, string> = {};
    try {
      const trPath = resolve(process.cwd(), 'knowledge', '_translations.json');
      translations = JSON.parse(await readFile(trPath, 'utf-8'));
    } catch {}
    const zhToJa: Record<string, string> = {};
    for (const [lf, zf] of Object.entries(translations)) {
      if (lf.startsWith('ja/')) zhToJa[zf] = lf;
    }

    try {
      const enFolderPath = resolve(
        process.cwd(),
        'knowledge',
        'en',
        folderName,
      );
      const enFiles = await readdir(enFolderPath);
      const enMarkdownFiles = enFiles.filter(
        (file: string) => file.endsWith('.md') && !file.startsWith('_'),
      );

      for (const file of enMarkdownFiles) {
        const enSlug = basename(file, '.md');
        // Check if ja translation exists via en→zh→ja
        const enKey = `en/${folderName}/${file}`;
        const zhFile = translations[enKey];
        if (!zhFile) continue;
        const jaFile = zhToJa[zhFile];
        if (!jaFile) continue;

        // Read ja content for title/description (in Japanese)
        const jaFilePath = resolve(process.cwd(), 'knowledge', jaFile);
        let frontmatter: Record<string, any> = {};
        let fnCount = 0;
        try {
          const jaContent = await readFile(jaFilePath, 'utf-8');
          const parsed = safeMatter(jaContent);
          frontmatter = parsed.data;
          fnCount = (jaContent.match(/^\[\^\d+\]:/gm) || []).length;
        } catch {
          continue;
        }

        articles.push({
          slug: enSlug, // Use EN slug for URL consistency with slug.astro
          title: frontmatter.title || enSlug,
          description: frontmatter.description || '',
          status: frontmatter.status || '',
          readingTime: frontmatter.readingTime || null,
          date: frontmatter.date || null,
          featured: frontmatter.featured || false,
          footnotes: fnCount,
          lang: 'fr',
        });
      }
    } catch (err) {
      console.error(
        `[ja/category/index] Error loading "${category}":`,
        (err as Error).message,
      );
    }

    let hubContent = '';
    try {
      const hubFolder = resolve(process.cwd(), 'knowledge', 'fr', folderName);
      const hubFiles = await readdir(hubFolder);
      const hubFile = hubFiles.find(
        (f) => f.startsWith('_') && f.includes('Hub'),
      );
      if (hubFile) {
        const hubPath = join(hubFolder, hubFile);
        const hubRaw = await readFile(hubPath, 'utf-8');
        const { content } = safeMatter(hubRaw);
        hubContent = content.replace(/^#\s+.+\n/, '').trim();
      }
    } catch {}

    // Compute top picks
    const computeTopPicks = () => {
      if (articles.length === 0) return [];
      const tryThr = (ft: number, nt: number) =>
        articles.filter(
          (a: any) => (a.footnotes || 0) >= (a.featured ? ft : nt),
        );
      let cands = tryThr(8, 15);
      if (cands.length < 2) cands = tryThr(3, 8);
      if (cands.length === 0) cands = articles.filter((a: any) => a.featured);
      if (cands.length === 0) return [];
      return [...cands]
        .sort((a: any, b: any) => {
          if (a.featured !== b.featured) return a.featured ? -1 : 1;
          return (b.footnotes || 0) - (a.footnotes || 0);
        })
        .slice(0, 5);
    };
    const topPicks = computeTopPicks();

    paths.push({
      params: { category },
      props: {
        category,
        hubContent,
        topPicks,
        articles: articles.sort((a, b) => {
          if (a.featured && !b.featured) return -1;
          if (!a.featured && b.featured) return 1;
          if ((b.footnotes || 0) !== (a.footnotes || 0))
            return (b.footnotes || 0) - (a.footnotes || 0);
          return a.title.localeCompare(b.title);
        }),
      },
    });
  }

  return paths;
}

const { category, hubContent, articles, topPicks } = Astro.props;

function resolveWikilinks(md: string, currentCategory: string) {
  if (!md) return md;

  function resolveOne(target: string, display?: string, bold = false) {
    const label = display || target;
    if (target.startsWith('_')) {
      const catName = target
        .replace(/^_/, '')
        .replace(/ Hub$/, '')
        .toLowerCase();
      return bold
        ? `[**${label}**](/fr/${catName})`
        : `[${label}](/fr/${catName})`;
    }
    const matchArticle = articles.find(
      (a: any) =>
        a.title === target ||
        a.slug === target ||
        a.slug === encodeURIComponent(target),
    );
    if (matchArticle) {
      const url = `/fr/${currentCategory}/${matchArticle.slug}`;
      return bold ? `[**${label}**](${url})` : `[${label}](${url})`;
    }
    return bold ? `**${label}**` : label;
  }

  // First pass: **[[X]]** → [**resolved**](/url) (bold inside link for marked CJK compat)
  md = md.replace(
    /\*\*\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]\*\*/g,
    (_, target, display) => resolveOne(target, display, true),
  );
  // Second pass: remaining [[X]]
  md = md.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, target, display) =>
    resolveOne(target, display),
  );
  return md;
}

const resolvedContent = hubContent
  ? resolveWikilinks(hubContent, category)
  : '';

// Build set of article URLs for topic-pill detection
const articleUrlSet = new Set(
  articles.map((a: any) => `/fr/${category}/${a.slug}`),
);
const categoryKeys = Object.keys({
  history: 1,
  geography: 1,
  culture: 1,
  food: 1,
  art: 1,
  music: 1,
  technology: 1,
  nature: 1,
  people: 1,
  society: 1,
  economy: 1,
  lifestyle: 1,
});

// Topic-pill link renderer for hub pages
const hubRenderer = new marked.Renderer();
hubRenderer.image = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  const altText = text || '';
  return `<img src="${href}" alt="${altText}"${titleAttr} loading="lazy" onerror="this.onerror=null;this.classList.add('img-broken')" />`;
};
hubRenderer.link = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  const h = href || '';
  const isArticleLink = articleUrlSet.has(decodeURIComponent(h));
  const isCategoryLink = categoryKeys.some(
    (k) => h === `/fr/${k}` || h === `/fr/${k}/`,
  );
  if (isArticleLink || isCategoryLink) {
    return `<a class="topic-pill" href="${h}"${titleAttr}>${text}</a>`;
  }
  return `<a href="${h}"${titleAttr}>${text}</a>`;
};

// Post-process: add callout/pull-quote classes to blockquotes
function enrichBlockquotes(html: string): string {
  if (!html) return html;
  const calloutMap: Record<string, string> = {
    '📝': 'callout-note',
    '⚠️': 'callout-warning',
    '💡': 'callout-tip',
    '📊': 'callout-data',
  };
  return html.replace(
    /<blockquote>([\s\S]*?)<\/blockquote>/g,
    (match, inner) => {
      if (inner.includes('✦')) {
        return `<blockquote class="pull-quote">${inner}</blockquote>`;
      }
      for (const [emoji, cls] of Object.entries(calloutMap)) {
        if (inner.includes(emoji) && inner.includes('<strong>')) {
          return `<blockquote class="${cls}">${inner}</blockquote>`;
        }
      }
      return match;
    },
  );
}

const rawHubHtml = resolvedContent
  ? marked.parse(resolvedContent, { renderer: hubRenderer, breaks: true })
  : '';
const hubHtml = enrichBlockquotes(rawHubHtml as string);

// Split hub HTML into hook (first 3 paragraphs, no headings) and full essay
let hubHook = '';
let hubFull = hubHtml;
if (hubHtml) {
  // Strip leading headings (h1, h2) from the beginning
  let stripped = (hubHtml as string)
    .replace(/^(\s*<h[12][^>]*>[\s\S]*?<\/h[12]>\s*)+/i, '')
    .trim();
  // Find the end of the 3rd </p> tag
  let cutIndex = -1;
  let pCount = 0;
  const pCloseRegex = /<\/p>/gi;
  let match;
  while ((match = pCloseRegex.exec(stripped)) !== null) {
    pCount++;
    if (pCount === 3) {
      cutIndex = match.index + match[0].length;
      break;
    }
  }
  if (cutIndex > 0 && cutIndex < stripped.length * 0.7) {
    hubHook = stripped.slice(0, cutIndex);
    hubFull = hubHtml;
  }
}

// Group articles by subcategory
const subcategoryGroups: { name: string; articles: any[] }[] = [];
const subcatMap = new Map<string, any[]>();
for (const article of articles) {
  const sub = (article as any).subcategory || 'その他';
  if (!subcatMap.has(sub)) subcatMap.set(sub, []);
  subcatMap.get(sub)!.push(article);
}
for (const [name, arts] of [...subcatMap.entries()].sort((a, b) => {
  if (a[0] === 'その他') return 1;
  if (b[0] === 'その他') return -1;
  return a[0].localeCompare(b[0]);
})) {
  subcategoryGroups.push({ name, articles: arts });
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const categoryConfigs = getCategoryConfigs(t);
const categoryInfo = categoryConfigs[category];

// Other categories (sidebar cross-category nav)
const otherCategories = categories
  .filter((cat) => cat !== category)
  .map((cat) => ({
    key: cat,
    ...categoryConfigs[cat as CategoryKey],
  }));
---

<Layout
  title={`${categoryInfo.name} - Taiwan.md`}
  description={`${categoryInfo.description} - Taiwan knowledge base`}
  lang="en"
  category={categoryInfo.name}
>
  <!--
    Phase 6 partial migration — ja/[category]/index.astro
    ─────────────────────────────────────────────────────
    Wrappers (header, hub-layout, sidebar, featured strip, articles
    toolbar, article-row list, hub essay wrapper, coming-soon
    fallback) moved to inline Tailwind. Kept scoped:
    - .hub-prose :global(*) — hub essay is innerHTML'd via set:html={hubHtml}
    - .header-hook-prose :global(*) — hub hook is also innerHTML'd
    - .category-page class kept as hook (global.css base rule)
    - The `.articles-main` id="articlesGrid" hook, `.article-row`
      class, `#noResults` id, `.subcategory-section` class, and
      `#articleFilter` id all kept as CSS hooks referenced by the
      JS in the <script> block above
  -->
  <main class="category-page">
    <!-- Category Header (compact bar + curatorial hook fused) -->
    <div
      class="bg-[var(--categoryColorLight)] pb-5 pt-3"
      style={`border-bottom: 2px solid ${categoryInfo.color};`}
    >
      <div class="mx-auto max-w-[1200px] px-8 max-[768px]:px-4">
        <nav
          class="mb-1 flex items-center gap-2 text-[0.9rem] [&>a:hover]:underline [&>a]:font-medium [&>a]:no-underline"
          style={`--breadcrumb-color: ${categoryInfo.color};`}
        >
          <a
            href="/ja"
            class="text-[var(--breadcrumb-color)]"
            style={`color: ${categoryInfo.color};`}>ホーム</a
          >
          <span class="text-[#9ca3af]">›</span>
          <span class="font-semibold text-[#6b7280]">{categoryInfo.name}</span>
        </nav>
        <div class="flex flex-wrap items-baseline gap-2">
          <span class="text-[1.5rem]">{categoryInfo.icon}</span>
          <h1
            class="m-0 text-[1.5rem] font-extrabold"
            style={`color: ${categoryInfo.color}`}
          >
            {categoryInfo.name}
          </h1>
          <span class="font-light text-[#94a3b8] max-[768px]:hidden">·</span>
          <span
            class="max-w-[50%] truncate text-[0.88rem] text-[#64748b] max-[768px]:hidden"
            >{categoryInfo.description}</span
          >
          <span
            class="ml-auto rounded-[12px] bg-[#f1f5f9] px-2 py-[0.15rem] text-[0.78rem] text-[#94a3b8]"
            >{articles.length} 記事</span
          >
        </div>
        {
          hubHook && (
            <div class="mt-3 max-w-[800px] text-[0.92rem] leading-[1.75] text-[#475569] max-[768px]:text-[0.85rem]">
              <div class="header-hook-prose" set:html={hubHook} />
              <a
                href="#hub-essay"
                class="mt-2 inline-block text-[0.82rem] font-semibold text-[var(--categoryColor)] no-underline transition-all duration-150 hover:underline"
              >
                キュレーション全文を読む →
              </a>
            </div>
          )
        }
      </div>
    </div>

    <div
      class="mx-auto max-w-[1200px] px-8 py-8 max-[768px]:px-4 max-[768px]:py-4"
    >
      {/* Main two-column layout: sidebar + content */}
      {
        articles.length > 0 ? (
          <div class="mt-4 flex items-start gap-8 max-[768px]:flex-col max-[768px]:gap-0">
            <aside class="sticky top-[72px] w-[180px] flex-shrink-0 self-start max-[768px]:static max-[768px]:w-full max-[768px]:max-h-none max-[768px]:overflow-visible">
              {subcategoryGroups.length > 1 && (
                <nav class="flex flex-col gap-1 max-[768px]:flex-row max-[768px]:flex-wrap max-[768px]:gap-[0.3rem] max-[768px]:border-b max-[768px]:border-[#e2e8f0] max-[768px]:pb-4 max-[768px]:mb-4">
                  <span class="mb-[0.3rem] border-b border-[#e2e8f0] px-2 pb-[0.4rem] text-[0.7rem] font-bold uppercase tracking-[0.1em] text-[#94a3b8] max-[768px]:hidden">
                    トピック
                  </span>
                  {subcategoryGroups.map((group) => (
                    <a
                      href={`#sub-${group.name}`}
                      class="flex items-center justify-between rounded px-2 py-[0.35rem] text-[0.82rem] text-[#475569] no-underline transition-all duration-150 hover:bg-[rgba(45,80,22,0.06)] hover:text-[var(--categoryColor,#2d5016)] max-[768px]:rounded-2xl max-[768px]:border max-[768px]:border-[#e2e8f0] max-[768px]:bg-[#f8fafc] max-[768px]:px-[0.6rem] max-[768px]:py-1 max-[768px]:text-[0.78rem]"
                    >
                      {group.name}
                      <span class="min-w-[1.2rem] rounded-lg bg-[#f1f5f9] px-[0.35rem] py-[0.1rem] text-center text-[0.7rem] text-[#94a3b8]">
                        {group.articles.length}
                      </span>
                    </a>
                  ))}
                </nav>
              )}

              <div class="my-3 h-px bg-[#e2e8f0] max-[768px]:hidden" />
              <nav class="flex flex-col gap-1 max-[768px]:hidden">
                <span class="mb-[0.3rem] border-b border-[#e2e8f0] px-2 pb-[0.4rem] text-[0.7rem] font-bold uppercase tracking-[0.1em] text-[#94a3b8]">
                  他のトピック
                </span>
                {otherCategories.map((cat) => (
                  <a
                    href={`/fr/${cat.key}`}
                    class="flex items-center justify-between rounded px-2 py-[0.35rem] text-[0.78rem] text-[#475569] no-underline opacity-75 transition-all duration-150 hover:bg-[rgba(45,80,22,0.06)] hover:text-[var(--categoryColor,#2d5016)] hover:opacity-100"
                  >
                    <span>
                      {cat.icon} {cat.name}
                    </span>
                  </a>
                ))}
              </nav>
            </aside>

            <div class="min-w-0 flex-1">
              {/* Featured chips */}
              {topPicks && topPicks.length > 0 && (
                <div class="mb-4 flex flex-wrap items-center gap-2 border-b border-[#e2e8f0] pb-3 max-[768px]:flex-nowrap max-[768px]:overflow-x-auto max-[768px]:pb-2 max-[768px]:[-webkit-overflow-scrolling:touch]">
                  <span class="flex-shrink-0 text-[0.72rem] font-bold uppercase tracking-[0.08em] text-[var(--categoryColor)]">
                    注目
                  </span>
                  {topPicks.slice(0, 3).map((article: any) => (
                    <a
                      href={`/fr/${category}/${encodeURIComponent(article.slug)}`}
                      class="whitespace-nowrap rounded-2xl border border-transparent bg-[var(--categoryColorLight)] px-[0.6rem] py-[0.2rem] text-[0.82rem] font-semibold text-[var(--categoryColor)] no-underline transition-all duration-150 hover:border-[var(--categoryColor)] hover:bg-white"
                    >
                      ★ {article.title}
                    </a>
                  ))}
                </div>
              )}

              {/* Articles list */}
              <div class="articles-main min-w-0 flex-1" id="articlesGrid">
                <div class="mb-4">
                  <input
                    type="text"
                    class="w-full max-w-[320px] rounded-md border border-[#e2e8f0] px-3 py-[0.45rem] text-[0.85rem] outline-none transition-colors duration-200 focus:border-[var(--categoryColor,#2d5016)] focus:shadow-[0_0_0_2px_rgba(45,80,22,0.08)]"
                    id="articleFilter"
                    placeholder="記事を検索..."
                    autocomplete="off"
                  />
                </div>

                {subcategoryGroups.map((group) => (
                  <div class="subcategory-section" id={`sub-${group.name}`}>
                    {subcategoryGroups.length > 1 && (
                      <h3 class="mb-2 mt-6 flex items-center gap-2 border-b-2 border-[var(--categoryColor,#e2e8f0)] pb-[0.4rem] text-[1rem] font-bold text-[#334155] [.subcategory-section:first-child_&]:mt-0">
                        {group.name}
                        <span class="text-[0.72rem] font-normal text-[#94a3b8]">
                          {group.articles.length}
                        </span>
                      </h3>
                    )}
                    <div class="flex flex-col">
                      {group.articles.map((article: any) => (
                        <a
                          href={`/fr/${category}/${encodeURIComponent(article.slug)}`}
                          class={`article-row ${article.featured ? 'is-featured' : ''}`}
                          data-title={article.title}
                        >
                          <div class="row-main">
                            <div class="row-title-line">
                              {article.featured && (
                                <span class="row-star">★</span>
                              )}
                              <h3 class="row-title">{article.title}</h3>
                            </div>
                            {article.description && (
                              <p class="row-desc">
                                {article.description.length > 120
                                  ? article.description.slice(0, 117) + '...'
                                  : article.description}
                              </p>
                            )}
                          </div>
                          <div class="row-meta">
                            {(article.footnotes || 0) > 0 && (
                              <span class="row-fn">
                                {article.footnotes} 引用
                              </span>
                            )}
                            {article.readingTime && (
                              <span class="row-time">
                                {article.readingTime} min
                              </span>
                            )}
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}

                <div
                  class="hidden p-8 text-center text-[#94a3b8]"
                  id="noResults"
                >
                  <p>条件に一致する記事が見つかりません</p>
                </div>
              </div>

              {/* Full Hub Essay */}
              {hubHtml && (
                <section
                  class="my-8 mb-12 rounded-2xl border border-[#e2e8f0] bg-white p-10 shadow-[0_1px_3px_rgba(0,0,0,0.04)]"
                  id="hub-essay"
                >
                  <h2 class="mb-2 mt-12 border-t-2 border-[#e2e8f0] pt-8 text-[1.15rem] font-bold text-[#334155]">
                    {categoryInfo.icon} キュレーション
                  </h2>
                  <div class="hub-prose" set:html={hubHtml} />
                </section>
              )}
            </div>
          </div>
        ) : (
          <section class="px-8 py-16 text-center max-[768px]:px-4">
            <div class="mx-auto max-w-[500px]">
              <div class="mb-8 text-[5rem] opacity-70">{categoryInfo.icon}</div>
              <h2 class="mb-4 text-[2.5rem] font-bold text-[#1f2937]">
                コンテンツ準備中
              </h2>
              <p class="mb-6 text-[1.1rem] leading-[1.6] text-[#6b7280]">
                このカテゴリの記事は準備中です。お楽しみに！
              </p>
              <p class="!mb-12 text-[1.1rem] font-medium italic text-[var(--categoryColor)]">
                準備中：{categoryInfo.description}
              </p>
              <div class="flex flex-wrap justify-center gap-4 max-[768px]:flex-col max-[768px]:items-center">
                <a
                  href="/ja"
                  class="inline-flex items-center gap-2 rounded-xl bg-[var(--categoryColor)] px-8 py-4 font-semibold text-white no-underline transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_16px_rgba(0,0,0,0.2)]"
                >
                  ホームに戻る
                </a>
                <a
                  href="https://github.com/frank890417/taiwan-md"
                  target="_blank"
                  class="inline-flex items-center gap-2 rounded-xl border-2 border-[var(--categoryColor)] bg-white px-8 py-4 font-semibold text-[var(--categoryColor)] no-underline transition-all duration-300 hover:-translate-y-0.5 hover:bg-[var(--categoryColor)] hover:text-white"
                >
                  貢献する
                </a>
              </div>
            </div>
          </section>
        )
      }
    </div>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('articlesGrid');
    const noResults = document.getElementById('noResults');
    const filterInput = document.getElementById(
      'articleFilter',
    ) as HTMLInputElement;
    if (!grid) return;

    const rows = Array.from(
      grid.querySelectorAll('.article-row'),
    ) as HTMLElement[];
    const subcategorySections = Array.from(
      grid.querySelectorAll('.subcategory-section'),
    ) as HTMLElement[];

    function applyFilters() {
      const query = filterInput?.value.toLowerCase() || '';
      let visible = 0;
      rows.forEach((row) => {
        const title = (row.dataset.title || '').toLowerCase();
        const show = !query || title.includes(query);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      subcategorySections.forEach((section) => {
        const sectionRows = section.querySelectorAll(
          '.article-row',
        ) as NodeListOf<HTMLElement>;
        const anyVisible = Array.from(sectionRows).some(
          (r) => r.style.display !== 'none',
        );
        section.style.display = anyVisible ? '' : 'none';
      });
      if (noResults) {
        noResults.classList.toggle('hidden', visible !== 0);
      }
    }

    filterInput?.addEventListener('input', () => {
      applyFilters();
    });
  });
</script>

