---
import Layout from '../../layouts/Layout.astro';
import { readdir, readFile } from 'fs/promises';
import { resolve, join } from 'path';
import { parse as parseYaml } from 'yaml';
import { createRequire } from 'module';

// ── Build-time: s2t converter for normalizing china values ────────────────────
// We use opencc-js at build time to convert any simplified Chinese china values
// to traditional Chinese, since the frontend OpenCC already converts input text
// from simplified → traditional before matching against our rules.
let s2tConverter: ((text: string) => string) | null = null;
try {
  const require = createRequire(import.meta.url);
  const OpenCC = require('opencc-js');
  // Converter({from:'cn', to:'tw'}) converts simplified→traditional (Taiwan standard)
  // This matches what the frontend does before terminology matching
  // Both build-time and frontend must use the same conversion to ensure rules match
  s2tConverter = OpenCC.Converter({ from: 'cn', to: 'tw' });
} catch {
  console.warn('[converter.astro] opencc-js not available, china values may not match simplified input');
}

function toTraditional(text: string): string {
  if (!s2tConverter) return text;
  try { return s2tConverter(text); } catch { return text; }
}

/**
 * Extract the primary source term from a china value that may contain
 * slash-separated variants or parenthetical annotations.
 * This mirrors the logic in scripts/tools/terminology-clean.py.
 */
function cleanChinaSource(raw: string): string {
  if (!raw || raw.startsWith('N/A') || raw.startsWith('（無')) return raw;
  let s = raw;
  // Remove parenthetical annotations like （簡）（中國）（舊）etc.
  s = s.replace(/（[^）]*）/g, '');
  s = s.replace(/\([^)]*\)/g, '');
  // Take first variant if slash-separated
  if (s.includes('/')) {
    s = s.split('/')[0];
  }
  return s.trim();
}

// ── Build-time: generate conversion rules from YAML files ─────────────────────
interface TermEntry {
  id: string;
  category?: string;
  subcategory?: string;
  fork_type?: string;
  display: {
    taiwan: string;
    china?: string;
    hongkong?: string;
  };
  notes?: string;
  sources?: string[];
}

interface ConversionRule {
  source: string;
  target: string;
  forkType: string;
  category: string;
  id: string;
}

const termDir = resolve(process.cwd(), 'data/terminology');
const files = await readdir(termDir);
const rules: ConversionRule[] = [];
// Track seen sources to avoid duplicates
const seenSources = new Set<string>();

for (const file of files) {
  if (!file.endsWith('.yaml') || file.startsWith('_')) continue;
  const raw = await readFile(join(termDir, file), 'utf-8');
  try {
    const d = parseYaml(raw) as TermEntry;
    // Support both display.{china,taiwan} and top-level {china,taiwan} formats
    const chinaVal = d?.display?.china || (d as any)?.china;
    const taiwanVal = d?.display?.taiwan || (d as any)?.taiwan;
    if (
      d &&
      chinaVal &&
      taiwanVal &&
      chinaVal !== taiwanVal
    ) {
      const forkType = d.fork_type || (d as any)?.type || '';
      const category = d.category || '';
      const id = d.id || file.replace('.yaml', '');
      const target = taiwanVal;
      const chinaRaw = chinaVal;

      // Step 1: Clean the raw china value (strip annotations, take first slash variant)
      const chinaCleaned = cleanChinaSource(chinaRaw);

      // Skip if value is N/A, （無直接對應）, or cleaned result equals taiwan
      if (!chinaCleaned || chinaCleaned === target) continue;
      if (chinaCleaned.startsWith('N/A') || chinaCleaned.startsWith('（無')) continue;

      // Step 2: Normalize to traditional Chinese so it matches
      // the frontend's OpenCC-converted input text
      const chinaTraditional = toTraditional(chinaCleaned);

      // Add rule for the traditional form (the primary matching source)
      if (!seenSources.has(chinaTraditional) && chinaTraditional !== target) {
        rules.push({ source: chinaTraditional, target, forkType, category, id });
        seenSources.add(chinaTraditional);
      }

      // If the original simplified form differs from traditional, also add
      // a fallback rule for the simplified form (for when OpenCC is unavailable)
      if (chinaCleaned !== chinaTraditional && !seenSources.has(chinaCleaned) && chinaCleaned !== target) {
        rules.push({ source: chinaCleaned, target, forkType, category, id: id + '_simp' });
        seenSources.add(chinaCleaned);
      }
    }
  } catch {
    // skip malformed
  }
}

// Sort by source length descending (longer matches first to avoid partial replacement)
rules.sort((a, b) => b.source.length - a.source.length);

const rulesJSON = JSON.stringify(rules);
---

<Layout title="🔄 用語轉換器 — Taiwan.md">
  <!-- Preload OpenCC for faster mobile loading -->
  <link rel="modulepreload" href="https://cdn.jsdelivr.net/npm/opencc-js@1/dist/esm/cn2t.js" />
  <main class="conv-page">
    <!-- ── Header ──────────────────────────────────────────────────── -->
    <div class="conv-header">
      <div class="header-inner">
        <h1>
          🔄 用語轉換器 <span class="header-en">Terminology Converter</span>
        </h1>
        <p class="header-tagline">
          把中國用語轉換為台灣用語——不只是字形，是語感。
        </p>
        <div class="header-bottom">
          <div class="header-stats">
            <span class="stat"><strong>{rules.length}</strong> 條轉換規則</span>
          </div>
          <div class="header-links">
            <a href="/terminology" class="fork-link-btn"> ← 回到詞庫 </a>
            <a href="/fork-graph" class="fork-link-btn"> 🌿 語言分支樹 </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Main converter area ─────────────────────────────────────── -->
    <div class="conv-body">
      <div class="conv-inner">
        <!-- Two-column editor -->
        <div class="editor-grid">
          <div class="editor-panel">
            <div class="panel-label">輸入文字</div>
            <div class="input-wrapper">
              <div id="input-highlight" class="input-highlight" aria-hidden="true"></div>
              <textarea
                id="input-text"
                class="editor-textarea"
                placeholder="在這裡貼入文字…

例如：這個軟件視頻很有用，可以通過下載來使用。"
                spellcheck="false"></textarea>
            </div>
          </div>

          <div class="editor-panel">
            <div class="panel-label">轉換結果</div>
            <div id="output-text" class="editor-output" aria-live="polite">
              <span class="output-placeholder"
                >轉換結果會顯示在這裡，<mark class="sample-mark">替換的詞</mark> 會被醒目標示。</span
              >
            </div>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="action-bar">
          <button id="btn-convert" class="btn btn-primary">🔄 轉換</button>
          <button id="btn-clear" class="btn btn-secondary">✕ 清除</button>
          <button id="btn-copy" class="btn btn-secondary" disabled
            >📋 複製結果</button
          >
          <span class="action-sep"></span>
          <span class="example-label">試試看：</span>
          <button class="btn btn-example" data-example="tech">💻 科技文</button>
          <button class="btn btn-example" data-example="life">🍜 生活文</button>
          <button class="btn btn-example" data-example="news">📰 新聞稿</button>
          <button class="btn btn-example" data-example="medical">🏥 醫療</button>
          <button class="btn btn-example" data-example="school">🎓 校園</button>
          <button class="btn btn-example" data-example="social">📱 社群</button>
          <button class="btn btn-example" data-example="gaming">🎮 遊戲</button>
          <button class="btn btn-example" data-example="office">💼 職場</button>
        </div>

        <!-- Analysis report -->
        <div id="analysis" class="analysis-box" hidden>
          <div class="analysis-header">
            <span id="analysis-title" class="analysis-title"></span>
          </div>

          <div id="opencc-status" class="opencc-status-row" hidden></div>

          <div id="must-change" class="analysis-section" hidden>
            <div class="section-label label-red">🔴 必換（A / B 類）</div>
            <ul id="must-list" class="change-list"></ul>
          </div>

          <div id="suggest-change" class="analysis-section" hidden>
            <div class="section-label label-yellow">🟡 建議（其他類）</div>
            <ul id="suggest-list" class="change-list"></ul>
          </div>

          <div class="taiwan-index-row">
            <span class="index-label">📊 台灣化指數</span>
            <span id="index-before" class="index-val before"></span>
            <span class="index-arrow">→</span>
            <span id="index-after" class="index-val after"></span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script define:vars={{ rulesJSON }}>
    // ── Parse rules injected from build time ────────────────────────────────
    const RULES = JSON.parse(rulesJSON);
    const GITHUB_BASE =
      'https://github.com/frank890417/taiwan-md/blob/main/data/terminology/';

    // ── OpenCC (簡→繁) setup ─────────────────────────────────────────────────
    let openccConverter = null;
    let openccStatus = 'loading'; // 'loading' | 'ready' | 'failed'

    async function initOpenCC() {
      // Try multiple CDN sources with timeout for mobile reliability
      const cdnUrls = [
        'https://cdn.jsdelivr.net/npm/opencc-js@1/dist/esm/cn2t.js',
        'https://unpkg.com/opencc-js@1/dist/esm/cn2t.js',
      ];
      for (const url of cdnUrls) {
        try {
          // Race import against a timeout (8s for mobile networks)
          const OpenCC = await Promise.race([
            import(/* @vite-ignore */ url),
            new Promise((_, reject) =>
              setTimeout(() => reject(new Error('timeout')), 8000)
            ),
          ]);
          // Use cn → tw (standard traditional Chinese used in Taiwan)
          // cn → t produces archaic characters (麪/喫/裏) that nobody uses,
          // cn → tw produces modern traditional (麵/吃/裡) matching our terminology rules.
          openccConverter = OpenCC.ConverterFactory(
            OpenCC.Locale.from.cn,
            OpenCC.Locale.to.tw,
          );
          openccStatus = 'ready';
          return; // success
        } catch (e) {
          console.warn(`OpenCC from ${url} failed:`, e.message);
        }
      }
      // All CDN sources failed
      console.warn('OpenCC 載入失敗，僅做用語替換（字形轉換不可用）');
      openccStatus = 'failed';
    }
    initOpenCC();

    // Apply OpenCC to text outside of HTML tags
    function applyOpenCC(html) {
      if (!openccConverter) return html;
      // Replace text nodes (content between tags) but skip content inside tags themselves
      return html.replace(/>([^<]+)</g, (match, text) => {
        return '>' + openccConverter(text) + '<';
      });
    }

    // ── DOM refs ────────────────────────────────────────────────────────────
    const inputEl = document.getElementById('input-text');
    const outputEl = document.getElementById('output-text');
    const btnConvert = document.getElementById('btn-convert');
    const btnClear = document.getElementById('btn-clear');
    const btnCopy = document.getElementById('btn-copy');
    const analysisEl = document.getElementById('analysis');
    const analysisTitleEl = document.getElementById('analysis-title');
    const openccStatusEl = document.getElementById('opencc-status');
    const mustSection = document.getElementById('must-change');
    const mustList = document.getElementById('must-list');
    const suggestSection = document.getElementById('suggest-change');
    const suggestList = document.getElementById('suggest-list');
    const indexBefore = document.getElementById('index-before');
    const indexAfter = document.getElementById('index-after');

    // ── Example texts ─────────────────────────────────────────────────────────
    const EXAMPLES = {
      tech: `最近在学习编程，发现这个软件的视频教程非常实用，信息量很大。用户可以通过下载客户端来使用云存储功能，支持多种操作系统。程序员们在论坛上分享了很多关于人工智能和机器学习的干货内容，楼主还贴心地整理了一份默认配置的排查攻略。如果遇到网络问题，可以尝试刷新缓存或者重启路由器。有个大佬在评论区说他用硬盘做了个集成方案，性价比超高，帧率提升明显。`,
      life: `周末去了一家超级棒的网红餐厅打卡，排了半小时队。点了好几个硬菜，还有用破壁机做的猕猴桃奶昔，味道很赞。服务员小姐姐态度很好，上菜速度很快。吃完饭打车回家，堵车堵了二十分钟，在路上刷手机看了会儿短视频，一个博主分享减肥健身攻略，质量很高。回到小区后去便利店买了酸奶和方便面当宵夜，顺便用洗发水的优惠券囤了几瓶。闺蜜发消息说明天约下午茶，立马答应了。`,
      news: `据报道，该项目总投资达到数十亿元人民币，将在未来三年内建设完成。相关部门通过多个渠道表示，这一举措将有效提升城市基础设施水平，惠及数百万群众。多位专家在接受采访时指出，该政策的出台对于促进经济高质量发展具有重要意义，底层逻辑很清晰。志愿者团队也在积极配合推进工作，国企方面已开始对接落实。与此同时，有关方面估计配套措施将在本月底前全面到位。`,
      medical: `早上好，去医院做了个体检，医生说血压偏高需要注意饮食。挂号排队等了半小时，做了个B超和验血，还贴了个创口贴。护士小姐姐很温柔，说打针一点都不疼，果然没什么感觉。开了几盒处方药，去药房取了药就回家了。回来路上买了杯酸奶补充下。现在每天都在用手机上的健康软件记录运动数据和血压信息，反馈给医生看诊时参考。得了忧郁症的朋友也推荐我多运动。`,
      school: `新学期开始了，教授布置了一个关于人工智能的项目作业，估计要花两三周才能完成。同学们在网上搜索资料，下载了很多学术论文和视频教程。学校的宽带网络很快，在线看课程完全不卡。学霸室友已经开始刷题复习了，他的绩点一直是年级第一。我这个学渣只能抱佛脚。图书馆太内卷了，连座位都要抢。晚上回宿舍叫了外卖，用手机充值了饭卡。`,
      social: `今天在社交媒体上发了条帖子，没想到阅读量破万了，颜值高的照片就是自带流量。好多网友在评论区互动讨论，有人艾特我说内容很走心。闺蜜转发到朋友圈，我也收到了很多点赞和关注。有个粉丝说"YYDS"，还有人说"绝绝子"。晚上开了个直播跟粉丝聊天，网络信号很好完全不卡顿。有个喷子在弹幕里阴阳怪气，直接拉黑屏蔽了。`,
      gaming: `最新的这款游戏画质太赞了，高清模式下帧率稳定在60帧，触控屏操作也很丝滑。下载了最新的补丁包更新后，服务器延迟明显降低了。和队友开了语音聊天组队打排位赛，操作手感比上个版本流畅多了。有个萌新在鱼塘局里被炸鱼的大佬虐得很惨，白给了好几次。游戏内置的社交系统很方便，可以直接发消息给好友，不过微交易的性价比一般。`,
      office: `新来的项目经理安排了一个视频会议，讨论软件开发的进度。我们需要更新数据库，优化用户界面的交互设计。设计师用鼠标在触控屏上操作，调整了对话框和下拉菜单的样式。文档已经上传到云端硬盘，大家可以在线协作编辑。领导说这个方案很靠谱，底气很足。同事通过渠道反馈了客户的需求，我们立马开始排查问题。下班后打车回家，堵车估计要半小时。`,
    };

    // ── Core convert function ───────────────────────────────────────────────
    function convertText(input) {
      if (!input.trim()) return { html: '', matches: [] };

      const matches = [];
      let text = input;

      // Step 1: Apply OpenCC (字形 only: 简→繁) FIRST,
      // so terminology rules can match traditional Chinese source terms
      if (openccConverter) {
        text = openccConverter(text);
      }

      // Step 2: Apply terminology replacements (rules sorted by source.length desc)
      // Use a marker system to avoid double-replacing
      const placeholders = [];
      let markerIdx = 0;

      for (const rule of RULES) {
        if (text.includes(rule.source)) {
          const marker = `\x00${markerIdx}\x00`;
          const escapedSource = rule.source.replace(
            /[.*+?^${}()|[\]\\]/g,
            '\\$&',
          );
          const count = (text.match(new RegExp(escapedSource, 'g')) || [])
            .length;
          if (count > 0) {
            matches.push({ ...rule, count });
            text = text.replace(new RegExp(escapedSource, 'g'), marker);
            placeholders.push({ marker, target: rule.target });
            markerIdx++;
          }
        }
      }

      // Escape HTML in the modified text
      let escaped = text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\n/g, '<br>');

      // Replace markers with highlighted spans
      // For multi-option targets (e.g. "高手 / 大大"), show only the first
      // option in the text body and put the full list in a tooltip
      for (const { marker, target } of placeholders) {
        const parts = target.split(/\s*\/\s*/);
        const primary = parts[0];
        let html;
        if (parts.length > 1) {
          const tooltip = escHtml(target);
          html = `<mark class="replaced-word has-alts" title="${tooltip}">${primary}</mark>`;
        } else {
          html = `<mark class="replaced-word">${primary}</mark>`;
        }
        escaped = escaped.split(marker).join(html);
      }

      return { html: escaped, matches };
    }

    // ── Highlight source (original) text — mark matched china terms ─────────
    // Strategy: find match positions in the OpenCC-converted text,
    // then apply highlights at the same character positions in the original text.
    // Chinese simplified→traditional is 1:1 character mapping, so positions align.
    function highlightSource(input, matches) {
      if (!input.trim() || matches.length === 0) return '';

      // Step 1: Get the OpenCC-converted text (same as convertText does)
      let converted = input;
      if (openccConverter) {
        converted = openccConverter(input);
      }

      // Step 2: Find all match positions in the converted text
      // (same order as convertText: longest first, no overlaps)
      const regions = []; // { start, end } in character positions
      let working = converted;
      const used = new Array(converted.length).fill(false);

      for (const m of matches) {
        let idx = 0;
        while ((idx = working.indexOf(m.source, idx)) !== -1) {
          // Check no overlap with already-marked regions
          let overlap = false;
          for (let i = idx; i < idx + m.source.length; i++) {
            if (used[i]) { overlap = true; break; }
          }
          if (!overlap) {
            regions.push({ start: idx, end: idx + m.source.length });
            for (let i = idx; i < idx + m.source.length; i++) used[i] = true;
          }
          idx += m.source.length;
        }
      }

      // Step 3: Sort regions by position
      regions.sort((a, b) => a.start - b.start);

      // Step 4: Build HTML from the ORIGINAL input using region positions
      let html = '';
      let pos = 0;
      for (const r of regions) {
        // Text before this match (from original)
        html += escHtml(input.substring(pos, r.start));
        // The matched portion (from original, same positions)
        html += `<mark class="source-word">${escHtml(input.substring(r.start, r.end))}</mark>`;
        pos = r.end;
      }
      html += escHtml(input.substring(pos));
      html = html.replace(/\n/g, '<br>');

      return html;
    }

    // ── Compute Taiwan-ization index ────────────────────────────────────────
    function computeIndex(input, matches) {
      if (!input.trim()) return { before: 100, after: 100 };
      const totalChars = input.replace(/\s/g, '').length || 1;
      let chinaChars = 0;
      for (const m of matches) {
        chinaChars += m.source.length * m.count;
      }
      const before = Math.round(
        Math.max(0, ((totalChars - chinaChars) / totalChars) * 100),
      );
      return { before, after: 100 };
    }

    // ── Render OpenCC status ────────────────────────────────────────────────
    function renderOpenCCStatus(hasMatches) {
      if (!openccStatusEl) return;
      if (openccStatus === 'ready') {
        openccStatusEl.hidden = false;
        openccStatusEl.className = 'opencc-status-row opencc-ready';
        openccStatusEl.textContent = '🔤 簡體→繁體字形轉換：已套用 OpenCC';
      } else if (openccStatus === 'failed') {
        openccStatusEl.hidden = false;
        openccStatusEl.className = 'opencc-status-row opencc-failed';
        openccStatusEl.textContent = '⚠️ 簡→繁字形轉換載入中或不可用，用語替換仍正常運作（建議先手動轉為繁體再貼入）';
      } else {
        openccStatusEl.hidden = true;
      }
    }

    // ── Render analysis report ──────────────────────────────────────────────
    function renderAnalysis(matches) {
      if (matches.length === 0) {
        // Still show analysis box if OpenCC info is relevant
        const showForOpenCC =
          openccStatus === 'ready' || openccStatus === 'failed';
        if (!showForOpenCC) {
          analysisEl.hidden = true;
          return;
        }
        analysisEl.hidden = false;
        analysisTitleEl.textContent = `✅ 未偵測到中國用語`;
        renderOpenCCStatus(false);
        mustSection.hidden = true;
        suggestSection.hidden = true;
        return;
      }

      analysisEl.hidden = false;
      analysisTitleEl.textContent = `偵測到 ${matches.length} 個中國用語`;
      renderOpenCCStatus(true);

      const mustMatches = matches.filter(
        (m) => m.forkType === 'A' || m.forkType === 'B',
      );
      const suggestMatches = matches.filter(
        (m) => m.forkType !== 'A' && m.forkType !== 'B',
      );

      // Must-change
      if (mustMatches.length > 0) {
        mustSection.hidden = false;
        mustList.innerHTML = mustMatches
          .map(
            (m) => `
          <li class="change-item">
            <span class="change-source">${escHtml(m.source)}</span>
            <span class="change-arrow">→</span>
            <span class="change-target">${escHtml(m.target)}</span>
            ${m.count > 1 ? `<span class="change-count">×${m.count}</span>` : ''}
            <a href="${GITHUB_BASE}${encodeURIComponent(m.id)}.yaml" target="_blank" rel="noopener" class="github-link" title="查看詞源">🔗</a>
          </li>
        `,
          )
          .join('');
      } else {
        mustSection.hidden = true;
      }

      // Suggest
      if (suggestMatches.length > 0) {
        suggestSection.hidden = false;
        suggestList.innerHTML = suggestMatches
          .map(
            (m) => `
          <li class="change-item">
            <span class="change-source">${escHtml(m.source)}</span>
            <span class="change-arrow">→</span>
            <span class="change-target">${escHtml(m.target)}</span>
            ${m.count > 1 ? `<span class="change-count">×${m.count}</span>` : ''}
            <a href="${GITHUB_BASE}${encodeURIComponent(m.id)}.yaml" target="_blank" rel="noopener" class="github-link" title="查看詞源">🔗</a>
          </li>
        `,
          )
          .join('');
      } else {
        suggestSection.hidden = true;
      }
    }

    function escHtml(s) {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    // ── Main run ────────────────────────────────────────────────────────────
    let lastHtml = '';
    const inputHighlightEl = document.getElementById('input-highlight');

    async function run() {
      const input = inputEl.value;
      if (!input.trim()) {
        outputEl.innerHTML =
          '<span class="output-placeholder">轉換結果會顯示在這裡，<mark class="sample-mark">替換的詞</mark> 會被醒目標示。</span>';
        inputHighlightEl.innerHTML = '';
        analysisEl.hidden = true;
        btnCopy.disabled = true;
        lastHtml = '';
        return;
      }

      // If OpenCC is still loading, wait a bit and retry
      if (openccStatus === 'loading') {
        outputEl.innerHTML =
          '<span class="output-placeholder">⏳ 正在載入字形轉換模組…</span>';
        await new Promise((resolve) => setTimeout(resolve, 800));
        // If still loading, proceed anyway (may use plain term replacement)
      }

      const { html, matches } = convertText(input);
      outputEl.innerHTML =
        html ||
        '<span class="no-change">✅ 未偵測到中國用語，文字已符合台灣習慣。</span>';
      lastHtml =
        matches.length > 0 ? outputEl.innerText || outputEl.textContent : input;
      btnCopy.disabled = false;

      // Highlight matched china terms in the input overlay
      inputHighlightEl.innerHTML = highlightSource(input, matches);

      // Render analysis
      const { before, after } = computeIndex(input, matches);
      renderAnalysis(matches);
      if (matches.length > 0) {
        indexBefore.textContent = `${before}%`;
        indexAfter.textContent = `${after}%`;
      }
    }

    // ── Event listeners ─────────────────────────────────────────────────────
    inputEl.addEventListener('input', run);
    btnConvert.addEventListener('click', run);

    // Sync scroll between textarea and highlight overlay
    inputEl.addEventListener('scroll', () => {
      inputHighlightEl.scrollTop = inputEl.scrollTop;
      inputHighlightEl.scrollLeft = inputEl.scrollLeft;
    });

    // Example buttons
    document.querySelectorAll('.btn-example').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.example;
        if (EXAMPLES[key]) {
          inputEl.value = EXAMPLES[key];
          run();
        }
      });
    });

    btnClear.addEventListener('click', () => {
      inputEl.value = '';
      run();
      inputEl.focus();
    });

    btnCopy.addEventListener('click', async () => {
      try {
        // Copy plain text (strip HTML tags)
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = outputEl.innerHTML;
        const plain = tempDiv.innerText || tempDiv.textContent || '';
        await navigator.clipboard.writeText(plain);
        btnCopy.textContent = '✅ 已複製';
        setTimeout(() => {
          btnCopy.textContent = '📋 複製結果';
        }, 1800);
      } catch {
        btnCopy.textContent = '❌ 複製失敗';
        setTimeout(() => {
          btnCopy.textContent = '📋 複製結果';
        }, 1800);
      }
    });
  </script>
</Layout>

