            <span class="stat"><strong>{rules.length}</strong> 條轉換規則</span>
          </div>
          <div class="header-links">
            <a href="/terminology" class="fork-link-btn"> ← 回到詞庫 </a>
            <a href="/fork-graph" class="fork-link-btn"> 🌿 語言分支樹 </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Main converter area ─────────────────────────────────────── -->
    <div class="conv-body">
      <div class="conv-inner">
        <!-- Two-column editor -->
        <div class="editor-grid">
          <div class="editor-panel">
            <div class="panel-label">輸入文字</div>
            <textarea
              id="input-text"
              class="editor-textarea"
              placeholder="在這裡貼入文字…

例如：這個軟件視頻很有用，可以通過下載來使用。"
              spellcheck="false"></textarea>
          </div>

          <div class="editor-panel">
            <div class="panel-label">轉換結果</div>
            <div id="output-text" class="editor-output" aria-live="polite">
              <span class="output-placeholder"
                >轉換結果會顯示在這裡，<mark class="sample-mark">替換的詞</mark> 會被高亮標記。</span
              >
            </div>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="action-bar">
          <button id="btn-convert" class="btn btn-primary">🔄 轉換</button>
          <button id="btn-clear" class="btn btn-secondary">✕ 清除</button>
          <button id="btn-copy" class="btn btn-secondary" disabled
            >📋 複製結果</button
          >
          <span class="action-sep"></span>
          <span class="example-label">試試看：</span>
          <button class="btn btn-example" data-example="tech">💻 科技文</button>
          <button class="btn btn-example" data-example="life">🍜 生活文</button>
          <button class="btn btn-example" data-example="news">📰 新聞稿</button>
        </div>

        <!-- Analysis report -->
        <div id="analysis" class="analysis-box" hidden>
          <div class="analysis-header">
            <span id="analysis-title" class="analysis-title"></span>
          </div>

          <div id="must-change" class="analysis-section" hidden>
            <div class="section-label label-red">🔴 必換（A / B 類）</div>
            <ul id="must-list" class="change-list"></ul>
          </div>

          <div id="suggest-change" class="analysis-section" hidden>
            <div class="section-label label-yellow">🟡 建議（其他類）</div>
            <ul id="suggest-list" class="change-list"></ul>
          </div>

          <div class="taiwan-index-row">
            <span class="index-label">📊 台灣化指數</span>
            <span id="index-before" class="index-val before"></span>
            <span class="index-arrow">→</span>
            <span id="index-after" class="index-val after"></span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script define:vars={{ rulesJSON }}>
    // ── Parse rules injected from build time ────────────────────────────────
    const RULES = JSON.parse(rulesJSON);
    const GITHUB_BASE =
      'https://github.com/frank890417/taiwan-md/blob/main/data/terminology/';

    // ── DOM refs ────────────────────────────────────────────────────────────
    const inputEl = document.getElementById('input-text');
    const outputEl = document.getElementById('output-text');
    const btnConvert = document.getElementById('btn-convert');
    const btnClear = document.getElementById('btn-clear');
    const btnCopy = document.getElementById('btn-copy');
    const analysisEl = document.getElementById('analysis');
    const analysisTitleEl = document.getElementById('analysis-title');
    const mustSection = document.getElementById('must-change');
    const mustList = document.getElementById('must-list');
    const suggestSection = document.getElementById('suggest-change');
    const suggestList = document.getElementById('suggest-list');
    const indexBefore = document.getElementById('index-before');
    const indexAfter = document.getElementById('index-after');

    // ── Example texts ─────────────────────────────────────────────────────────
    const EXAMPLES = {
      tech: `最近在学习编程，发现这个软件的视频教程非常实用。用户可以通过下载客户端来使用云存储功能，支持多种操作系统。程序员们在论坛上分享了很多关于人工智能和机器学习的干货内容，信息量很大。如果遇到网络问题，可以尝试刷新缓存或者重启路由器。`,
      life: `周末去了一家超级棒的网红餐厅打卡，点了好几个硬菜，味道很赞。服务员态度也很好，上菜速度很快。吃完饭叫了个出租车回家，在路上用手机刷了会儿短视频，看到一个博主分享了减肥健身的攻略，质量很高。回到小区后去便利店买了酸奶和方便面当宵夜。`,
      news: `据新华社报道，该项目总投资达到数十亿元人民币，将在未来三年内建设完成。相关部门表示，这一举措将有效提升城市基础设施水平，惠及数百万群众。多位专家在接受采访时指出，该政策的出台对于促进经济高质量发展具有重要意义。与此同时，有关方面正在积极推进相关配套措施的落实。`,
    };

    // ── Core convert function ───────────────────────────────────────────────
    function convertText(input) {
      if (!input.trim()) return { html: '', matches: [] };

      const matches = [];
      let text = input;

      // Apply replacements (rules already sorted by source.length desc)
      // Use a marker system to avoid double-replacing
      const placeholders = [];
      let markerIdx = 0;

      for (const rule of RULES) {
        if (text.includes(rule.source)) {
          const marker = `\x00${markerIdx}\x00`;
          const escapedSource = rule.source.replace(
            /[.*+?^${}()|[\]\\]/g,
            '\\$&',
          );
          const count = (text.match(new RegExp(escapedSource, 'g')) || [])
            .length;
          if (count > 0) {
            matches.push({ ...rule, count });
            text = text.replace(new RegExp(escapedSource, 'g'), marker);
            placeholders.push({ marker, target: rule.target });
            markerIdx++;
          }
        }
      }

      // Escape HTML in the modified text
      let escaped = text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\n/g, '<br>');

      // Replace markers with highlighted spans
      for (const { marker, target } of placeholders) {
        const escapedMarker = marker.replace(/\x00/g, '\\x00');
        // Use a regex to replace the null-byte markers
        const safeMarker = marker.replace(/\x00(\d+)\x00/, '\x00$1\x00');
        escaped = escaped
          .split(marker)
          .join(`<mark class="replaced-word">${target}</mark>`);
      }

      return { html: escaped, matches };
    }

    // ── Compute Taiwan-ization index ────────────────────────────────────────
    function computeIndex(input, matches) {
      if (!input.trim()) return { before: 100, after: 100 };
      const totalChars = input.replace(/\s/g, '').length || 1;
      let chinaChars = 0;
      for (const m of matches) {
        chinaChars += m.source.length * m.count;
      }
      const before = Math.round(
        Math.max(0, ((totalChars - chinaChars) / totalChars) * 100),
      );
      return { before, after: 100 };
    }

    // ── Render analysis report ──────────────────────────────────────────────
    function renderAnalysis(matches) {
      if (matches.length === 0) {
        analysisEl.hidden = true;
        return;
      }

      analysisEl.hidden = false;
      analysisTitleEl.textContent = `偵測到 ${matches.length} 個中國用語`;

      const mustMatches = matches.filter(
        (m) => m.forkType === 'A' || m.forkType === 'B',
      );
      const suggestMatches = matches.filter(
        (m) => m.forkType !== 'A' && m.forkType !== 'B',
      );

      // Must-change
      if (mustMatches.length > 0) {
        mustSection.hidden = false;
        mustList.innerHTML = mustMatches
          .map(
            (m) => `
          <li class="change-item">
            <span class="change-source">${escHtml(m.source)}</span>
            <span class="change-arrow">→</span>
            <span class="change-target">${escHtml(m.target)}</span>
            ${m.count > 1 ? `<span class="change-count">×${m.count}</span>` : ''}
            <a href="${GITHUB_BASE}${encodeURIComponent(m.id)}.yaml" target="_blank" rel="noopener" class="github-link" title="查看詞源">🔗</a>
          </li>
        `,
          )
          .join('');
      } else {
        mustSection.hidden = true;
      }

      // Suggest
      if (suggestMatches.length > 0) {
        suggestSection.hidden = false;
        suggestList.innerHTML = suggestMatches
          .map(
            (m) => `
          <li class="change-item">
            <span class="change-source">${escHtml(m.source)}</span>
            <span class="change-arrow">→</span>
            <span class="change-target">${escHtml(m.target)}</span>
            ${m.count > 1 ? `<span class="change-count">×${m.count}</span>` : ''}
            <a href="${GITHUB_BASE}${encodeURIComponent(m.id)}.yaml" target="_blank" rel="noopener" class="github-link" title="查看詞源">🔗</a>
          </li>
        `,
          )
          .join('');
      } else {
        suggestSection.hidden = true;
      }
    }

    function escHtml(s) {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    // ── Main run ────────────────────────────────────────────────────────────
    let lastHtml = '';

    function run() {
      const input = inputEl.value;
      if (!input.trim()) {
        outputEl.innerHTML =
          '<span class="output-placeholder">轉換結果會顯示在這裡，<mark class="sample-mark">替換的詞</mark> 會被高亮標記。</span>';
        analysisEl.hidden = true;
        btnCopy.disabled = true;
        lastHtml = '';
        return;
      }

      const { html, matches } = convertText(input);
      outputEl.innerHTML =
        html ||
        '<span class="no-change">✅ 未偵測到中國用語，文字已符合台灣習慣。</span>';
      lastHtml =
        matches.length > 0 ? outputEl.innerText || outputEl.textContent : input;
      btnCopy.disabled = false;

      // Render analysis
      const { before, after } = computeIndex(input, matches);
      renderAnalysis(matches);
      if (matches.length > 0) {
        indexBefore.textContent = `${before}%`;
        indexAfter.textContent = `${after}%`;
      }
    }

    // ── Event listeners ─────────────────────────────────────────────────────
    inputEl.addEventListener('input', run);
    btnConvert.addEventListener('click', run);

    // Example buttons
    document.querySelectorAll('.btn-example').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.example;
        if (EXAMPLES[key]) {
          inputEl.value = EXAMPLES[key];
          run();
        }
      });
    });

    btnClear.addEventListener('click', () => {
      inputEl.value = '';
      run();
      inputEl.focus();
    });

    btnCopy.addEventListener('click', async () => {
      try {
        // Copy plain text (strip HTML tags)
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = outputEl.innerHTML;
        const plain = tempDiv.innerText || tempDiv.textContent || '';
        await navigator.clipboard.writeText(plain);
        btnCopy.textContent = '✅ 已複製';
        setTimeout(() => {
          btnCopy.textContent = '📋 複製結果';
        }, 1800);
      } catch {
        btnCopy.textContent = '❌ 複製失敗';
        setTimeout(() => {
          btnCopy.textContent = '📋 複製結果';
        }, 1800);
      }
    });
  </script>
</Layout>

