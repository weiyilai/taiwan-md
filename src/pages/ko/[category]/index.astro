<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', () => {
    const segs = window.location.pathname.split('/').filter(Boolean);
    const currentCategory = ['ko', 'en', 'ja'].includes(segs[0] || '')
      ? segs[1]
      : segs[0];
    if (currentCategory !== 'food') return;

    const mapEl = document.getElementById('ko-food-zh-slug-map');
    let zhToKo = {};
    try {
      zhToKo = mapEl ? JSON.parse(mapEl.textContent || '{}') : {};
    } catch {
      zhToKo = {};
    }
    function localizeFoodUrl(url) {
      if (!url || !url.startsWith('/food/')) return url;
      const zhSlug = decodeURIComponent(url.replace(/^\/food\//, ''));
      const koSlug = zhToKo[zhSlug];
      if (koSlug) return '/ko/food/' + encodeURIComponent(koSlug);
      return url;
    }

