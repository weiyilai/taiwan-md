---
import { readFileSync } from 'fs';
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';
import Layout from '../../../layouts/Layout.astro';
import { marked } from 'marked';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';
import {
  categoryList as categories,
  getCategoryConfigs,
  type CategoryKey,
} from '../../../utils/categoryConfig';

const safeMatter = (fileContent: string) => {
  try {
    return matter(fileContent);
  } catch {
    const stripped = fileContent.replace(/^---\s*\n[\s\S]*?\n---\s*\n/, '');
    return { data: {}, content: stripped };
  }
};

export async function getStaticPaths() {
  const safeMatter = (fileContent: string) => {
    try {
      return matter(fileContent);
    } catch {
      const stripped = fileContent.replace(/^---\s*\n[\s\S]*?\n---\s*\n/, '');
      return { data: {}, content: stripped };
    }
  };

  const categoryMapping: Record<string, string> = {
    history: 'History',
    geography: 'Geography',
    culture: 'Culture',
    food: 'Food',
    art: 'Art',
    music: 'Music',
    technology: 'Technology',
    nature: 'Nature',
    people: 'People',
    society: 'Society',
    economy: 'Economy',
    lifestyle: 'Lifestyle',
  };

  const paths = [];

  for (const category of categories) {
    const folderName = categoryMapping[category];
    if (!folderName) continue;
    const articles = [];

    try {
      const koFolderPath = resolve(
        process.cwd(),
        'knowledge',
        'ko',
        folderName,
      );
      const koFiles = await readdir(koFolderPath);
      const koMarkdownFiles = koFiles.filter(
        (file) => file.endsWith('.md') && !file.startsWith('_'),
      );

      for (const file of koMarkdownFiles) {
        const filePath = join(koFolderPath, file);
        const fileContent = await readFile(filePath, 'utf-8');
        const { data: frontmatter } = safeMatter(fileContent);
        const slug = basename(file, '.md');
        const fnCount = (fileContent.match(/^\[\^\d+\]:/gm) || []).length;

        articles.push({
          slug,
          title: frontmatter.title || slug,
          description: frontmatter.description || '',
          status: frontmatter.status || '',
          readingTime: frontmatter.readingTime || null,
          date: frontmatter.date || null,
          featured: frontmatter.featured || false,
          tags: frontmatter.tags || [],
          lang: 'ko',
          image: frontmatter.image || null,
          imageAlt: frontmatter.imageAlt || '',
          imageCredit: frontmatter.imageCredit || '',
          subcategory: frontmatter.subcategory || '',
          footnotes: fnCount,
        });
      }
    } catch (err) {
      console.error(
        `[ko/category/index] Error loading "${category}":`,
        (err as Error).message,
      );
    }

    let hubContent = '';
    try {
      const hubFolder = resolve(process.cwd(), 'knowledge', 'ko', folderName);
      const hubFiles = await readdir(hubFolder);
      const hubFile = hubFiles.find(
        (f) => f.startsWith('_') && f.includes('Hub'),
      );
      if (hubFile) {
        const hubPath = join(hubFolder, hubFile);
        const hubRaw = await readFile(hubPath, 'utf-8');
        const { content } = safeMatter(hubRaw);
        hubContent = content.replace(/^#\s+.+\n/, '').trim();
      }
    } catch {}

    // ── Compute top picks (adaptive threshold + subcategory diversification) ──
    const computeTopPicks = () => {
      if (articles.length === 0) return [];

      const tryThreshold = (featThr: number, normalThr: number) =>
        articles.filter((a: any) => {
          const thr = a.featured ? featThr : normalThr;
          return (a.footnotes || 0) >= thr;
        });

      let candidates = tryThreshold(8, 15);
      if (candidates.length < 2) candidates = tryThreshold(3, 8);
      if (candidates.length === 0)
        candidates = articles.filter((a: any) => a.featured);
      if (candidates.length === 0) return [];

      const sorted = [...candidates].sort((a: any, b: any) => {
        if (a.featured !== b.featured) return a.featured ? -1 : 1;
        if ((b.footnotes || 0) !== (a.footnotes || 0))
          return (b.footnotes || 0) - (a.footnotes || 0);
        return String(b.date || '').localeCompare(String(a.date || ''));
      });

      // Subcategory diversification: one per subcategory first, then fill
      const result: any[] = [];
      const seenSub = new Set<string>();
      for (const a of sorted) {
        const sub = a.subcategory || '';
        if (!seenSub.has(sub)) {
          result.push(a);
          seenSub.add(sub);
        }
        if (result.length >= 5) break;
      }
      if (result.length < 5) {
        for (const a of sorted) {
          if (!result.includes(a)) result.push(a);
          if (result.length >= 5) break;
        }
      }
      return result;
    };

    const topPicks = computeTopPicks();

    paths.push({
      params: { category },
      props: {
        category,
        hubContent,
        topPicks,
        articles: articles.sort((a, b) => {
          if (a.featured && !b.featured) return -1;
          if (!a.featured && b.featured) return 1;
          if ((b.footnotes || 0) !== (a.footnotes || 0))
            return (b.footnotes || 0) - (a.footnotes || 0);
          return a.title.localeCompare(b.title);
        }),
      },
    });
  }

  return paths;
}

const { category, hubContent, articles, topPicks } = Astro.props;
const koFoodSlugFromZh: Record<string, string> = {};
try {
  const trPath = resolve(process.cwd(), 'knowledge', '_translations.json');
  const tr = JSON.parse(readFileSync(trPath, 'utf-8')) as Record<
    string,
    string
  >;
  for (const [koPath, zhPath] of Object.entries(tr)) {
    if (
      typeof koPath === 'string' &&
      koPath.startsWith('ko/Food/') &&
      typeof zhPath === 'string' &&
      zhPath.startsWith('Food/')
    ) {
      const koSlug = basename(koPath, '.md');
      const zhSlug = basename(zhPath, '.md');
      koFoodSlugFromZh[zhSlug] = koSlug;
    }
  }
} catch {
  /* ignore */
}

// Compute unique tags for filter
const allTagsSet = new Set();
articles.forEach((a: any) => {
  if (a.tags) a.tags.forEach((t: string) => allTagsSet.add(t));
});
const uniqueTags = [...allTagsSet].sort().slice(0, 12) as string[];

// Load economic data for economy category
let taiexData: any[] = [];
let cpiData: any[] = [];
let salaryData: any[] = [];
let housingData: any[] = [];
if (category === 'economy') {
  const [taiexJson, cpiJson, salaryJson, housingJson] = await Promise.all([
    import('../../../data/taiex-yearly.json'),
    import('../../../data/taiwan-cpi.json'),
    import('../../../data/taiwan-salary.json'),
    import('../../../data/taiwan-housing.json'),
  ]);
  taiexData = taiexJson.data;
  cpiData = cpiJson.data;
  salaryData = salaryJson.data;
  housingData = housingJson.data;
}

function resolveWikilinks(md: string, currentCategory: string) {
  if (!md) return md;

  function resolveOne(target: string, display?: string, bold = false) {
    const label = display || target;
    if (target.startsWith('_')) {
      const catName = target
        .replace(/^_/, '')
        .replace(/ Hub$/, '')
        .toLowerCase();
      return bold
        ? `<a class="topic-pill" href="/ko/${catName}"><strong>${label}</strong></a>`
        : `<a class="topic-pill" href="/ko/${catName}">${label}</a>`;
    }
    const matchArticle = articles.find(
      (a: any) =>
        a.title === target ||
        a.slug === target ||
        a.slug === encodeURIComponent(target),
    );
    if (matchArticle) {
      const url = `/ko/${currentCategory}/${matchArticle.slug}`;
      return bold
        ? `<a class="topic-pill" href="${url}"><strong>${label}</strong></a>`
        : `<a class="topic-pill" href="${url}">${label}</a>`;
    }
    return bold ? `**${label}**` : label;
  }

  // First pass: **[[X]]** → [**resolved**](/url) (bold inside link for marked CJK compat)
  md = md.replace(
    /\*\*\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]\*\*/g,
    (_, target, display) => resolveOne(target, display, true),
  );
  // Second pass: remaining [[X]]
  md = md.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, target, display) =>
    resolveOne(target, display),
  );
  return md;
}

const resolvedContent = hubContent
  ? resolveWikilinks(hubContent, category)
  : '';

// Build set of article URLs for topic-pill detection
const articleUrlSet = new Set(
  articles.map((a: any) => `/ko/${category}/${a.slug}`),
);
// Also add cross-category hub URLs
const categoryKeys = Object.keys({
  history: 1,
  geography: 1,
  culture: 1,
  food: 1,
  art: 1,
  music: 1,
  technology: 1,
  nature: 1,
  people: 1,
  society: 1,
  economy: 1,
  lifestyle: 1,
});

// Broken image fallback + topic-pill link for hub pages
const hubRenderer = new marked.Renderer();
hubRenderer.image = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  const altText = text || '';
  return `<img src="${href}" alt="${altText}"${titleAttr} loading="lazy" onerror="this.onerror=null;this.classList.add('img-broken')" />`;
};
hubRenderer.link = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  const h = href || '';
  // Check if link points to an article or a hub category page
  const isArticleLink = articleUrlSet.has(decodeURIComponent(h));
  const isCategoryLink = categoryKeys.some(
    (k) =>
      h === `/ko/${k}` || h === `/ko/${k}/` || h === `/${k}` || h === `/${k}/`,
  );
  if (isArticleLink || isCategoryLink) {
    return `<a class="topic-pill" href="${h}"${titleAttr}>${text}</a>`;
  }
  return `<a href="${h}"${titleAttr}>${text}</a>`;
};
const rawHubHtml = resolvedContent
  ? marked.parse(resolvedContent, { renderer: hubRenderer, breaks: true })
  : '';

// Post-process: add callout/pull-quote classes to blockquotes
function enrichBlockquotes(html: string): string {
  if (!html) return html;
  const calloutMap: Record<string, string> = {
    '📝': 'callout-note',
    '⚠️': 'callout-warning',
    '💡': 'callout-tip',
    '📊': 'callout-data',
  };
  return (html as string).replace(
    /<blockquote>([\s\S]*?)<\/blockquote>/g,
    (match, inner) => {
      // Pull quote: contains ✦
      if (inner.includes('✦')) {
        return `<blockquote class="pull-quote">${inner}</blockquote>`;
      }
      // Callout: starts with emoji + bold
      for (const [emoji, cls] of Object.entries(calloutMap)) {
        if (inner.includes(emoji) && inner.includes('<strong>')) {
          return `<blockquote class="${cls}">${inner}</blockquote>`;
        }
      }
      return match;
    },
  );
}
const hubHtml = enrichBlockquotes(rawHubHtml as string);

// Split hub HTML into sections at <h2> boundaries for chart injection (economy only)
const isEconomy = category === 'economy';
type HubSection = { html: string; chartAfter?: string };
let hubSections: HubSection[] = [];
if (isEconomy && hubHtml) {
  const parts = (hubHtml as string).split(/(?=<h2>)/);
  const chartSequence = ['cpi', 'taiex', 'salary', 'housing'] as const;
  let chartIdx = 0;
  hubSections = parts.map((part) => {
    let chartAfter: string | undefined;
    if (part.includes('<h2') && chartIdx < chartSequence.length) {
      chartAfter = chartSequence[chartIdx];
      chartIdx++;
    }
    return { html: part, chartAfter };
  });
}

// Group articles by subcategory
const subcategoryGroups: { name: string; articles: any[] }[] = [];
const subcatMap = new Map<string, any[]>();
for (const article of articles) {
  const sub = (article as any).subcategory || '기타';
  if (!subcatMap.has(sub)) subcatMap.set(sub, []);
  subcatMap.get(sub)!.push(article);
}
// Sort: named subcategories first (alphabetically), then "기타" last
for (const [name, arts] of [...subcatMap.entries()].sort((a, b) => {
  if (a[0] === '기타') return 1;
  if (b[0] === '기타') return -1;
  return a[0].localeCompare(b[0]);
})) {
  subcategoryGroups.push({ name, articles: arts });
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const categoryConfigs = getCategoryConfigs(t);
const categoryInfo = categoryConfigs[category];

// Other categories (cross-category nav)
const otherCategories = categories
  .filter((cat) => cat !== category)
  .map((cat) => ({
    key: cat,
    ...categoryConfigs[cat as CategoryKey],
  }));
---

<Layout
  title={`${categoryInfo.name} - Taiwan.md`}
  description={`${categoryInfo.description} - Taiwan.md`}
  lang="ko"
  category={categoryInfo.name}
>
  <main class="category-page">
    <!-- Hero Banner -->
    <section
      class="hero-banner"
      style={`background: ${categoryInfo.gradient};`}
    >
      <div class="hero-content">
        <div class="hero-icon">{categoryInfo.icon}</div>
        <h1 class="hero-title">{categoryInfo.name}</h1>
        <p class="hero-description">{categoryInfo.description}</p>
        <div class="hero-stats">
          <span class="stats-badge">📚 {articles.length}개 글</span>
        </div>
      </div>
      <div class="hero-decoration"></div>
    </section>

    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/ko" class="breadcrumb-link">홈</a>
        <span class="separator">›</span>
        <span class="current">{categoryInfo.name}</span>
      </nav>

      <!-- Featured Picks (above essay for immediate navigation) -->
      {
        topPicks && topPicks.length > 0 && (
          <section class="hub-picks">
            <h2 class="hub-picks-heading">{categoryInfo.icon} 추천 글</h2>
            <div class="hub-picks-grid">
              {topPicks.map((article: any) => (
                <a
                  href={`/ko/${category}/${encodeURIComponent(article.slug)}`}
                  class="pick-card"
                >
                  <span class="pick-head">
                    <span class="pick-title">{article.title}</span>
                    {article.footnotes > 0 && (
                      <span class="pick-fn">{article.footnotes} 인용</span>
                    )}
                  </span>
                  {article.description && (
                    <span class="pick-desc">
                      {article.description.length > 100
                        ? article.description.slice(0, 97) + '...'
                        : article.description}
                    </span>
                  )}
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- Hub Content (curated overview) -->
      {
        hubHtml && !isEconomy && (
          <section class="hub-content">
            <div class="hub-prose" set:html={hubHtml} />
          </section>
        )
      }

      {
        isEconomy && hubSections.length > 0 && (
          <section class="hub-content">
            <div class="hub-prose">
              {hubSections.map((section) => (
                <Fragment>
                  <div set:html={section.html} />
                  {section.chartAfter && (
                    <div
                      class="econ-chart-wrapper"
                      data-chart={section.chartAfter}
                    >
                      <div class="econ-chart-container">
                        <div class="econ-chart-header">
                          <h4 class="econ-chart-title">
                            {section.chartAfter === 'taiex' &&
                              '📈 대만 가권주가지수 (TAIEX) 연도별'}
                            {section.chartAfter === 'cpi' &&
                              '📊 소비자물가지수 (CPI) 연도별'}
                            {section.chartAfter === 'salary' &&
                              '💰 월평균 상용직 급여 (경상)'}
                            {section.chartAfter === 'housing' &&
                              '🏠 신이 주택 가격 지수 (信義)'}
                          </h4>
                          <span class="econ-chart-source">
                            {section.chartAfter === 'taiex' &&
                              '출처: 대만증권거래소'}
                            {section.chartAfter === 'cpi' &&
                              '출처: 행정원 주계총처'}
                            {section.chartAfter === 'salary' &&
                              '출처: 행정원 주계총처'}
                            {section.chartAfter === 'housing' &&
                              '출처: 신이 주택 (Sinyi Housing Index)'}
                          </span>
                        </div>
                        <div class="econ-chart-svg-wrap">
                          <svg
                            class="econ-chart-svg"
                            viewBox="0 0 800 300"
                            preserveAspectRatio="xMidYMid meet"
                          />
                          <div class="econ-chart-tooltip" />
                        </div>
                      </div>
                    </div>
                  )}
                </Fragment>
              ))}
            </div>
          </section>
        )
      }

      <!-- Food Visualization (only for food category) -->
      {
        category === 'food' && (
          <section class="food-viz">
            <div class="food-viz-inner">
              <h2>🍜 대만 미식 우주 탐험</h2>
              <p class="food-viz-subtitle">
                섹터나 노드를 눌러 각 대만의 맛을 자세히 살펴보세요
              </p>

              <div class="viz-tabs">
                <button class="viz-tab active" data-viz="sunburst">
                  🎯 풍미 휠
                </button>
                <button class="viz-tab" data-viz="network">
                  🕸️ 관계도
                </button>
              </div>

              <div class="viz-container" id="sunburstViz" />
              <div
                class="viz-container"
                id="networkViz"
                style="display:none;"
              />

              <div class="viz-legend" id="vizLegend" />
            </div>
          </section>
        )
      }

      <!-- Articles Section (row list + sidebar) -->
      {
        articles.length > 0 ? (
          <section class="articles-section">
            <div class="articles-layout">
              {subcategoryGroups.length > 1 && (
                <aside class="subcategory-sidebar">
                  <nav class="sidebar-nav">
                    <span class="sidebar-label">주제</span>
                    {subcategoryGroups.map((group) => (
                      <a href={`#sub-${group.name}`} class="sidebar-item">
                        {group.name}
                        <span class="sidebar-count">
                          {group.articles.length}
                        </span>
                      </a>
                    ))}
                  </nav>
                </aside>
              )}

              <div class="articles-main" id="articlesGrid">
                <div class="articles-toolbar">
                  <input
                    type="text"
                    class="filter-input"
                    id="articleFilter"
                    placeholder="글 검색..."
                    autocomplete="off"
                  />
                </div>

                {subcategoryGroups.map((group) => (
                  <div class="subcategory-section" id={`sub-${group.name}`}>
                    {subcategoryGroups.length > 1 && (
                      <h3 class="subcategory-heading">
                        {group.name}
                        <span class="subcategory-count">
                          {group.articles.length}
                        </span>
                      </h3>
                    )}
                    <div class="article-rows">
                      {group.articles.map((article: any) => (
                        <a
                          href={`/ko/${category}/${encodeURIComponent(article.slug)}`}
                          class={`article-row ${article.featured ? 'is-featured' : ''}`}
                          data-title={article.title}
                          data-date={article.date || ''}
                          data-reading={article.readingTime || 0}
                          data-featured={article.featured ? '1' : '0'}
                          data-tags={JSON.stringify(article.tags || [])}
                          data-subcategory={article.subcategory || ''}
                        >
                          <div class="row-main">
                            <div class="row-title-line">
                              {article.featured && (
                                <span class="row-star">★</span>
                              )}
                              <h3 class="row-title">{article.title}</h3>
                            </div>
                            {article.description && (
                              <p class="row-desc">
                                {article.description.length > 120
                                  ? article.description.slice(0, 117) + '...'
                                  : article.description}
                              </p>
                            )}
                          </div>
                          <div class="row-meta">
                            {(article.footnotes || 0) > 0 && (
                              <span class="row-fn">
                                {article.footnotes} 인용
                              </span>
                            )}
                            {article.readingTime && (
                              <span class="row-time">
                                {article.readingTime} min
                              </span>
                            )}
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}

                <div class="no-results" id="noResults" style="display:none;">
                  <p>조건에 맞는 글이 없습니다</p>
                </div>
              </div>
            </div>
          </section>
        ) : (
          <section class="coming-soon">
            <div class="coming-soon-content">
              <div class="coming-soon-icon">{categoryInfo.icon}</div>
              <h2>콘텐츠 준비 중</h2>
              <p>이 주제의 글을 준비 중입니다. 조금만 기다려 주세요.</p>
              <p class="category-desc">
                앞으로 여기에는: {categoryInfo.description}
              </p>

              <div class="action-buttons">
                <a href="/ko" class="btn-primary">
                  홈으로
                </a>
                <a
                  href="https://github.com/frank890417/taiwan-md"
                  target="_blank"
                  class="btn-secondary"
                >
                  기여하기
                </a>
              </div>
            </div>
          </section>
        )
      }

      <!-- 探索其他面向 -->
      <section class="explore-more">
        <h2 class="explore-title">대만의 다른 모습 둘러보기</h2>
        <div class="categories-grid">
          {
            otherCategories.map((cat) => (
              <a
                href={`/ko/${cat.key}`}
                class="category-card"
                style={`border-color: ${cat.color}; color: ${cat.color};`}
              >
                <div class="category-card-icon">{cat.icon}</div>
                <div class="category-card-name">{cat.name}</div>
              </a>
            ))
          }
        </div>
      </section>
    </div>

    {
      category === 'food' && (
        <script
          type="application/json"
          id="ko-food-zh-slug-map"
          set:html={JSON.stringify(koFoodSlugFromZh)}
        />
      )
    }
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('articlesGrid');
    const noResults = document.getElementById('noResults');
    const filterInput = document.getElementById(
      'articleFilter',
    ) as HTMLInputElement;
    if (!grid) return;

    const cards = Array.from(
      grid.querySelectorAll('.article-row'),
    ) as HTMLElement[];
    const subcategorySections = Array.from(
      grid.querySelectorAll('.subcategory-section'),
    ) as HTMLElement[];
    let activeSort = 'featured';
    let activeTag = '';

    // Sort
    function sortCards(method: string) {
      const sorted = [...cards].sort((a, b) => {
        if (method === 'featured') {
          const af = a.dataset.featured === '1' ? 1 : 0;
          const bf = b.dataset.featured === '1' ? 1 : 0;
          if (af !== bf) return bf - af;
          return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        }
        if (method === 'title') {
          return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        }
        if (method === 'date') {
          return (b.dataset.date || '').localeCompare(a.dataset.date || '');
        }
        if (method === 'reading') {
          return (
            parseInt(a.dataset.reading || '0') -
            parseInt(b.dataset.reading || '0')
          );
        }
        return 0;
      });
      sorted.forEach((card) => grid?.appendChild(card));
    }

    // Filter
    function applyFilters() {
      const query = filterInput?.value.toLowerCase() || '';
      let visible = 0;
      cards.forEach((card) => {
        const title = (card.dataset.title || '').toLowerCase();
        const tags: string[] = JSON.parse(card.dataset.tags || '[]');
        const matchQuery = !query || title.includes(query);
        const matchTag = !activeTag || tags.includes(activeTag);
        const show = matchQuery && matchTag;
        card.style.display = show ? '' : 'none';
        // Reset featured-card class based on visibility
        if (show) visible++;
      });
      // Hide subcategory sections with no visible cards
      subcategorySections.forEach((section) => {
        const sectionCards = section.querySelectorAll(
          '.article-row',
        ) as NodeListOf<HTMLElement>;
        const anyVisible = Array.from(sectionCards).some(
          (c) => c.style.display !== 'none',
        );
        section.style.display = anyVisible ? '' : 'none';
      });
      if (noResults) {
        noResults.style.display = visible === 0 ? 'block' : 'none';
      }
    }

    // Sort buttons
    document.querySelectorAll('.sort-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document
          .querySelectorAll('.sort-btn')
          .forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeSort = (btn as HTMLElement).dataset.sort || 'featured';
        sortCards(activeSort);
      });
    });

    // Tag buttons
    document.querySelectorAll('.tag-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = (btn as HTMLElement).dataset.tag || '';
        if (activeTag === tag) {
          activeTag = '';
          btn.classList.remove('active');
        } else {
          document
            .querySelectorAll('.tag-btn')
            .forEach((b) => b.classList.remove('active'));
          activeTag = tag;
          btn.classList.add('active');
        }
        applyFilters();
      });
    });

    // Text filter
    filterInput?.addEventListener('input', () => {
      applyFilters();
    });
  });
</script>

