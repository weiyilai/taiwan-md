---
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import { execSync } from 'child_process';
import matter from 'gray-matter';
import Layout from '../../../layouts/Layout.astro';
import { marked } from 'marked';
import ArticleHero from '../../../components/ArticleHero.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import ArticleSidebar from '../../../components/ArticleSidebar.astro';
import RelatedArticleCard from '../../../components/RelatedArticleCard.astro';
import { useTranslations } from '../../../i18n/utils';
import {
  categoryList as categories,
  getCategoryConfigs,
  type CategoryKey,
} from '../../../utils/categoryConfig';

const safeMatter = (fileContent: string) => {
  try {
    return matter(fileContent);
  } catch {
    const stripped = fileContent.replace(/^---\s*\n[\s\S]*?\n---\s*\n/, '');
    return { data: {}, content: stripped };
  }
};

// ── Git helpers ───────────────────────────────────────────────────────────────
let _gitCache: Map<
  string,
  { contributors: string[]; lastModified: string }
> | null = null;

function buildGitCache() {
  if (_gitCache) return _gitCache;
  _gitCache = new Map();
  try {
    const logOutput = execSync(
      `git -c core.quotePath=false log --name-only --format="COMMIT_BY:%an" -- "knowledge/en/"`,
      { encoding: 'utf-8', maxBuffer: 10 * 1024 * 1024 },
    );
    let currentAuthor = '';
    for (const line of logOutput.split('\n')) {
      if (line.startsWith('COMMIT_BY:')) {
        currentAuthor = line.slice(10);
      } else if (line.startsWith('knowledge/') && line.endsWith('.md')) {
        const key = resolve(process.cwd(), line);
        const entry = _gitCache.get(key) || {
          contributors: [],
          lastModified: '',
        };
        if (!entry.contributors.includes(currentAuthor))
          entry.contributors.push(currentAuthor);
        _gitCache.set(key, entry);
      }
    }
    const dateOutput = execSync(
      `git -c core.quotePath=false log --format="COMMIT_DATE:%aI" --name-only -- "knowledge/en/"`,
      { encoding: 'utf-8', maxBuffer: 10 * 1024 * 1024 },
    );
    let currentDate = '';
    const seenFiles = new Set<string>();
    for (const line of dateOutput.split('\n')) {
      if (line.startsWith('COMMIT_DATE:')) {
        currentDate = line.slice(12);
      } else if (line.startsWith('knowledge/') && line.endsWith('.md')) {
        const key = resolve(process.cwd(), line);
        if (!seenFiles.has(key)) {
          seenFiles.add(key);
          const entry = _gitCache.get(key) || {
            contributors: [],
            lastModified: '',
          };
          entry.lastModified = currentDate;
          _gitCache.set(key, entry);
        }
      }
    }
  } catch (e) {
    console.error('Git cache error:', (e as Error).message);
  }
  return _gitCache;
}

function getGitInfo(filePath: string) {
  return (
    buildGitCache().get(filePath) || { contributors: [], lastModified: '' }
  );
}

// ── Category → folder mapping ─────────────────────────────────────────────────
const categoryMapping: Record<string, string> = {
  history: 'History',
  geography: 'Geography',
  culture: 'Culture',
  food: 'Food',
  art: 'Art',
  music: 'Music',
  technology: 'Technology',
  nature: 'Nature',
  people: 'People',
  society: 'Society',
  economy: 'Economy',
  lifestyle: 'Lifestyle',
};

// ── getStaticPaths ────────────────────────────────────────────────────────────
export async function getStaticPaths() {
  const safeMatter = (fileContent: string) => {
    try {
      return matter(fileContent);
    } catch {
      const stripped = fileContent.replace(/^---\s*\n[\s\S]*?\n---\s*\n/, '');
      return { data: {}, content: stripped };
    }
  };

  const _categoryMapping: Record<string, string> = {
    history: 'History',
    geography: 'Geography',
    culture: 'Culture',
    food: 'Food',
    art: 'Art',
    music: 'Music',
    technology: 'Technology',
    nature: 'Nature',
    people: 'People',
    society: 'Society',
    economy: 'Economy',
    lifestyle: 'Lifestyle',
  };

  // Build git cache for this function scope
  let __gitCache: Map<
    string,
    {
      contributors: string[];
      lastModified: string;
      commitHash: string;
      revisionCount: number;
    }
  > | null = null;
  function _buildGitCache() {
    if (__gitCache) return __gitCache;
    __gitCache = new Map();
    try {
      const logOutput = execSync(
        `git log --full-history -z --name-only --format="COMMIT|%H|%aI|%an" -- "knowledge/en/"`,
        { encoding: 'utf-8', maxBuffer: 10 * 1024 * 1024 },
      );
      let currentHash = '';
      let currentDate = '';
      let currentAuthor = '';

      // git log -z: commit headers and filenames are SEPARATE NUL-terminated tokens.
      for (let token of logOutput.split('\0')) {
        token = token.replace(/^\n+/, '').trim();
        if (!token) continue;

        if (token.startsWith('COMMIT|')) {
          const parts = token.split('|');
          currentHash = parts[1] || '';
          currentDate = parts[2] || '';
          currentAuthor = parts[3] || '';
        } else if (token.startsWith('knowledge/') && token.endsWith('.md')) {
          const key = resolve(process.cwd(), token).normalize('NFC');
          let entry = __gitCache.get(key);
          if (!entry) {
            entry = {
              contributors: [],
              lastModified: currentDate,
              commitHash: currentHash,
              revisionCount: 0,
            };
            __gitCache.set(key, entry);
          }
          entry.revisionCount += 1;
          if (currentAuthor && !entry.contributors.includes(currentAuthor)) {
            entry.contributors.push(currentAuthor);
          }
        }
      }
    } catch {}
    return __gitCache;
  }

  const paths: any[] = [];
  for (const [categorySlug, folderName] of Object.entries(_categoryMapping)) {
    try {
      const folderPath = resolve(process.cwd(), 'knowledge', 'en', folderName);
      const files = await readdir(folderPath);
      for (const file of files.filter(
        (f) => f.endsWith('.md') && !f.startsWith('_'),
      )) {
        const filePath = join(folderPath, file).normalize('NFC');
        const fileContent = await readFile(filePath, 'utf-8');
        const { data: frontmatter, content } = safeMatter(fileContent);
        const slug = basename(file, '.md');
        let gitInfo = {
          contributors: [] as string[],
          lastModified: '',
          commitHash: '',
          revisionCount: 0,
        };
        try {
          gitInfo = _buildGitCache().get(filePath) || gitInfo;
        } catch {}
        paths.push({
          params: { category: categorySlug, slug },
          props: {
            title: frontmatter.title || slug,
            description: frontmatter.description || '',
            content,
            frontmatter,
            lang: 'en',
            contributors: gitInfo.contributors,
            lastModified: gitInfo.lastModified,
            commitHash: gitInfo.commitHash,
            revisionCount: gitInfo.revisionCount,
          },
        });
      }
    } catch (err) {
      console.error(
        `[en/getStaticPaths] Error processing category "${categorySlug}":`,
        (err as Error).message,
      );
    }
  }
  if (paths.length === 0) {
    throw new Error(
      '[en/getStaticPaths] Generated 0 paths — all categories failed.',
    );
  }
  return paths;
}

// ── Props ─────────────────────────────────────────────────────────────────────
const {
  title,
  description,
  content,
  frontmatter,
  contributors = [],
  lastModified = '',
  commitHash = '',
  revisionCount = 0,
} = Astro.props;
const { category, slug } = Astro.params;
const lang = 'en';

const t = useTranslations(lang);
const categoryConfigs = getCategoryConfigs(t);
const categoryInfo = categoryConfigs[category as CategoryKey];
if (!categoryInfo) throw new Error(`Unknown category: ${category}`);

// Category name is already localised by getCategoryConfigs(t)
const categoryNameEn = categoryInfo.name;

// ── Related articles (same category, up to 3) ─────────────────────────────────
let relatedArticles: any[] = [];
try {
  const folderName = categoryMapping[category as string];
  if (folderName) {
    const folderPath = resolve(process.cwd(), 'knowledge', 'en', folderName);
    const files = (await readdir(folderPath)).filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    );
    for (const file of files) {
      const articleSlug = basename(file, '.md');
      if (articleSlug === slug) continue;
      const filePath = join(folderPath, file);
      const { data: fm } = safeMatter(await readFile(filePath, 'utf-8'));
      relatedArticles.push({
        title: fm.title || articleSlug,
        slug: articleSlug,
        description: fm.description || '',
        image: fm.image || '',
        category,
      });
    }
    relatedArticles = relatedArticles.slice(0, 3);
  }
} catch {}

// ── Random explore list ───────────────────────────────────────────────────────
let allArticles: Array<{ title: string; slug: string; category: string }> = [];
try {
  for (const [catSlug, folderName] of Object.entries(categoryMapping)) {
    if (catSlug === category) continue;
    try {
      const catPath = resolve(process.cwd(), 'knowledge', 'en', folderName);
      for (const file of (await readdir(catPath)).filter(
        (f) => f.endsWith('.md') && !f.startsWith('_'),
      )) {
        const articleSlug = basename(file, '.md');
        const { data: fm } = safeMatter(
          await readFile(join(catPath, file), 'utf-8'),
        );
        allArticles.push({
          title: fm.title || articleSlug,
          slug: articleSlug,
          category: catSlug,
        });
      }
    } catch {}
  }
} catch {}

// ── Other categories ──────────────────────────────────────────────────────────
const otherCategories = categories
  .filter((cat) => cat !== category)
  .slice(0, 3)
  .map((cat) => ({ key: cat, ...categoryConfigs[cat as CategoryKey] }));

// ── Markdown → HTML ───────────────────────────────────────────────────────────
function resolveWikilinks(md: string) {
  if (!md) return md;
  return md.replace(
    /\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g,
    (_, target, display) => {
      return `**${display || target}**`;
    },
  );
}

const renderer = new marked.Renderer();

renderer.heading = ({ text, depth }) => {
  const id = text
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\w\u4e00-\u9fff-]/g, '')
    .slice(0, 60);
  return `<h${depth} id="${id}">${text}</h${depth}>`;
};

renderer.link = ({ href, title, text }) => {
  const isExternal =
    href?.startsWith('http://') || href?.startsWith('https://');
  // Fix bare internal links: /people/ang-lee → /en/people/ang-lee
  // EN markdown files sometimes link to /<cat>/<slug> without /en/ prefix.
  // These bare paths don't exist in the zh route (zh uses Chinese slugs).
  let h = href || '';
  if (
    !isExternal &&
    h.startsWith('/') &&
    !h.startsWith('/en/') &&
    !h.startsWith('/ja/') &&
    !h.startsWith('/ko/') &&
    !h.startsWith('/#') &&
    !h.startsWith('/about') &&
    !h.startsWith('/map') &&
    !h.startsWith('/data') &&
    !h.startsWith('/contribute') &&
    !h.startsWith('/dashboard') &&
    !h.startsWith('/soundscape') &&
    !h.startsWith('/resources') &&
    !h.startsWith('/changelog') &&
    !h.startsWith('/graph') &&
    !h.startsWith('/terminology')
  ) {
    h = `/en${h}`;
  }
  const titleAttr = title ? ` title="${title}"` : '';
  const targetAttr = isExternal
    ? ' target="_blank" rel="noopener noreferrer"'
    : '';
  return `<a href="${h}"${titleAttr}${targetAttr}>${text}</a>`;
};

renderer.image = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  return `<img src="${href}" alt="${text || ''}"${titleAttr} loading="lazy" onerror="this.onerror=null;this.classList.add('img-broken')" />`;
};

const processedContent = marked.parse(resolveWikilinks(content), {
  renderer,
  breaks: true,
}) as string;

// ── Reading time ───────────────────────────────────────────────────────────────
const estimatedReadingTime =
  frontmatter.readingTime ||
  Math.max(1, Math.round(content.replace(/\s+/g, ' ').length / 250));

const articleUrl = `https://taiwan.md/en/${category}/${slug}`;
const encodedUrl = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(title);
---

<Layout
  title={title}
  description={description}
  type="article"
  datePublished={frontmatter.date || new Date().toISOString()}
  dateModified={frontmatter.modified ||
    frontmatter.date ||
    new Date().toISOString()}
  content={content}
  tags={frontmatter.tags}
  category={categoryNameEn}
  lang="en"
>
  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <!--
    Phase 6 partial migration — en/[category]/[slug].astro
    ──────────────────────────────────────────────────────
    - Wrappers (article shell grid, meta strip, sources block,
      AI disclaimer, contribute row, bottom meta, return nav,
      related section, random explore, explore section) migrated
      to inline Tailwind
    - `.article-page` kept as hook: global.css has
      `body.page-default main.article-page { padding-top: 0 }`
    - `.prose :global(*)` rules stay in scoped <style> because
      the markdown body is rendered via `set:html={processedContent}`
      and its elements (h1-h6, p, ul, blockquote, code, table…)
      can't be reached by Tailwind classes
    - `.reading-progress` stays scoped because JS animates its
      width live and the bar reads `var(--catColor)` from the
      `define:vars` wrapper on the <style> block
    - Same markup structure is mirrored to ja/ko/zh-TW copies
  -->
  <main class="article-page bg-[#f8f1e9] min-h-screen" lang="en">
    <!-- ── Hero ─────────────────────────────────────────────────── -->
    <ArticleHero
      title={title}
      description={description}
      category={category}
      categoryName={categoryNameEn}
      categoryColor={categoryInfo.color}
      coverImage={categoryInfo.cover}
      slug={slug}
      lang="en"
    />

    <!-- ── Three-column body ─────────────────────────────────────── -->
    <div
      class="mx-auto grid max-w-[1280px] grid-cols-[220px_1fr_200px] [grid-template-areas:'toc_body_sidebar'] items-start gap-14 px-8 pb-20 pt-16 max-lg:grid-cols-1 max-lg:[grid-template-areas:'body'_'sidebar'] max-lg:gap-8 max-lg:px-6 max-lg:pb-16 max-lg:pt-10 max-[640px]:px-4 max-[640px]:pb-12 max-[640px]:pt-6"
    >
      <!-- Left: Table of Contents -->
      <div
        class="[grid-area:toc] max-lg:hidden"
        aria-label={t('article.toc', 'en')}
      >
        <TableOfContents content={processedContent} />
      </div>

      <!-- Center: Article content -->
      <article class="min-w-0 [grid-area:body]" data-pagefind-body>
        <!-- Status / date strip -->
        <div
          class="mb-10 flex flex-wrap items-center gap-3 border-b border-[rgba(26,60,52,0.08)] pb-8"
        >
          {
            frontmatter.status && (
              <span
                class="rounded-full px-3 py-1 font-['Inter',system-ui,sans-serif] text-[0.72rem] font-semibold uppercase tracking-[0.12em]"
                style={`background:${categoryInfo.colorLight}; color:${categoryInfo.color};`}
              >
                {frontmatter.status}
              </span>
            )
          }
          {
            frontmatter.date && (
              <time
                class="font-['Inter',system-ui,sans-serif] text-[0.8rem] text-[#7a8b7e]"
                datetime={frontmatter.date}
              >
                {new Date(frontmatter.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            )
          }
          <span
            class="ml-auto rounded-full border border-[rgba(26,60,52,0.12)] px-[0.6rem] py-[0.2rem] font-['Inter',system-ui,sans-serif] text-[0.75rem] text-[#9aa89e]"
            >{t('article.langLabel', 'en')}</span
          >
        </div>

        <!-- Prose body -->
        <div class="prose" set:html={processedContent} />

        <!-- Sources -->
        {
          frontmatter.source && frontmatter.source.length > 0 && (
            <div class="my-12 rounded-2xl border border-[rgba(26,60,52,0.08)] bg-[rgba(26,60,52,0.03)] p-8">
              <h3 class="mb-4 font-['Inter',system-ui,sans-serif] text-[0.85rem] font-semibold uppercase tracking-[0.1em] text-[#1a3c34]">
                {t('article.sources', 'en')}
              </h3>
              <ul class="m-0 flex list-none flex-col gap-2 p-0">
                {frontmatter.source.map((url: string) => (
                  <li>
                    <a
                      href={url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="break-all text-[0.82rem] text-[#006d77] no-underline hover:underline"
                    >
                      {url}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <!-- AI Disclaimer -->
        <div
          class="my-12 mb-8 flex items-start gap-4 rounded-xl border border-[rgba(193,125,94,0.18)] bg-[rgba(193,125,94,0.06)] px-6 py-5"
        >
          <div
            class="mt-[0.15rem] flex-shrink-0 text-[#c17d5e]"
            aria-hidden="true"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><line
                x1="12"
                y1="8"
                x2="12"
                y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"
              ></line></svg
            >
          </div>
          <div
            class="font-['Inter',system-ui,sans-serif] text-[0.83rem] leading-[1.6] text-[#5a4a42] [&>strong]:mb-[0.3rem] [&>strong]:block [&>strong]:text-[0.8rem] [&>strong]:font-semibold [&>strong]:uppercase [&>strong]:tracking-[0.08em] [&>strong]:text-[#c17d5e]"
          >
            <strong>{t('article.disclaimer.title', 'en')}</strong>
            {t('article.disclaimer.body', 'en')}
          </div>
        </div>

        <!-- Contribution row -->
        <div class="my-8 flex flex-wrap gap-3">
          <a
            href={`https://github.com/frank890417/taiwan-md/edit/main/knowledge/en/${categoryMapping[category as string]}/${slug}.md`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[0.45rem] rounded-full bg-[#1a3c34] px-[1.1rem] py-[0.55rem] font-['Inter',system-ui,sans-serif] text-[0.82rem] font-medium text-[#f8f1e9] no-underline transition-all duration-200 hover:bg-[#243d36]"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              ><path
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              ></path></svg
            >
            {t('article.editPage', 'en')}
          </a>
          <a
            href={`https://github.com/frank890417/taiwan-md/issues/new?title=${encodeURIComponent(`Feedback: ${title}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[0.45rem] rounded-full border border-[rgba(26,60,52,0.2)] bg-transparent px-[1.1rem] py-[0.55rem] font-['Inter',system-ui,sans-serif] text-[0.82rem] font-medium text-[#1a3c34] no-underline transition-all duration-200 hover:bg-[rgba(26,60,52,0.05)]"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              ><path
                d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
              ></path></svg
            >
            {t('article.reportIssue', 'en')}
          </a>
        </div>

        <!-- Tags + bottom share row -->
        <div
          class="my-12 mb-8 flex flex-wrap items-center justify-between gap-4 border-t border-[rgba(26,60,52,0.08)] pt-8 max-[640px]:flex-col max-[640px]:items-start"
        >
          {
            frontmatter.tags && frontmatter.tags.length > 0 && (
              <div class="flex flex-wrap gap-[0.4rem]">
                {frontmatter.tags.map((tag: string) => (
                  <span
                    class="rounded-full border px-[0.7rem] py-1 font-['Inter',system-ui,sans-serif] text-[0.75rem] font-medium"
                    style={`color:${categoryInfo.color}; background:${categoryInfo.colorLight}; border-color:${categoryInfo.color}28;`}
                  >
                    {tag}
                  </span>
                ))}
              </div>
            )
          }

          <div class="flex items-center gap-[0.4rem]">
            <span
              class="mr-1 font-['Inter',system-ui,sans-serif] text-[0.78rem] text-[#7a8b7e]"
              >{t('article.shareLabel', 'en')}</span
            >
            <a
              href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-[34px] w-[34px] cursor-pointer items-center justify-center rounded-full border-none bg-[rgba(26,60,52,0.06)] text-[#1a3c34] no-underline transition-[background,color] duration-200 hover:bg-[#1a3c34] hover:text-[#f8f1e9]"
              aria-label="Share on X"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.256 5.636L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path></svg
              >
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-[34px] w-[34px] cursor-pointer items-center justify-center rounded-full border-none bg-[rgba(26,60,52,0.06)] text-[#1a3c34] no-underline transition-[background,color] duration-200 hover:bg-[#1a3c34] hover:text-[#f8f1e9]"
              aria-label="Share on Facebook"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
                ></path></svg
              >
            </a>
            <a
              href={`https://social-plugins.line.me/lineit/share?url=${encodedUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-[34px] w-[34px] cursor-pointer items-center justify-center rounded-full border-none bg-[rgba(26,60,52,0.06)] text-[#1a3c34] no-underline transition-[background,color] duration-200 hover:bg-[#1a3c34] hover:text-[#f8f1e9]"
              aria-label="Share on LINE"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
