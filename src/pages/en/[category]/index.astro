  }

  .featured-card {
    grid-column: 1 / -1;
    max-width: 600px;
    margin: 0 auto;
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-image-placeholder {
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .featured-card .card-image-placeholder {
