    gap: 1rem;
    font-size: 0.9rem;
    color: #9ca3af;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  /* Coming Soon */
  .coming-soon {
    text-align: center;
    padding: 4rem 2rem;
  }

  .coming-soon-content {
    max-width: 500px;
    margin: 0 auto;
  }

  .coming-soon-icon {
    font-size: 5rem;
    margin-bottom: 2rem;
