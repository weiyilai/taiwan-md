---
import Layout from '../../layouts/Layout.astro';
import CategoryGrid from '../../components/CategoryGrid.astro';
import { getCollection } from 'astro:content';

// Count articles per category for English content
const categories = [
  { id: 'history', name: 'History', emoji: '📜' },
  { id: 'geography', name: 'Geography', emoji: '🗺️' },
  { id: 'culture', name: 'Culture', emoji: '🎭' },
  { id: 'food', name: 'Food', emoji: '🍜' },
  { id: 'art', name: 'Art', emoji: '🎨' },
  { id: 'music', name: 'Music', emoji: '🎵' },
  { id: 'technology', name: 'Technology', emoji: '💻' },
  { id: 'nature', name: 'Nature', emoji: '🌿' },
  { id: 'people', name: 'People', emoji: '👥' },
  { id: 'society', name: 'Society', emoji: '⚖️' },
  { id: 'economy', name: 'Economy', emoji: '📈' },
  { id: 'lifestyle', name: 'Lifestyle', emoji: '🏠' },
];

// Get English articles count
const articleCounts: Record<string, number> = {};
try {
  const allEnArticles = await getCollection('en');
  for (const cat of categories) {
    const categoryArticles = allEnArticles.filter(article => 
      article.id.startsWith(`${cat.id}/`) && !article.id.includes('/_')
    );
    articleCounts[cat.id] = categoryArticles.length;
  }
} catch (error) {
  console.warn('Error counting English articles:', error);
  // Set default counts
  categories.forEach(cat => {
    articleCounts[cat.id] = 0;
  });
}

// Prepare article list for random discovery
const allArticles = allEnArticles
  .filter(article => !article.id.includes('/_') && !article.id.endsWith('/_Hub.md'))
  .map(article => {
    const slug = article.id.split('/').slice(1).join('/').replace(/\.md$/, '');
    const category = article.id.split('/')[0];
    const categoryData = categories.find(c => c.id === category);
    return {
      title: article.data.title,
      url: `/en/${category}/${slug}`,
      category: categoryData ? categoryData.name : category
    };
  });

const randomArticlesData = JSON.stringify(allArticles);
---

