---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/home/HeroSection.astro';
import CoverStory from '../../components/home/CoverStory.astro';
import RandomDiscovery from '../../components/home/RandomDiscovery.astro';
import RecentUpdates from '../../components/home/RecentUpdates.astro';
import NewsletterSection from '../../components/home/NewsletterSection.astro';
import ContributeSection from '../../components/home/ContributeSection.astro';
import LanguageStatement from '../../components/home/LanguageStatement.astro';
import ReadingPath from '../../components/ReadingPath.astro';
import FeatureCards from '../../components/FeatureCards.astro';
import CategoryGrid from '../../components/CategoryGrid.astro';
import { fetchRecentCommits } from '../../lib/commits';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';
import { readdir, readFile } from 'fs/promises';
import { readFileSync, readdirSync } from 'node:fs';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const recentCommits = await fetchRecentCommits();

// Build article list for RandomDiscovery
const categories = [
  { id: 'history', name: 'History', folder: 'History' },
  { id: 'geography', name: 'Geography', folder: 'Geography' },
  { id: 'culture', name: 'Culture', folder: 'Culture' },
  { id: 'food', name: 'Food', folder: 'Food' },
  { id: 'art', name: 'Art', folder: 'Art' },
  { id: 'music', name: 'Music', folder: 'Music' },
  { id: 'technology', name: 'Technology', folder: 'Technology' },
  { id: 'nature', name: 'Nature', folder: 'Nature' },
  { id: 'people', name: 'People', folder: 'People' },
  { id: 'society', name: 'Society', folder: 'Society' },
  { id: 'economy', name: 'Economy', folder: 'Economy' },
  { id: 'lifestyle', name: 'Lifestyle', folder: 'Lifestyle' },
];

let allArticles: { title: string; url: string; category: string }[] = [];

for (const cat of categories) {
  try {
    const folderPath = resolve(process.cwd(), 'knowledge', 'en', cat.folder);
    const files = await readdir(folderPath);
    const mdFiles = files.filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    );

    for (const file of mdFiles) {
      try {
        const content = await readFile(join(folderPath, file), 'utf-8');
        const { data: frontmatter } = matter(content);
        const slug = basename(file, '.md');
        allArticles.push({
          title: frontmatter.title || slug,
          url: `/en/${cat.id}/${slug}`,
          category: cat.name,
        });
      } catch {
        // YAML parse error in this file, skip it
      }
    }
  } catch {
    // folder doesn't exist, skip
  }
}

const randomArticlesData = JSON.stringify(allArticles);

// ── Exhibition: scan A-grade EN articles for pick cards ──
interface PickArticle {
  title: string;
  href: string;
  footnotes: number;
  readingTime: number;
  description: string;
  featured?: boolean;
}

const categoryFolders: Record<string, string> = {
  history: 'History',
  geography: 'Geography',
  culture: 'Culture',
  food: 'Food',
  art: 'Art',
  music: 'Music',
  technology: 'Technology',
  nature: 'Nature',
  people: 'People',
  society: 'Society',
  economy: 'Economy',
  lifestyle: 'Lifestyle',
};

const topPicks: Record<string, PickArticle[]> = {};

for (const [slug, folder] of Object.entries(categoryFolders)) {
  const dir = resolve(process.cwd(), 'knowledge', 'en', folder);
  const picks: PickArticle[] = [];
  try {
    const files = readdirSync(dir).filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    );
    for (const file of files) {
      const raw = readFileSync(join(dir, file), 'utf-8');
      const { data } = matter(raw);
      const fnCount = (raw.match(/^\[\^\d+\]:/gm) || []).length;
      const threshold = data.featured ? 8 : 15;
      if (fnCount >= threshold) {
        picks.push({
          title: data.title || basename(file, '.md'),
          href: `/en/${slug}/${encodeURIComponent(basename(file, '.md'))}`,
          footnotes: fnCount,
          readingTime: data.readingTime || 10,
          description: data.description || '',
          featured: data.featured || false,
        });
      }
    }
  } catch {}
  topPicks[slug] = picks
    .sort((a, b) => {
      if (a.featured !== b.featured) return a.featured ? -1 : 1;
      return b.footnotes - a.footnotes;
    })
    .slice(0, 3);
}

// Hall-level dedup
const hallGroups: Record<string, string[]> = {
  hall1: ['geography', 'nature', 'lifestyle'],
  hall2: ['history', 'culture', 'society'],
  hall3: ['people', 'art', 'music'],
  hall4: ['technology', 'economy', 'food'],
};

for (const cats of Object.values(hallGroups)) {
  const seen = new Set<string>();
  for (const cat of cats) {
    topPicks[cat] = (topPicks[cat] || [])
      .filter((p) => {
        const prefix = p.title.slice(0, 4);
        if (seen.has(prefix)) return false;
        seen.add(prefix);
        return true;
      })
      .slice(0, 2);
  }
}

// ── Dynamic reading path ──
const usedCategories = new Set<string>();
const readingCandidates = Object.entries(topPicks)
  .flatMap(([cat, arts]) => arts.slice(0, 1).map((a) => ({ ...a, cat })))
  .sort((a, b) => b.footnotes - a.footnotes);

const readingPathSteps = readingCandidates
  .filter((a) => {
    if (usedCategories.has(a.cat)) return false;
    usedCategories.add(a.cat);
    return true;
  })
  .slice(0, 5)
  .map((a) => ({
    href: a.href,
    title: a.title,
    description:
      a.description.length > 60
        ? a.description.slice(0, 57) + '...'
        : a.description,
    time: `${a.readingTime} min`,
  }));

const totalTime = readingPathSteps.reduce(
  (sum, s) => sum + parseInt(s.time),
  0,
);

const readingPathFooterItems = [
  { icon: '⏱️', label: `Total ${totalTime} minutes` },
  { icon: '🎯', label: `${readingPathSteps.length} key domains` },
  { icon: '🌟', label: 'Complete Taiwan overview' },
];
---

<Layout
  title="Open Knowledge Base of Taiwan"
  description="The open-source, AI-friendly knowledge base about Taiwan. 660+ pages covering history, culture, food, music, technology and more — written by the community, for the world."
  lang="en"
>
  <HeroSection />

  <CoverStory />

  <RandomDiscovery articlesJson={randomArticlesData} />

  <FeatureCards
    lang="en"
    sectionTitle="Why Taiwan.md?"
    cards={[
      {
        icon: '🎯',
        title: 'Curated Perspectives',
        description:
          'Carefully curated deep narratives, not encyclopedic listings',
      },
      {
        icon: '🤖',
        title: 'AI-Friendly Design',
        description:
          "Structured content that helps AI understand Taiwan's complexity",
      },
      {
        icon: '🌍',
        title: 'Bilingual Global Vision',
        description:
          "Starting from local perspectives, telling Taiwan's story in global languages",
      },
      {
        icon: '📚',
        title: 'Complete Multi-dimensional',
        description:
          "Covering 12+ domains, presenting Taiwan's three-dimensional complete picture",
      },
    ]}
  />

  <ReadingPath
    lang="en"
    title="📖 Don't know where to start?"
    subtitle="Discover the real Taiwan in 30 minutes with these 5 essential articles"
    steps={readingPathSteps}
    footerItems={readingPathFooterItems}
    continueHref="#categories"
    continueLabel="Continue exploring more topics →"
  />

  <LanguageStatement />

  <!-- ===== EXHIBITION HALLS =====
       Partial Tailwind migration (Phase 6): wrappers (section,
       header, halls container, divider) moved to Tailwind. The
       repeated hall/pick card classes (.hall-divider, .hall-label,
       .hall-body, .hall-picks, .pick-card, .pick-head, .pick-title,
       .pick-fn, .pick-desc, .topic-pill) stay in scoped <style>
       because they repeat across 8 exhibition halls × 2 languages,
       and inlining them would turn the markup into noise. This is
       the same "scoped CSS is a tool" principle applied to Header.
  -->
  <section class="my-24" id="categories">
    <div class="mb-8 text-center">
      <h2
        class="text-center font-['jf-lanyangming','Noto_Serif_TC','Source_Han_Serif_TC',serif] text-[2rem] font-light text-[#1f2937]"
      >
        {t('home.categories.heading')}
      </h2>
    </div>

    <div
      class="exhibition-halls mx-auto max-w-[800px] px-8 max-[768px]:px-6 max-[480px]:px-4"
    >
      {/* ── Hall I: What this island looks like ── */}
      <div class="exhibition-hall">
        <div class="hall-divider">
          <div class="hall-line"></div>
          <span class="hall-label">I — What this island looks like</span>
          <div class="hall-line"></div>
        </div>
        <div class="hall-body">
          <p>
            Just 36,000 square kilometers, yet the Philippine Sea Plate pushes
            into the Eurasian Plate at 8 cm a year, making Taiwan one of the
            most mountainous islands on Earth.
            <a href="/en/geography" class="topic-pill">🗺️ The geography here</a>
            isn't a postcard — it's an island still growing taller. The Tropic of
            Cancer crosses Chiayi; on the same day you can drive from Kenting's tropical
            beach to Hehuan Mountain's frost.
          </p>
          {
            topPicks.geography && topPicks.geography.length > 0 && (
              <div class="hall-picks">
                {topPicks.geography.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            On an island smaller than the Netherlands, 59,000 species crowd
            together — 2.5% of global biodiversity. The Formosan landlocked
            salmon has survived 15,000 years in Dajia Creek; fewer than 600
            Formosan black bears remain.
            <a href="/en/nature" class="topic-pill">🌿 Taiwan's nature</a> vertically
            compresses every ecosystem from the equator to the subarctic — coral reefs
            to cloud forests in 3,000 meters. A paradise for ecologists, a frontline
            for development pressure.
          </p>
          {
            topPicks.nature && topPicks.nature.length > 0 && (
              <div class="hall-picks">
                {topPicks.nature.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            13,000 convenience stores — one for every 2,000 people. Pay bills,
            pick up packages, buy train tickets, photocopy your thesis, all at
            the same counter.
            <a href="/en/lifestyle" class="topic-pill">🏠 Taiwanese life</a> is wrapped
            in hyper-compressed infrastructure — but step into an alley after work,
            and grandma will still ask, "Have you eaten yet?"
          </p>
          {
            topPicks.lifestyle && topPicks.lifestyle.length > 0 && (
              <div class="hall-picks">
                {topPicks.lifestyle.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>

      {/* ── Hall II: How this island came to be ── */}
      <div class="exhibition-hall">
        <div class="hall-divider">
          <div class="hall-line"></div>
          <span class="hall-label">II — How this island came to be</span>
          <div class="hall-line"></div>
        </div>
        <div class="hall-body">
          <p>
            In 1624, the Dutch built Fort Zeelandia in Tainan. Eight regimes
            followed in four centuries — one every fifty years on average — each
            bringing new languages, laws, and time zones.
            <a href="/en/history" class="topic-pill">📜 Taiwan's history</a>'s
            most astonishing chapter came in 1996: 14.3 million people walked
            into polling stations and cast the first direct presidential vote in
            Chinese-speaking history. No bloodshed, no coup. An island under
            authoritarian rule for 38 years quietly turned itself into a
            democracy.
          </p>
          {
            topPicks.history && topPicks.history.length > 0 && (
              <div class="hall-picks">
                {topPicks.history.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            Sixteen indigenous peoples have lived here for 6,000 years. Hoklo
            brought Mazu, Hakka brought Yimin Ye, mainlanders brought Shandong
            mantou from military villages, Southeast Asian immigrants brought
            Eid al-Fitr.
            <a href="/en/culture" class="topic-pill">🎭 Taiwan's culture</a> is not
            a melting pot — nobody got melted. The Dajia Mazu pilgrimage draws a million
            walkers over nine days; the Tsou Mayasvi war ritual happens in Alishan
            the same month. Both are Taiwan, and they don't contradict.
          </p>
          {
            topPicks.culture && topPicks.culture.length > 0 && (
              <div class="hall-picks">
                {topPicks.culture.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            On May 17, 2019, the legislature voted to legalize same-sex marriage
            — making Taiwan the first in Asia. Six months earlier, 7.65 million
            people had just voted against it in a referendum.
            <a href="/en/society" class="topic-pill">⚖️ Taiwan's society</a>'s
            most fascinating quality is right here: the referendum said no, the
            legislature said yes, and society kept functioning. People finished
            arguing, then stood in line together for breakfast.
          </p>
          {
            topPicks.society && topPicks.society.length > 0 && (
              <div class="hall-picks">
                {topPicks.society.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>

      {/* ── Hall III: What the people are doing ── */}
      <div class="exhibition-hall">
        <div class="hall-divider">
          <div class="hall-line"></div>
          <span class="hall-label">III — What the people are doing</span>
          <div class="hall-line"></div>
        </div>
        <div class="hall-body">
          <p>
            Yan Chang-shou delivered mail at American Express at 23, became
            general manager five years later. Jeremy Lin sat on the bench for
            two years, then rewrote the NBA's Asian narrative in one week. Chen
            Shu-chu sold vegetables at Taitung market for 48 years and donated
            over NT$10 million.
            <a href="/en/people" class="topic-pill">👥 Taiwan's people</a>
            didn't walk out of textbooks — their stories are worth reading because
            every turning point could have not happened.
          </p>
          {
            topPicks.people && topPicks.people.length > 0 && (
              <div class="hall-picks">
                {topPicks.people.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            In 2009, Cai Guo-Qiang detonated nine gunpowder explosions at Taipei
            Fine Arts Museum. The same year, Lin Hwai-min's Cloud Gate Dance
            Theatre rose from the ashes of their Bali studio fire.
            <a href="/en/art" class="topic-pill">🎨 Taiwan's art</a> runs from temple
            Eight Generals face paint to the Venice Biennale, from Jiaozhi pottery
            to digital installations. The question Taiwan's creators ask most often
            isn't "what is beauty" — it's "who are we."
          </p>
          {
            topPicks.art && topPicks.art.length > 0 && (
              <div class="hall-picks">
                {topPicks.art.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            In 1932, Deng Yu-xian wrote "Longing for Spring Wind" — ninety years
            later it's still a KTV regular. The Bunun's pasibutbut (eight-part
            polyphony) caught UNESCO's attention because Western music theory
            can't explain it.
            <a href="/en/music" class="topic-pill">🎵 Taiwan's sound</a> runs from
            tribal chants to Mayday filling an arena with 100,000 voices. Music on
            this island isn't just entertainment — it's how each generation recognizes
            itself.
          </p>
          {
            topPicks.music && topPicks.music.length > 0 && (
              <div class="hall-picks">
                {topPicks.music.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>

      {/* ── Hall IV: Where this island is going ── */}
      <div class="exhibition-hall">
        <div class="hall-divider">
          <div class="hall-line"></div>
          <span class="hall-label">IV — Where this island is going</span>
          <div class="hall-line"></div>
        </div>
        <div class="hall-body">
          <p>
            90% of the world's advanced chips ship from Taiwan. A single TSMC
            fab costs US$20 billion; its cleanrooms are 10,000 times cleaner
            than operating theaters.
            <a href="/en/technology" class="topic-pill">💻 This tech island</a>
            started from tin-roof workshops in the 1980s Hsinchu Science Park and
            became, forty years later, a supply-chain node that no phone, laptop,
            or car on Earth can bypass. The trade-off: semiconductors consume 7% of
            Taiwan's total electricity — and rising.
          </p>
          {
            topPicks.technology && topPicks.technology.length > 0 && (
              <div class="hall-picks">
                {topPicks.technology.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            In 1960, Taiwan's GDP per capita was US$154 — lower than the
            Congo's. Sixty years later it exceeds US$33,000, without oil,
            colonial dividends, or continental hinterland.
            <a href="/en/economy" class="topic-pill">📈 Taiwan's economy</a>
            is the story of a resource-poor island turning itself into a global supply-chain
            hub. The method was singular: work harder and pivot faster than everyone
            else.
          </p>
          {
            topPicks.economy && topPicks.economy.length > 0 && (
              <div class="hall-picks">
                {topPicks.economy.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            A bowl of beef noodle soup: Sichuan red-braised base, Taiwanese soy
            sweetness, and a 1949 veteran's homesickness. Bubble tea left a
            Taichung tea house and landed on five continents.
            <a href="/en/food" class="topic-pill">🍜 Taiwan's flavor</a>
            is its immigration history — Hoklo oyster omelets, Hakka ginger intestines,
            indigenous millet wine, new immigrant fish sauce. Four centuries of homesickness,
            all simmering in the same night market.
          </p>
          {
            topPicks.food && topPicks.food.length > 0 && (
              <div class="hall-picks">
                {topPicks.food.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} sources</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </div>

    <div
      class="mx-auto my-12 flex max-w-[800px] items-center px-8 max-[480px]:px-4"
    >
      <div
        class="h-px flex-1 bg-[linear-gradient(90deg,transparent,#d1d5db,transparent)]"
      >
      </div>
      <span
        class="whitespace-nowrap px-6 font-[var(--font-title,'Noto_Serif_TC',serif)] text-[1.3rem] font-bold tracking-[0.05em] text-[#1a3c34]"
        >{t('home.categories.divider')}</span
      >
      <div
        class="h-px flex-1 bg-[linear-gradient(90deg,transparent,#d1d5db,transparent)]"
      >
      </div>
    </div>

    <CategoryGrid lang="en" />
  </section>

  <RecentUpdates commits={recentCommits} />

  <NewsletterSection />

  <ContributeSection />
</Layout>

<!--
  Phase 6 partial migration — en/index.astro
  ──────────────────────────────────────────
