<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline define:vars={{ mindmapData }}>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('resources-graph');
    if (!container) return;

    const data = JSON.parse(mindmapData);

    // Build hierarchy from flat data
    const root = { id: 'taiwan', label: '🇹🇼 台灣資源', children: [] };
    const catMap = {};
    data.nodes.forEach(n => {
      if (n.group === 'center') return;
      if (n.size > 10) {
        const cat = { ...n, children: [] };
        catMap[n.id] = cat;
        root.children.push(cat);
      }
    });
    data.nodes.forEach(n => {
      if (n.size <= 10 && n.group !== 'center') {
        const parentId = n.id.split('_')[0];
        if (catMap[parentId]) catMap[parentId].children.push(n);
      }
    });

    // D3 Tidy Tree — horizontal left-to-right (like Observable @d3/tree/2)
    const hierarchy = d3.hierarchy(root);
    const dx = 18; // vertical spacing between nodes
    const dy = 220; // horizontal spacing between levels
    const treeLayout = d3.tree().nodeSize([dx, dy]);
    treeLayout(hierarchy);

    // Compute bounding box
    let x0 = Infinity, x1 = -Infinity;
    hierarchy.each(d => {
      if (d.x > x1) x1 = d.x;
      if (d.x < x0) x0 = d.x;
    });
    const treeHeight = x1 - x0 + dx * 2;
    const width = container.clientWidth;
    const svgHeight = Math.max(700, treeHeight + 40);

    const svg = d3.select('#resources-graph')
      .append('svg')
      .attr('width', width)
      .attr('height', svgHeight)
      .attr('viewBox', [-dy, x0 - dx, width + 40, svgHeight])
      .style('max-width', '100%')
      .style('overflow', 'visible');

    const g = svg.append('g');

    // Zoom + pan
    svg.call(d3.zoom().scaleExtent([0.3, 2]).on('zoom', (event) => {
      g.attr('transform', event.transform);
    }));

    // Links — smooth horizontal bezier curves
    g.append('g')
      .attr('fill', 'none')
      .selectAll('path')
      .data(hierarchy.links())
      .join('path')
      .attr('d', d => {
        // Horizontal bezier (like d3.linkHorizontal)
        return `M${d.source.y},${d.source.x} C${(d.source.y + d.target.y) / 2},${d.source.x} ${(d.source.y + d.target.y) / 2},${d.target.x} ${d.target.y},${d.target.x}`;
      })
      .attr('stroke', d => d.target.data.color || '#94a3b8')
      .attr('stroke-width', d => d.target.depth === 1 ? 2 : 1.2)
      .attr('stroke-opacity', 0.5);

    // Nodes
    const nodeG = g.append('g')
      .selectAll('g')
      .data(hierarchy.descendants())
      .join('g')
      .attr('transform', d => `translate(${d.y},${d.x})`)
      .attr('cursor', d => d.data.url ? 'pointer' : 'default');

    nodeG.append('circle')
      .attr('r', d => {
        if (d.depth === 0) return 8;
        if (d.depth === 1) return 6;
        return 3.5;
      })
      .attr('fill', d => d.data.color || '#94a3b8')
      .attr('stroke', '#fff')
      .attr('stroke-width', 1.5);

    // Labels — always horizontal, right of node (or left for root)
    nodeG.append('text')
      .attr('dy', '0.32em')
      .attr('x', d => d.children ? -12 : 8)
      .attr('text-anchor', d => d.children ? 'end' : 'start')
      .attr('font-size', d => {
        if (d.depth === 0) return '14px';
        if (d.depth === 1) return '12px';
        return '10px';
      })
      .attr('font-weight', d => d.depth <= 1 ? '700' : '400')
      .attr('fill', d => d.depth === 0 ? '#065f46' : d.depth === 1 ? '#1a1a1a' : '#555')
      .text(d => d.data.label || d.data.name || '');

    // Click to navigate
    nodeG.on('click', (event, d) => {
      if (d.data.url) {
        window.open(d.data.url, '_blank', 'noopener noreferrer');
      }
    });

    // Hover effects
    nodeG.on('mouseover', function() {
      d3.select(this).select('circle')
        .transition().duration(150)
        .attr('stroke', '#3b82f6').attr('stroke-width', 3);
      d3.select(this).select('text')
        .transition().duration(150)
        .attr('fill', '#065f46').attr('font-weight', '700');
    }).on('mouseout', function(event, d) {
      d3.select(this).select('circle')
        .transition().duration(150)
        .attr('stroke', '#fff').attr('stroke-width', 1.5);
      d3.select(this).select('text')
        .transition().duration(150)
        .attr('fill', d.depth === 0 ? '#065f46' : d.depth === 1 ? '#1a1a1a' : '#555')
        .attr('font-weight', d.depth <= 1 ? '700' : '400');
    });
  });
</script>