  <!-- D3 泡泡圖腳本 -->
  <script define:vars={{ companies, sectorColors }}>
    const data = companies;
    const colors = sectorColors;

    // 載入 D3
    const script = document.createElement('script');
    script.src = 'https://d3js.org/d3.v7.min.js';
    script.onload = () => initBubbleChart(data, colors);
    document.head.appendChild(script);

    function initBubbleChart(data, colors) {
      const container = document.getElementById('bubble-chart');
      const width = container.clientWidth;
      const height = Math.max(500, window.innerHeight * 0.5);

      let currentMode = 'marketCap';
      let currentSector = 'all';

      const svg = d3
        .select('#bubble-chart')
        .append('svg')
        .attr('width', width)
        .attr('height', height)
        .attr('viewBox', `0 0 ${width} ${height}`);

      const tooltip = d3
        .select('#bubble-chart')
        .append('div')
        .attr('class', 'tooltip')
        .style('opacity', 0);

      function getValue(d) {
        return d[currentMode] || 0;
      }

      function getRadius(d) {
        const val = getValue(d);
        const maxVal = d3.max(data, getValue);
        const minR = 12;
        const maxR = Math.min(width, height) * 0.15;
        return minR + (maxR - minR) * Math.sqrt(val / maxVal);
      }

      const simulation = d3
        .forceSimulation(data)
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force('charge', d3.forceManyBody().strength(3))
        .force(
          'collision',
          d3.forceCollide().radius((d) => getRadius(d) + 1.5).strength(0.8)
        )
        .force('x', d3.forceX(width / 2).strength(0.05))
        .force('y', d3.forceY(height / 2).strength(0.05));

      const nodes = svg
        .selectAll('g.node')
        .data(data)
        .join('g')
        .attr('class', 'node')
        .call(
          d3
            .drag()
            .on('start', (e, d) => {
              if (!e.active) simulation.alphaTarget(0.3).restart();
              d.fx = d.x;
              d.fy = d.y;
            })
            .on('drag', (e, d) => {
              d.fx = e.x;
              d.fy = e.y;
            })
            .on('end', (e, d) => {
              if (!e.active) simulation.alphaTarget(0);
              d.fx = null;
              d.fy = null;
            })
        );

      const circles = nodes
        .append('circle')
        .attr('r', (d) => getRadius(d))
        .attr('fill', (d) => colors[d.sector] || '#888')
        .attr('fill-opacity', 0.8)
        .attr('stroke', (d) => colors[d.sector] || '#888')
        .attr('stroke-width', 2)
        .attr('stroke-opacity', 0.3)
        .style('cursor', 'grab');

      const labels = nodes
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'central')
        .attr('fill', '#fff')
        .attr('font-weight', '600')
        .attr('pointer-events', 'none')
        .each(function (d) {
          const r = getRadius(d);
          const el = d3.select(this);
          const shortName = d.name.split(' ')[0];
          if (r > 40) {
            el.append('tspan').attr('x', 0).attr('dy', '-0.3em').attr('font-size', `${Math.min(12, r / 4)}px`).text(shortName);
            el.append('tspan').attr('x', 0).attr('dy', '1.2em').attr('font-size', `${Math.min(10, r / 5)}px`).attr('fill-opacity', 0.8).text(d.marketCap.toLocaleString() + ' 億');
          } else if (r > 20) {
            el.attr('font-size', `${Math.min(10, r / 3)}px`).text(shortName);
          } else {
            el.attr('font-size', '8px').text(shortName.slice(0, 2));
          }
        });

      nodes
        .on('mouseover', (e, d) => {
          tooltip.transition().duration(200).style('opacity', 1);
          tooltip.html(`
            <strong>${d.name}</strong><br/>
            <span style="color:${colors[d.sector]||'#888'}">● ${d.sector}</span><br/>
            市值：${d.marketCap.toLocaleString()} 億 TWD<br/>
            營收：${d.revenue.toLocaleString()} 億 TWD<br/>
            員工：${d.employees.toLocaleString()} 人<br/>
            成立：${d.founded} 年
          `)
            .style('left', e.pageX + 15 + 'px')
            .style('top', e.pageY - 10 + 'px');
          d3.select(e.currentTarget).select('circle').attr('fill-opacity', 1).attr('stroke-width', 3);
        })
        .on('mouseout', (e) => {
          tooltip.transition().duration(300).style('opacity', 0);
          d3.select(e.currentTarget).select('circle').attr('fill-opacity', 0.8).attr('stroke-width', 2);
        });

      simulation.on('tick', () => {
        nodes.attr('transform', (d) => {
          d.x = Math.max(getRadius(d), Math.min(width - getRadius(d), d.x));
          d.y = Math.max(getRadius(d), Math.min(height - getRadius(d), d.y));
          return `translate(${d.x},${d.y})`;
        });
      });

      // Toggle 控制項
      document.querySelectorAll('.toggle-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.toggle-btn').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentMode = btn.dataset.mode;
          updateBubbles();
        });
      });

      document.querySelectorAll('.sector-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.sector-btn').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentSector = btn.dataset.sector;
          updateBubbles();
        });
      });

      function updateBubbles() {
        circles
          .transition()
          .duration(600)
          .attr('r', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return getRadius(d);
          })
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 0.8;
          });

        labels
          .transition()
          .duration(600)
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 1;
          });

        simulation
          .force(
            'collision',
            d3.forceCollide().radius((d) => {
              if (currentSector !== 'all' && d.sector !== currentSector) return 0;
              return getRadius(d) + 1.5;
            }).strength(0.8)
          )
          .alpha(0.6)
          .restart();
      }
    }
  </script>

  <!-- SVG 複製函數 -->
  <script is:inline>
    async function copySVG(filename, btn) {
      try {
        const res = await fetch('/assets/svg/' + filename);
        const text = await res.text();
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = '✅ 已複製';
        setTimeout(() => (btn.textContent = orig), 2000);
      } catch (e) {
        btn.textContent = '❌ 複製失敗';
        setTimeout(() => (btn.textContent = '複製代碼'), 2000);
      }
    }
  </script>

