---
/**
 * ArticleSidebar — Right sidebar with reading time, tags, share buttons.
 * Fully i18n-aware: date formatting, reading time label, share labels.
 */
import { useTranslatedPath, useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  title: string;
  tags?: string[];
  readingTime?: number;
  date?: string;
  lastModified?: string;
  contributors?: string[];
  category: string;
  categoryName: string;
  categoryColor: string;
  slug: string;
  lang?: Locale;
}

const {
  title,
  tags = [],
  readingTime,
  date,
  lastModified,
  contributors = [],
  category,
  categoryColor,
  slug,
  lang = 'zh-TW',
} = Astro.props;

const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const langPrefix = translatePath(lang);
const articleUrl = `https://taiwan.md${langPrefix}/${category}/${slug}`;
const encodedUrl = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(title);

// Locale-aware date formatting
const dateLocale = lang === 'zh-TW' ? 'zh-TW' : 'en-US';
const dateOpts: Intl.DateTimeFormatOptions = {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
};

const displayDate = date
  ? new Date(date).toLocaleDateString(dateLocale, dateOpts)
  : null;
const displayModified = lastModified
  ? new Date(lastModified).toLocaleDateString(dateLocale, dateOpts)
  : null;

// i18n labels
const readingTimeLabel =
  lang === 'zh-TW' ? `${readingTime} 分鐘閱讀` : `${readingTime} min read`;

const updatedLabel = lang === 'zh-TW' ? '更新於' : 'Updated';
const keywordsLabel = lang === 'zh-TW' ? '關鍵詞' : 'Tags';
const shareLabel = t('article.share');
const copyLinkLabel = t('article.copyLink');
const copiedLabel = t('article.copied');

const shareXLabel = lang === 'zh-TW' ? '分享到 X' : 'Share on X';
const shareFBLabel = lang === 'zh-TW' ? '分享到 Facebook' : 'Share on Facebook';
const shareLINELabel = lang === 'zh-TW' ? '分享到 LINE' : 'Share on LINE';
---

<aside class="article-sidebar">
  <!-- Reading meta -->
  <div class="sidebar-block sidebar-meta">
    {
      readingTime && (
        <div class="meta-row">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <>
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </>
          </svg>
          <span>{readingTimeLabel}</span>
        </div>
      )
    }
    {
      displayDate && (
        <div class="meta-row">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <>
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </>
          </svg>
          <span>{displayDate}</span>
        </div>
      )
    }
    {
      displayModified && displayModified !== displayDate && (
        <div class="meta-row meta-row--subtle">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <>
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </>
          </svg>
          <span>
            {updatedLabel} {displayModified}
          </span>
        </div>
      )
    }
  </div>

  <!-- Tags -->
  {
    tags.length > 0 && (
      <div class="sidebar-block">
        <p class="sidebar-label">{keywordsLabel}</p>
        <div class="tag-cloud">
          {tags.map((tag) => (
            <span
              class="tag"
              style={`color: ${categoryColor}; background: ${categoryColor}12; border-color: ${categoryColor}28;`}
            >
              {tag}
            </span>
          ))}
        </div>
      </div>
    )
  }

  <!-- Share -->
  <div class="sidebar-block">
    <p class="sidebar-label">{shareLabel}</p>
    <div class="share-stack">
      <a
        href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-row"
        aria-label={shareXLabel}
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          ><path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.256 5.636L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path></svg
        >
        <span>{shareXLabel}</span>
      </a>
      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-row"
        aria-label={shareFBLabel}
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          ><path
            d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
          ></path></svg
        >
        <span>{shareFBLabel}</span>
      </a>
      <a
        href={`https://social-plugins.line.me/lineit/share?url=${encodedUrl}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-row"
        aria-label={shareLINELabel}
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          ><path
            d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
          ></path></svg
        >
        <span>{shareLINELabel}</span>
      </a>
      <button
        class="share-row copy-link-btn"
        type="button"
        aria-label={copyLinkLabel}
        data-copied-text={copiedLabel}
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
          ></path><path
            d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
          ></path></svg
        >
        <span class="copy-link-text">{copyLinkLabel}</span>
      </button>
    </div>
  </div>

  <!-- Contributors -->
  {
    contributors.length > 0 && (
      <div class="sidebar-block">
        <p class="sidebar-label">貢獻者</p>
        <div class="contributor-list">
          {contributors.map((name) => (
            <a
              href={`https://github.com/${name}`}
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-chip"
            >
              {name}
            </a>
          ))}
        </div>
      </div>
    )
  }
</aside>

<style>
  .article-sidebar {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sidebar-block {
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(26, 60, 52, 0.08);
  }
  .sidebar-block:last-child {
    border-bottom: none;
  }

  .sidebar-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.67rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #9aa89e;
    margin-bottom: 0.85rem;
  }

  /* Meta rows */
  .sidebar-meta {
    padding-top: 0;
  }
  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.82rem;
    color: #4a5e52;
    margin-bottom: 0.5rem;
  }
  .meta-row svg {
    color: #7a8b7e;
    flex-shrink: 0;
  }
  .meta-row--subtle {
    color: #7a8b7e;
  }

  /* Tags */
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.28rem 0.65rem;
    border-radius: 100px;
    border: 1px solid;
  }

  /* Share */
  .share-stack {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .share-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.82rem;
    color: #4a5e52;
    text-decoration: none;
    padding: 0.45rem 0.5rem;
    border-radius: 6px;
    background: none;
    border: none;
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s;
    text-align: left;
    width: 100%;
  }
  .share-row:hover {
    background: rgba(26, 60, 52, 0.05);
    color: #1a3c34;
  }
  .share-row svg {
    flex-shrink: 0;
    color: #7a8b7e;
  }
  .share-row:hover svg {
    color: #1a3c34;
  }

  /* Contributors */
  .contributor-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .contributor-chip {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    color: #006d77;
    background: rgba(0, 109, 119, 0.07);
    border: 1px solid rgba(0, 109, 119, 0.15);
    padding: 0.22rem 0.6rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .contributor-chip:hover {
    background: rgba(0, 109, 119, 0.14);
  }
</style>

<script>
  (function () {
    const btn = document.querySelector<HTMLButtonElement>('.copy-link-btn');
    if (!btn) return;
    const textEl = btn.querySelector<HTMLSpanElement>('.copy-link-text');
    btn.addEventListener('click', () => {
      navigator.clipboard
        .writeText(window.location.href)
        .then(() => {
          if (textEl) textEl.textContent = '已複製';
          btn.style.color = '#006D77';
          setTimeout(() => {
            if (textEl) textEl.textContent = '複製連結';
            btn.style.color = '';
          }, 2200);
        })
        .catch(() => {
          const ta = document.createElement('textarea');
          ta.value = window.location.href;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          if (textEl) textEl.textContent = '已複製';
          setTimeout(() => {
            if (textEl) textEl.textContent = '複製連結';
          }, 2200);
        });
    });
  })();
</script>
