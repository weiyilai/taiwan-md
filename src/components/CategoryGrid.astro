---
import {
  useTranslations,
  getLangFromUrl,
  useTranslatedPath,
} from '../i18n/utils';
import { defaultLang } from '../i18n/ui';
import { getCategoryConfigs } from '../utils/categoryConfig';
import * as fs from 'node:fs';
import * as path from 'node:path';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const categoryConfigs = getCategoryConfigs(t);

// Count articles dynamically from knowledge/ directory
function countArticles(categorySlug: string): number {
  const categoryMap: Record<string, string> = {
    history: 'History',
    geography: 'Geography',
    culture: 'Culture',
    food: 'Food',
    art: 'Art',
    music: 'Music',
    technology: 'Technology',
    nature: 'Nature',
    people: 'People',
    society: 'Society',
    economy: 'Economy',
    lifestyle: 'Lifestyle',
  };
  const dirName = categoryMap[categorySlug] || categorySlug;
  const dirPath = path.join(
    process.cwd(),
    'knowledge',
    lang === defaultLang ? '/' : lang,
    dirName,
  );
  try {
    const files = fs.readdirSync(dirPath);
    return files.filter((f) => f.endsWith('.md') && !f.startsWith('_')).length;
  } catch {
    return 0;
  }
}

const categories = [
  {
    name: categoryConfigs['history'].name,
    slug: 'history',
    description: categoryConfigs['history'].description,
    icon: '📜',
    color: 'from-amber-500 to-orange-600',
    cover: '/images/wiki/b5604a9d7dac.jpg',
  },
  {
    name: categoryConfigs['geography'].name,
    slug: 'geography',
    description: categoryConfigs['geography'].description,
    icon: '🗺️',
    color: 'from-emerald-500 to-teal-600',
    cover: '/images/wiki/3a0af3fa1cff.jpg',
  },
  {
    name: categoryConfigs['culture'].name,
    slug: 'culture',
    description: categoryConfigs['culture'].description,
    icon: '🎭',
    color: 'from-purple-500 to-violet-600',
    cover: '/images/wiki/c3f69037472b.jpg',
  },
  {
    name: categoryConfigs['food'].name,
    slug: 'food',
    description: categoryConfigs['food'].description,
    icon: '🍜',
    color: 'from-rose-500 to-pink-600',
    cover: '/images/wiki/6a7bed12c2a6.jpg',
  },
  {
    name: categoryConfigs['art'].name,
    slug: 'art',
    description: categoryConfigs['art'].description,
    icon: '🎨',
    color: 'from-cyan-500 to-blue-600',
    cover: '/images/wiki/b92068ae92fb.jpg',
  },
  {
    name: categoryConfigs['music'].name,
    slug: 'music',
    description: categoryConfigs['music'].description,
    icon: '🎵',
    color: 'from-indigo-500 to-purple-600',
    cover: '/images/wiki/dba145c33d6d.jpg',
  },
  {
    name: categoryConfigs['technology'].name,
    slug: 'technology',
    description: categoryConfigs['technology'].description,
    icon: '💻',
    color: 'from-slate-500 to-gray-600',
    cover: '/images/wiki/f43072687967.jpg',
  },
  {
    name: categoryConfigs['nature'].name,
    slug: 'nature',
    description: categoryConfigs['nature'].description,
    icon: '🌿',
    color: 'from-green-500 to-emerald-600',
    cover: '/images/wiki/51510a8c6a50.jpg',
  },
  {
    name: categoryConfigs['people'].name,
    slug: 'people',
    description: categoryConfigs['people'].description,
    icon: '👥',
    color: 'from-orange-500 to-red-600',
    cover: '/images/wiki/4eadbb02099d.jpg',
  },
  {
    name: categoryConfigs['society'].name,
    slug: 'society',
    description: categoryConfigs['society'].description,
    icon: '🏛️',
    color: 'from-blue-500 to-indigo-600',
    cover: '/images/wiki/c18008c3ec52.jpg',
  },
  {
    name: categoryConfigs['economy'].name,
    slug: 'economy',
    description: categoryConfigs['economy'].description,
    icon: '📊',
    color: 'from-yellow-500 to-amber-600',
    cover: '/images/wiki/53ecc1645c5a.jpg',
  },
  {
    name: categoryConfigs['lifestyle'].name,
    slug: 'lifestyle',
    description: categoryConfigs['lifestyle'].description,
    icon: '🏠',
    color: 'from-teal-500 to-cyan-600',
    cover: '/images/wiki/c1fb1b3a4b79.jpg',
  },
];
---

<section class="category-grid" aria-label={t('CategoryGrid.aria-section')}>
  {
    categories.map((category) => {
      const count = countArticles(category.slug);

      return (
        <article>
          <a
            href={translatePath(`/${category.slug}`)}
            class="category-card"
            data-color={category.color}
            aria-label={`${t('CategoryGrid.aria-explore')} ${category.name}${t('CategoryGrid.aria-explore-suffix')}`}
          >
            <div class="category-header">
              {category.cover ? (
                <img
                  src={category.cover}
                  alt={`${category.name} ${t('CategoryGrid.alt-category-image-suffix')}`}
                  class="category-cover"
                  loading="lazy"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
              ) : null}
              <div
                class="category-icon"
                style={category.cover ? 'display:none' : ''}
              >
                {category.icon}
              </div>
              <div class="category-gradient" />
              <div class="article-badge">
                <span class="article-count">{count}</span>
                <span class="article-label">
                  {count > 1
                    ? t('CategoryGrid.articles')
                    : t('CategoryGrid.article')}
                </span>
              </div>
            </div>
            <div class="category-body">
              <h3 class="category-name">{category.name}</h3>
              <p class="category-description">{category.description}</p>
              <div class="category-footer">
                <span class="explore-link">{`${t('CategoryGrid.explore')}→`}</span>
              </div>
            </div>
          </a>
        </article>
      );
    })
  }
</section>

<style>
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin: 3rem auto;
    max-width: var(--container-wide);
    padding: 0;
  }

  .category-card {
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(226, 232, 240, 0.9);
    border-radius: 24px;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      border-color 0.28s ease;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 292px;
    backdrop-filter: blur(10px);
  }

  .category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 45px rgba(15, 23, 42, 0.1);
    border-color: rgba(148, 163, 184, 0.4);
  }

  .category-card:hover .category-gradient {
    opacity: 0.2;
  }

  .category-card:hover .category-icon {
    transform: scale(1.04);
  }

  .category-card:hover .explore-link {
    color: #1d4ed8;
  }

  .category-header {
    position: relative;
    height: 136px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }

  .category-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .category-card:hover .category-cover {
    transform: scale(1.04);
  }

  .category-gradient {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    opacity: 0.12;
    transition: opacity 0.4s ease;
  }

  /* 文章數量 badge */
  .article-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-radius: 999px;
    padding: 0.5rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #374151;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .article-count {
    color: #dc2626;
    font-weight: 700;
    font-size: 0.9rem;
  }

  /* Color gradients for each category */
  .category-card[data-color='from-amber-500 to-orange-600'] .category-gradient {
    background: linear-gradient(135deg, #f59e0b, #ea580c);
  }

  .category-card[data-color='from-emerald-500 to-teal-600'] .category-gradient {
    background: linear-gradient(135deg, #10b981, #0d9488);
  }

  .category-card[data-color='from-purple-500 to-violet-600']
    .category-gradient {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
  }

  .category-card[data-color='from-rose-500 to-pink-600'] .category-gradient {
    background: linear-gradient(135deg, #f43f5e, #db2777);
  }

  .category-card[data-color='from-cyan-500 to-blue-600'] .category-gradient {
    background: linear-gradient(135deg, #06b6d4, #2563eb);
  }

  .category-card[data-color='from-indigo-500 to-purple-600']
    .category-gradient {
    background: linear-gradient(135deg, #6366f1, #9333ea);
  }

  .category-card[data-color='from-slate-500 to-gray-600'] .category-gradient {
    background: linear-gradient(135deg, #64748b, #4b5563);
  }

  .category-card[data-color='from-green-500 to-emerald-600']
    .category-gradient {
    background: linear-gradient(135deg, #22c55e, #059669);
  }

  .category-card[data-color='from-orange-500 to-red-600'] .category-gradient {
    background: linear-gradient(135deg, #f97316, #dc2626);
  }

  .category-card[data-color='from-blue-500 to-indigo-600'] .category-gradient {
    background: linear-gradient(135deg, #3b82f6, #4f46e5);
  }

  .category-card[data-color='from-yellow-500 to-amber-600'] .category-gradient {
    background: linear-gradient(135deg, #eab308, #d97706);
  }

  .category-card[data-color='from-teal-500 to-cyan-600'] .category-gradient {
    background: linear-gradient(135deg, #14b8a6, #0891b2);
  }

  .category-icon {
    font-size: 3.25rem;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.15));
    transition: transform 0.28s ease;
  }

  .category-body {
    padding: 1.35rem 1.35rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .category-name {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    color: #1f2937;
    line-height: 1.25;
  }

  .category-description {
    color: #64748b;
    font-size: 0.96rem;
    line-height: 1.7;
    margin-bottom: 1.1rem;
    flex: 1;
  }

  .category-footer {
    display: flex;
    justify-content: flex-start;
    margin-top: auto;
  }

  .explore-link {
    color: #2563eb;
    font-weight: 600;
    font-size: 0.9rem;
    opacity: 1;
    transform: none;
    transition: color 0.2s ease;
  }

  @media (max-width: 1200px) {
    .category-grid {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }
  }

  @media (max-width: 768px) {
    .category-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
      margin: 2rem 0;
    }

    .category-card {
      min-height: 272px;
    }

    .category-header {
      height: 112px;
    }

    .category-icon {
      font-size: 2.8rem;
    }

    .category-name {
      font-size: 1.2rem;
    }

    .category-description {
      font-size: 0.9rem;
    }

    .article-badge {
      padding: 0.4rem 0.6rem;
      font-size: 0.75rem;
    }
  }
</style>
