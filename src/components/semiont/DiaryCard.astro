---
/**
 * DiaryCard — A single diary entry in the list view.
 * Styled as a notebook page: left border, warm tones, literary serif title.
 */
import type { DiaryEntry } from '../../lib/semiont-diary';
import { estimateReadingTime } from '../../lib/semiont-diary';

export interface Props {
  entry: DiaryEntry;
}

const { entry } = Astro.props;
const readingTime = estimateReadingTime(entry.wordCount);
---

<a
  href={`/semiont/diary/${entry.slug}`}
  class="group block border-l-2 border-[#b8860b]/15 py-6 pl-6 pr-4 transition-colors hover:border-[#b8860b]/40 hover:bg-[#b8860b]/[0.03]"
>
  {/* Date + session tag */}
  <div class="mb-2 flex items-center gap-2 font-mono text-xs text-[#b8860b]/60">
    <time datetime={entry.date}>{entry.date}</time>
    {
      entry.sessionGreek && (
        <span class="inline-flex h-5 items-center rounded-full bg-[#b8860b]/10 px-2 text-[10px] font-medium text-[#b8860b]/70">
          {entry.sessionGreek}
        </span>
      )
    }
  </div>

  {/* Title */}
  <h3
    class="mb-2 text-lg font-bold leading-snug text-[#2c2a26] group-hover:text-[#b8860b]/90"
    style="font-family: 'jf-jinxuanlatte', 'Noto Serif TC', serif;"
  >
    {entry.title}
  </h3>

  {/* Excerpt */}
  <p class="mb-3 text-sm leading-relaxed text-[#2c2a26]/50">
    {entry.excerpt}
  </p>

  {/* Meta row */}
  <div
    class="flex flex-wrap items-center gap-3 font-mono text-[10px] text-[#2c2a26]/30"
  >
    <span>{entry.wordCount.toLocaleString()} 字</span>
    <span>·</span>
    <span>{readingTime} 分鐘</span>
    {
      entry.duration && (
        <>
          <span>·</span>
          <span>session {entry.duration}</span>
        </>
      )
    }
  </div>
</a>
