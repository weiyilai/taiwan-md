---
/**
 * DiaryNav — Previous/next navigation between diary entries.
 */
export interface Props {
  prev?: { slug: string; title: string; date: string; sessionGreek: string };
  next?: { slug: string; title: string; date: string; sessionGreek: string };
}

const { prev, next } = Astro.props;
---

<nav
  class="mt-16 border-t border-[#b8860b]/10 pt-8"
  aria-label="diary navigation"
>
  <div class="flex flex-col gap-6 sm:flex-row sm:justify-between">
    {/* Previous (newer) */}
    {
      prev ? (
        <a
          href={`/semiont/diary/${prev.slug}`}
          class="group flex-1 rounded-lg p-4 transition-colors hover:bg-[#b8860b]/[0.04]"
        >
          <div class="mb-1 font-mono text-[10px] text-[#b8860b]/40">
            ← 上一篇
          </div>
          <div class="mb-1 font-mono text-xs text-[#b8860b]/50">
            {prev.date} {prev.sessionGreek}
          </div>
          <div
            class="text-sm font-medium text-[#2c2a26]/70 group-hover:text-[#2c2a26]"
            style="font-family: 'jf-jinxuanlatte', 'Noto Serif TC', serif;"
          >
            {prev.title.length > 30
              ? prev.title.slice(0, 30) + '⋯'
              : prev.title}
          </div>
        </a>
      ) : (
        <div class="flex-1" />
      )
    }

    {/* Next (older) */}
    {
      next ? (
        <a
          href={`/semiont/diary/${next.slug}`}
          class="group flex-1 rounded-lg p-4 text-right transition-colors hover:bg-[#b8860b]/[0.04]"
        >
          <div class="mb-1 font-mono text-[10px] text-[#b8860b]/40">
            下一篇 →
          </div>
          <div class="mb-1 font-mono text-xs text-[#b8860b]/50">
            {next.date} {next.sessionGreek}
          </div>
          <div
            class="text-sm font-medium text-[#2c2a26]/70 group-hover:text-[#2c2a26]"
            style="font-family: 'jf-jinxuanlatte', 'Noto Serif TC', serif;"
          >
            {next.title.length > 30
              ? next.title.slice(0, 30) + '⋯'
              : next.title}
          </div>
        </a>
      ) : (
        <div class="flex-1" />
      )
    }
  </div>
</nav>
