---
import type { Lang } from '../config/languages';

interface FeatureCard {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  lang?: Lang;
  sectionTitle: string;
  cards: FeatureCard[];
}

const { lang = 'zh-TW', sectionTitle, cards } = Astro.props;

const isZh = lang === 'zh-TW';
---

<!--
  Phase 4 leaf migration #2: FeatureCards.astro
  ────────────────────────────────────────────
  Desktop-first layout with `max-md:` mobile overrides (kicks in
  below 768px). The original `md:` prefixes were a bug — `md:` is
  min-width in Tailwind, so the overrides were inverted and landed
  on desktop instead of mobile, leaving the 4-col grid collapsed
  to 2 cols and margins shrunk on desktop. Fixed in Phase 8 after
  the user reported the homepage section looked skewed.

  Colors kept as arbitrary values (gray palette that doesn't match
  our ink tokens).
-->
<section
  class:list={[
    'mx-auto my-20 max-w-[1400px] px-8 max-md:mx-5 max-md:my-14 max-md:px-0',
    { 'features--zh': isZh },
  ]}
>
  <h2
    class:list={[
      'mb-12 text-center text-[2.5rem] font-bold text-[#1f2937] max-md:mb-8 max-md:text-[2rem]',
      {
        "font-extrabold font-['jf-lanyanghei','Noto_Sans_TC','Source_Han_Sans_TC',sans-serif]":
          isZh,
      },
    ]}
  >
    {sectionTitle}
  </h2>
  <div
    class="mx-auto grid max-w-[1100px] grid-cols-4 gap-4 max-md:grid-cols-2 max-md:gap-5"
  >
    {
      cards.map((card) => (
        <div class="flex flex-col items-start gap-2 rounded-xl border border-[#f1f5f9] bg-white p-5 shadow-[0_2px_8px_rgba(0,0,0,0.04)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[#e2e8f0] hover:shadow-[0_8px_20px_rgba(0,0,0,0.08)] max-md:gap-4 max-md:p-6">
          <div class="flex-shrink-0 text-[2.5rem] leading-none [filter:drop-shadow(0_2px_4px_rgba(0,0,0,0.1))] max-md:text-[2.25rem]">
            {card.icon}
          </div>
          <div>
            <h3 class="mb-2 text-[1.15rem] font-semibold leading-tight text-[#1f2937] max-md:text-[1.1rem]">
              {card.title}
            </h3>
            <p class="m-0 text-[0.95rem] leading-relaxed text-[#6b7280] max-md:text-[0.9rem]">
              {card.description}
            </p>
          </div>
        </div>
      ))
    }
  </div>
  <slot />
</section>
