---
import CommitLog from '../commits/CommitLog.astro';
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../../i18n/utils';
import type { Commit } from '../../lib/commits';

interface Props {
  commits: Commit[];
}

const { commits } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

{
  commits.length > 0 && (
    <section class="recent-updates">
      <div class="updates-inner">
        <div class="updates-header">
          <h2>{t('home.updates.heading')}</h2>
          <p class="updates-subtitle">{t('home.updates.subtitle')}</p>
        </div>
        <CommitLog commits={commits} lang={lang} variant="cards" />
        <div class="updates-footer">
          <a href={translatePath('/changelog')} class="updates-more-btn">
            {t('home.updates.viewAll')}
          </a>
        </div>
      </div>
    </section>
  )
}

<style>
  .recent-updates {
    max-width: 980px;
    margin: 4rem auto;
    padding: 0 2rem;
  }
  .updates-inner {
    background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
    border-radius: 20px;
    border: 1px solid #e0f2fe;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .updates-inner::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 200px;
    background: radial-gradient(
      circle,
      rgba(59, 130, 246, 0.05) 0%,
      transparent 70%
    );
  }
  .updates-header {
    text-align: center;
    margin-bottom: 2rem;
    position: relative;
    z-index: 2;
  }
  .updates-header h2 {
    font-size: 1.8rem;
    font-weight: 800;
    color: #1e3a5f;
    margin-bottom: 0.5rem;
    font-family:
      'jf-lanyanghei', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
  }
  .updates-subtitle {
    font-size: 1rem;
    color: #64748b;
    font-weight: 500;
  }
  :global(.recent-updates .commit-log) {
    position: relative;
    z-index: 2;
    max-width: 860px;
    margin: 0 auto;
  }
  .updates-footer {
    text-align: center;
    margin-top: 1.5rem;
    position: relative;
    z-index: 2;
  }
  .updates-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.6rem 1.5rem;
    background: #1e3a5f;
    color: white;
    text-decoration: none;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s ease;
  }
  .updates-more-btn:hover {
    background: #1e40af;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(30, 64, 175, 0.3);
  }
  @media (max-width: 768px) {
    .recent-updates {
      padding: 0 1rem;
      margin: 3rem auto;
    }
    .updates-inner {
      padding: 1.5rem;
    }
    .updates-header h2 {
      font-size: 1.5rem;
    }
  }
</style>
