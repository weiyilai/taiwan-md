---
import { getLangSwitchPath } from '../utils/getLangSwitchPath';

const currentPath = Astro.url.pathname;

const { enLink } = await getLangSwitchPath(currentPath);
---

<div id="lang-banner" class="lang-banner" style="display:none;">
  <span
    >🌐 English version available → <a href={enLink}>Switch to English</a></span
  >
  <button
    class="lang-banner-close"
    onclick="document.getElementById('lang-banner').style.display='none';localStorage.setItem('lang-banner-dismissed','1');var h=document.getElementById('main-header');if(h)h.style.top='0px';"
    aria-label="Close">✕</button
  >
</div>
<script is:inline>
  (function () {
    if (localStorage.getItem('lang-banner-dismissed')) return;
    var lang = navigator.language || navigator.userLanguage || '';
    if (lang.startsWith('zh')) return;
    if (window.location.pathname.startsWith('/en')) return;
    var b = document.getElementById('lang-banner');
    if (b) b.style.display = 'flex';
  })();
</script>
<style>
  .lang-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: #007864;
    color: white !important;
    font-size: 0.85rem;
    text-align: center;
    line-height: 1.4;
    position: relative;
    z-index: 50;
  }
  .lang-banner a {
    color: #4fd1b0;
    font-weight: 600;
    text-decoration: underline;
  }
  .lang-banner a:hover {
    color: #7ee8ca;
  }
  .lang-banner-close {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
    cursor: pointer;
    padding: 0 0.3rem;
  }
  .lang-banner-close:hover {
    color: white;
  }
</style>
