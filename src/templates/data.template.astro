---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import {
  getCompanyConfigs,
  getCategories,
  sectorColors,
} from '../utils/dataConfig';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get companies from centralized config
const companies = getCompanyConfigs(t);

const sectors = [...new Set(companies.map((c) => c.sector))];

// Get categories from centralized config
const dataCategories = getCategories(t);
---

<Layout title={t('data.meta.title')} description={t('data.meta.description')}>
  <main class="data-hub">
    <!-- Hero -->
    <section class="hero">
      <h1 class="hero-title"><span class="hero-emoji">📊</span> {t('data.hero.title')}</h1>
      <p class="hero-subtitle">{t('data.hero.subtitle')}</p>
      <p class="hero-desc">{t('data.hero.description')}</p>
    </section>

    <!-- Taiwan vs World Infographic Section -->
    <section class="taiwan-vs-world-section" id="global">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.taiwanVsWorld.title')}</h2>
        <div class="story-text">
          <p>{t('data.taiwanVsWorld.story.p1')}</p>
          <p>{t('data.taiwanVsWorld.story.p2')}</p>
        </div>
      </div>

      <div class="comparison-cards">
        <div class="comparison-card">
          <div class="card-emoji">📏</div>
          <div class="card-number">{t('data.taiwanVsWorld.area.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.area.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.area.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">💰</div>
          <div class="card-number">{t('data.taiwanVsWorld.gdp.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.gdp.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.gdp.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🏭</div>
          <div class="card-number">{t('data.taiwanVsWorld.semiconductor.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.semiconductor.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.semiconductor.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🗳️</div>
          <div class="card-number">{t('data.taiwanVsWorld.democracy.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.democracy.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.democracy.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">👶</div>
          <div class="card-number">{t('data.taiwanVsWorld.birthRate.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.birthRate.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.birthRate.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🏪</div>
          <div class="card-number">{t('data.taiwanVsWorld.convenience.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.convenience.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.convenience.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🚄</div>
          <div class="card-number">{t('data.taiwanVsWorld.hsr.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.hsr.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.hsr.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🏥</div>
          <div class="card-number">{t('data.taiwanVsWorld.healthcare.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.healthcare.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.healthcare.context')}</div>
        </div>
      </div>
    </section>

    <!-- Population Pyramid Section -->
    <section class="population-section" id="population">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.population.title')}</h2>
        <div class="story-text">
          <p>{t('data.population.story.p1')}</p>
          <p>{t('data.population.story.p2')}</p>
        </div>
      </div>

      <!-- Population Pyramid Chart -->
      <div class="pyramid-container">
        <div id="population-pyramid"></div>
        
        <!-- Year Slider -->
        <div class="year-slider-container">
          <div class="slider-track">
            <div class="slider-thumb" id="yearThumb"></div>
          </div>
          <div class="year-labels">
            <span>2000</span>
            <span>2010</span>
            <span>2025</span>
            <span>2050</span>
          </div>
          <div class="current-year" id="currentYear">2025</div>
        </div>
      </div>

      <!-- Key Insights Cards -->
      <div class="insights">
        <div class="insight-grid">
          <div class="insight-card">
            <div class="insight-label">
              {t('data.population.insights.card1.title')}
            </div>
            <div class="insight-number">
              {t('data.population.insights.card1.detail')}
            </div>
            <div class="insight-detail">
              {t('data.population.insights.card1.subtitle')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-label">
              {t('data.population.insights.card2.title')}
            </div>
            <div class="insight-number">
              {t('data.population.insights.card2.detail')}
            </div>
            <div class="insight-detail">
              {t('data.population.insights.card2.subtitle')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-label">
              {t('data.population.insights.card3.title')}
            </div>
            <div class="insight-number">
              {t('data.population.insights.card3.detail')}
            </div>
            <div class="insight-detail">
              {t('data.population.insights.card3.subtitle')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-label">
              {t('data.population.insights.card4.title')}
            </div>
            <div class="insight-number">
              {t('data.population.insights.card4.detail')}
            </div>
            <div class="insight-detail">
              {t('data.population.insights.card4.subtitle')}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Taiwan Shape Section -->
    <section class="taiwan-shape-section" id="shape">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.taiwanShape.title')}</h2>
        <div class="story-text">
          <p>{t('data.taiwanShape.story.p1')}</p>
          <p>{t('data.taiwanShape.story.p2')}</p>
        </div>
      </div>

      <!-- AI vs Real Taiwan Comparison -->
      <div class="taiwan-comparison">
        <h3 class="comparison-title">{t('data.taiwanComparison.title')}</h3>
        <div class="comparison-grid">
          <div class="comparison-item wrong">
            <div class="svg-container">
              <img src="/assets/svg/ai-taiwan-wrong.svg" alt="AI Generated Taiwan (Wrong)" />
            </div>
            <div class="comparison-label wrong">
              {t('data.taiwanComparison.aiGenerated')}
            </div>
          </div>
          <div class="comparison-vs">VS</div>
          <div class="comparison-item correct">
            <div class="svg-container">
              <img src="/assets/svg/taiwan-icon-wiki.svg" alt="Correct Taiwan Shape" />
            </div>
            <div class="comparison-label correct">
              {t('data.taiwanComparison.correct')}
            </div>
          </div>
        </div>
      </div>

      <!-- SVG Cards -->
      <div class="svg-grid">
        <div class="svg-card">
          <div class="svg-preview">
            <img src="/assets/svg/taiwan-icon-wiki.svg" alt="Taiwan Icon" />
          </div>
          <div class="svg-info">
            <h3>{t('data.svg.card1.title')}</h3>
            <p class="svg-desc">{t('data.svg.card1.description')}</p>
            <p class="svg-meta">Wikimedia Commons · CC</p>
            <div class="svg-actions">
              <a
                href="/assets/svg/taiwan-icon-wiki.svg"
                download
                class="btn btn-primary"
              >
                {t('data.svg.button.download')}
              </a>
              <button
                class="btn btn-outline"
                onclick="copySVG('taiwan-icon-wiki.svg', this)"
              >
                {t('data.svg.button.copy')}
              </button>
            </div>
          </div>
        </div>

        <div class="svg-card">
          <div class="svg-preview">
            <img
              src="/assets/svg/taiwan-simplemaps.svg"
              alt="Taiwan SimpleMaps"
            />
          </div>
          <div class="svg-info">
            <h3>{t('data.svg.card2.title')}</h3>
            <p class="svg-desc">{t('data.svg.card2.description')}</p>
            <p class="svg-meta">SimpleMaps · 5 KB</p>
            <div class="svg-actions">
              <a
                href="/assets/svg/taiwan-simplemaps.svg"
                download
                class="btn btn-primary"
              >
                {t('data.svg.button.download')}
              </a>
              <button
                class="btn btn-outline"
                onclick="copySVG('taiwan-simplemaps.svg', this)"
              >
                {t('data.svg.button.copy')}
              </button>
            </div>
          </div>
        </div>

        <div class="svg-card">
          <div class="svg-preview">
            <img
              src="/assets/svg/taiwan-location-map.svg"
              alt="Taiwan Location Map"
            />
          </div>
          <div class="svg-info">
            <h3>{t('data.svg.card3.title')}</h3>
            <p class="svg-desc">{t('data.svg.card3.description')}</p>
            <p class="svg-meta">Wikimedia Commons · CC</p>
            <div class="svg-actions">
              <a
                href="/assets/svg/taiwan-location-map.svg"
                download
                class="btn btn-primary"
              >
                {t('data.svg.button.download')}
              </a>
              <button
                class="btn btn-outline"
                onclick="copySVG('taiwan-location-map.svg', this)"
              >
                {t('data.svg.button.copy')}
              </button>
            </div>
          </div>
        </div>

        <div class="svg-card">
          <div class="svg-preview">
            <img
              src="/assets/svg/taiwan-political-division.svg"
              alt="Taiwan Political Division"
            />
          </div>
          <div class="svg-info">
            <h3>{t('data.svg.card4.title')}</h3>
            <p class="svg-desc">{t('data.svg.card4.description')}</p>
            <p class="svg-meta">Wikimedia Commons · CC</p>
            <div class="svg-actions">
              <a
                href="/assets/svg/taiwan-political-division.svg"
                download
                class="btn btn-primary"
              >
                {t('data.svg.button.download')}
              </a>
              <button
                class="btn btn-outline"
                onclick="copySVG('taiwan-political-division.svg', this)"
              >
                {t('data.svg.button.copy')}
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Usage Example -->
      <div class="usage-example">
        <h3>{t('data.svg.usage.heading')}</h3>
        <div class="code-block">
          <pre><code>&lt;!-- 直接嵌入 / Embed directly --&gt;
&lt;img src="https://taiwan.md/assets/svg/taiwan-icon-wiki.svg" alt="Taiwan" width="200"&gt;

&lt;!-- 作為 CSS 背景 / As CSS background --&gt;
background-image: url('https://taiwan.md/assets/svg/taiwan-icon-wiki.svg');

&lt;!-- 在 Markdown 中引用 / In Markdown --&gt;
![Taiwan](https://taiwan.md/assets/svg/taiwan-icon-wiki.svg)</code></pre>
        </div>
        <p class="license-note">
          {t('data.svg.usage.licenseNote')}
        </p>
      </div>
    </section>

    <!-- Digital Democracy Timeline Section -->
    <section class="digital-democracy-section" id="democracy">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.digitalDemocracy.title')}</h2>
        <div class="story-text">
          <p>{t('data.digitalDemocracy.story.p1')}</p>
          <p>{t('data.digitalDemocracy.story.p2')}</p>
        </div>
      </div>

      <!-- Horizontal Timeline -->
      <div class="timeline-container">
        <div class="timeline-horizontal">
          <div class="timeline-item" data-year="1997">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">1997</div>
              <div class="timeline-title">{t('data.timeline.1997.title')}</div>
              <div class="timeline-desc">{t('data.timeline.1997.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2003">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2003</div>
              <div class="timeline-title">{t('data.timeline.2003.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2003.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2012">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2012</div>
              <div class="timeline-title">{t('data.timeline.2012.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2012.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2013">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2013</div>
              <div class="timeline-title">{t('data.timeline.2013.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2013.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2014">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2014</div>
              <div class="timeline-title">{t('data.timeline.2014.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2014.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2015">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2015</div>
              <div class="timeline-title">{t('data.timeline.2015.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2015.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2016">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2016</div>
              <div class="timeline-title">{t('data.timeline.2016.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2016.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2020">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2020</div>
              <div class="timeline-title">{t('data.timeline.2020.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2020.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2022">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2022</div>
              <div class="timeline-title">{t('data.timeline.2022.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2022.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2023">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2023</div>
              <div class="timeline-title">{t('data.timeline.2023.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2023.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2024">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2024</div>
              <div class="timeline-title">{t('data.timeline.2024.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2024.desc')}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Open Data Categories (3-column grid) -->
      <div class="open-data-section" id="opendata">
        <h3 class="section-title" style="margin-top: 3rem; margin-bottom: 2rem;">📊 開放資料</h3>
        <div class="data-categories-grid">
          {
            dataCategories.map((cat) => (
              <div class="data-category-card">
                <div class="category-header">
                  <span class="category-icon">{cat.icon}</span>
                  <div>
                    <h4 class="category-title">{cat.title}</h4>
                    <p class="category-desc">{cat.description}</p>
                  </div>
                </div>
                <ul class="item-list">
                  {cat.items.map((item) => (
                    <li class="item">
                      <a
                        href={item.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="item-link"
                      >
                        {item.name}
                      </a>
                      <span class="item-desc">— {item.desc}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Enterprise Landscape -->
    <section class="companies-section" id="enterprise">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.enterprise.title')}</h2>
        <div class="story-text">
          <p>{t('data.enterprise.story.p1')}</p>
          <p>{t('data.enterprise.story.p2')}</p>
        </div>
      </div>

      <!-- Bubble Chart Controls -->
      <div class="bubble-controls">
        <div class="size-toggle">
          <label>{t('data.enterprise.controls.sizeLabel')}</label>
          <button class="toggle-btn active" data-mode="marketCap">
            {t('data.enterprise.controls.marketCap')}
          </button>
          <button class="toggle-btn" data-mode="revenue">
            {t('data.enterprise.controls.revenue')}
          </button>
          <button class="toggle-btn" data-mode="employees">
            {t('data.enterprise.controls.employees')}
          </button>
        </div>
        <div class="sector-filters">
          <button class="sector-btn active" data-sector="all">
            {t('data.enterprise.controls.filterAll')}
          </button>
          {
            sectors.slice(0, 8).map((s) => (
              <button
                class="sector-btn"
                data-sector={s}
                style={`--sector-color: ${sectorColors[s] || '#888'}`}
              >
                <span
                  class="sector-dot"
                  style={`background: ${sectorColors[s] || '#888'}`}
                />
                {t(`data.sector.${s}`)}
              </button>
            ))
          }
        </div>
      </div>

      <!-- Bubble Chart Container -->
      <div id="bubble-chart"></div>

      <!-- Key Insights -->
      <div class="insights">
        <div class="insight-grid">
          <div class="insight-card">
            <div class="insight-number">
              {t('data.enterprise.insights.card1.number')}
            </div>
            <div class="insight-label">
              {t('data.enterprise.insights.card1.label')}
            </div>
            <div class="insight-detail">
              {t('data.enterprise.insights.card1.detail')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-number">
              {t('data.enterprise.insights.card2.number')}
            </div>
            <div class="insight-label">
              {t('data.enterprise.insights.card2.label')}
            </div>
            <div class="insight-detail">
              {t('data.enterprise.insights.card2.detail')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-number">
              {t('data.enterprise.insights.card3.number')}
            </div>
            <div class="insight-label">
              {t('data.enterprise.insights.card3.label')}
            </div>
            <div class="insight-detail">
              {t('data.enterprise.insights.card3.detail')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-number">
              {t('data.enterprise.insights.card4.number')}
            </div>
            <div class="insight-label">
              {t('data.enterprise.insights.card4.label')}
            </div>
            <div class="insight-detail">
              {t('data.enterprise.insights.card4.detail')}
            </div>
          </div>
        </div>
        <div class="explore-more">
          <a href="/economy" class="explore-link">
            {t('data.enterprise.exploreLink')}
          </a>
        </div>
      </div>
    </section>







    <!-- Footer -->
    <footer class="data-footer">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <h3 class="footer-title">{t('data.footer.heading')}</h3>
      <div class="footer-links">
        <a href="/economy" class="footer-link">
          <span class="footer-icon">📈</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link1.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link1.description')}
            </span>
          </div>
        </a>
        <a href="/graph" class="footer-link">
          <span class="footer-icon">🕸️</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link2.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link2.description')}
            </span>
          </div>
        </a>
        <a href="/contribute" class="footer-link">
          <span class="footer-icon">✋</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link3.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link3.description')}
            </span>
          </div>
        </a>
      </div>
    </footer>
  </main>

  <!-- D3 Bubble Chart Script -->
  <script define:vars={{ companies, sectorColors, lang }}>
    const data = companies;
    const colors = sectorColors;
    const currentLang = lang;

    // Load D3
    const script = document.createElement('script');
    script.src = 'https://d3js.org/d3.v7.min.js';
    script.onload = () => initBubbleChart(data, colors, currentLang);
    document.head.appendChild(script);

    function initBubbleChart(data, colors, lang) {
      const container = document.getElementById('bubble-chart');
      const width = container.clientWidth;
      const height = Math.max(500, window.innerHeight * 0.5);

      let currentMode = 'marketCap';
      let currentSector = 'all';

      const svg = d3
        .select('#bubble-chart')
        .append('svg')
        .attr('width', width)
        .attr('height', height)
        .attr('viewBox', `0 0 ${width} ${height}`);

      const tooltip = d3
        .select('#bubble-chart')
        .append('div')
        .attr('class', 'tooltip')
        .style('opacity', 0);

      function getValue(d) {
        return d[currentMode] || 0;
      }

      function getRadius(d) {
        const val = getValue(d);
        const maxVal = d3.max(data, getValue);
        const minR = 12;
        const maxR = Math.min(width, height) * 0.15;
        return minR + (maxR - minR) * Math.sqrt(val / maxVal);
      }

      const simulation = d3
        .forceSimulation(data)
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force('charge', d3.forceManyBody().strength(3))
        .force(
          'collision',
          d3
            .forceCollide()
            .radius((d) => getRadius(d) + 1.5)
            .strength(0.8),
        )
        .force('x', d3.forceX(width / 2).strength(0.05))
        .force('y', d3.forceY(height / 2).strength(0.05));

      const nodes = svg
        .selectAll('g.node')
        .data(data)
        .join('g')
        .attr('class', 'node')
        .call(
          d3
            .drag()
            .on('start', (e, d) => {
              if (!e.active) simulation.alphaTarget(0.3).restart();
              d.fx = d.x;
              d.fy = d.y;
            })
            .on('drag', (e, d) => {
              d.fx = e.x;
              d.fy = e.y;
            })
            .on('end', (e, d) => {
              if (!e.active) simulation.alphaTarget(0);
              d.fx = null;
              d.fy = null;
            }),
        );

      const circles = nodes
        .append('circle')
        .attr('r', (d) => getRadius(d))
        .attr('fill', (d) => colors[d.sector] || '#888')
        .attr('fill-opacity', 0.8)
        .attr('stroke', (d) => colors[d.sector] || '#888')
        .attr('stroke-width', 2)
        .attr('stroke-opacity', 0.3)
        .style('cursor', 'grab');

      const labels = nodes
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'central')
        .attr('fill', '#fff')
        .attr('font-weight', '600')
        .attr('pointer-events', 'none')
        .each(function (d) {
          const r = getRadius(d);
          const el = d3.select(this);
          const shortName = d.name.split(' ')[0];
          const suffix = lang === 'zh-TW' ? ' 億' : 'B';
          if (r > 40) {
            el.append('tspan')
              .attr('x', 0)
              .attr('dy', '-0.3em')
              .attr('font-size', `${Math.min(12, r / 4)}px`)
              .text(shortName);
            el.append('tspan')
              .attr('x', 0)
              .attr('dy', '1.2em')
              .attr('font-size', `${Math.min(10, r / 5)}px`)
              .attr('fill-opacity', 0.8)
              .text(d.marketCap.toLocaleString() + suffix);
          } else if (r > 20) {
            el.attr('font-size', `${Math.min(10, r / 3)}px`).text(shortName);
          } else {
            el.attr('font-size', '8px').text(shortName.slice(0, 2));
          }
        });

      // Get tooltip labels from translations
      const tooltipData = {
        marketCap: lang === 'zh-TW' ? '市值' : 'Market Cap',
        revenue: lang === 'zh-TW' ? '營收' : 'Revenue',
        employees: lang === 'zh-TW' ? '員工' : 'Employees',
        founded: lang === 'zh-TW' ? '成立' : 'Founded',
        unit: lang === 'zh-TW' ? '億 TWD' : 'B TWD',
        people: lang === 'zh-TW' ? '人' : '',
        year: lang === 'zh-TW' ? '年' : '',
      };

      nodes
        .on('mouseover', (e, d) => {
          tooltip.transition().duration(200).style('opacity', 1);
          tooltip
            .html(
              `
            <strong>${d.name}</strong><br/>
            <span style="color:${colors[d.sector] || '#888'}">● ${d.sector}</span><br/>
            ${tooltipData.marketCap}：${d.marketCap.toLocaleString()} ${tooltipData.unit}<br/>
            ${tooltipData.revenue}：${d.revenue.toLocaleString()} ${tooltipData.unit}<br/>
            ${tooltipData.employees}：${d.employees.toLocaleString()} ${tooltipData.people}<br/>
            ${tooltipData.founded}：${d.founded} ${tooltipData.year}
          `,
            )
            .style('left', e.pageX + 15 + 'px')
            .style('top', e.pageY - 10 + 'px');
          d3.select(e.currentTarget)
            .select('circle')
            .attr('fill-opacity', 1)
            .attr('stroke-width', 3);
        })
        .on('mouseout', (e) => {
          tooltip.transition().duration(300).style('opacity', 0);
          d3.select(e.currentTarget)
            .select('circle')
            .attr('fill-opacity', 0.8)
            .attr('stroke-width', 2);
        })
        .on('click', (e, d) => {
          e.stopPropagation();
          if (d.articleUrl) {
            window.location.href = d.articleUrl;
          }
        })
        .style('cursor', (d) => d.articleUrl ? 'pointer' : 'default');

      simulation.on('tick', () => {
        nodes.attr('transform', (d) => {
          d.x = Math.max(getRadius(d), Math.min(width - getRadius(d), d.x));
          d.y = Math.max(getRadius(d), Math.min(height - getRadius(d), d.y));
          return `translate(${d.x},${d.y})`;
        });
      });

      // Toggle controls
      document.querySelectorAll('.toggle-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document
            .querySelectorAll('.toggle-btn')
            .forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentMode = btn.dataset.mode;
          updateBubbles();
        });
      });

      document.querySelectorAll('.sector-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document
            .querySelectorAll('.sector-btn')
            .forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentSector = btn.dataset.sector;
          updateBubbles();
        });
      });

      function updateBubbles() {
        circles
          .transition()
          .duration(600)
          .attr('r', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return getRadius(d);
          })
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 0.8;
          });

        labels
          .transition()
          .duration(600)
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 1;
          });

        simulation
          .force(
            'collision',
            d3
              .forceCollide()
              .radius((d) => {
                if (currentSector !== 'all' && d.sector !== currentSector)
                  return 0;
                return getRadius(d) + 1.5;
              })
              .strength(0.8),
          )
          .alpha(0.6)
          .restart();
      }
    }
  </script>

  <!-- Population Pyramid Script -->
  <script define:vars={{ lang }}>
    // Population data (estimated based on research)
    const populationData = {
      2000: {
        male: [650000, 680000, 720000, 750000, 800000, 820000, 750000, 680000, 620000, 550000, 480000, 420000, 350000, 280000, 220000, 160000, 120000, 80000],
        female: [620000, 650000, 680000, 710000, 760000, 780000, 720000, 650000, 590000, 530000, 460000, 400000, 340000, 280000, 230000, 180000, 140000, 100000],
        totalPop: 22270000,
        medianAge: 30,
        elderlyRatio: 8.6,
        youthRatio: 20.1
      },
      2010: {
        male: [520000, 540000, 580000, 650000, 720000, 750000, 820000, 800000, 750000, 680000, 620000, 550000, 480000, 420000, 350000, 280000, 220000, 160000],
        female: [490000, 510000, 550000, 620000, 680000, 720000, 780000, 760000, 720000, 650000, 590000, 530000, 460000, 400000, 340000, 280000, 230000, 180000],
        totalPop: 23160000,
        medianAge: 37,
        elderlyRatio: 10.7,
        youthRatio: 15.6
      },
      2025: {
        male: [420000, 450000, 480000, 520000, 580000, 650000, 720000, 750000, 820000, 800000, 750000, 680000, 620000, 550000, 480000, 420000, 350000, 280000],
        female: [400000, 430000, 460000, 490000, 550000, 620000, 680000, 720000, 780000, 760000, 720000, 650000, 590000, 530000, 460000, 400000, 340000, 280000],
        totalPop: 23300000,
        medianAge: 43,
        elderlyRatio: 18.0,
        youthRatio: 11.5
      },
      2050: {
        male: [320000, 340000, 360000, 380000, 420000, 480000, 520000, 580000, 650000, 720000, 750000, 820000, 800000, 750000, 680000, 620000, 550000, 480000],
        female: [300000, 320000, 340000, 360000, 400000, 460000, 490000, 550000, 620000, 680000, 720000, 780000, 760000, 720000, 650000, 590000, 530000, 460000],
        totalPop: 19800000,
        medianAge: 57,
        elderlyRatio: 38.0,
        youthRatio: 9.2
      }
    };

    const ageGroups = [
      '0-4', '5-9', '10-14', '15-19', '20-24', '25-29', '30-34', '35-39',
      '40-44', '45-49', '50-54', '55-59', '60-64', '65-69', '70-74', '75-79', '80-84', '85+'
    ];

    // Load D3 and initialize population pyramid
    const pyramidScript = document.createElement('script');
    pyramidScript.src = 'https://d3js.org/d3.v7.min.js';
    pyramidScript.onload = () => initPopulationPyramid();
    document.head.appendChild(pyramidScript);

    function initPopulationPyramid() {
      const container = document.getElementById('population-pyramid');
      const width = Math.min(container.clientWidth, 800);
      const height = 600;
      const margin = { top: 20, right: 40, bottom: 60, left: 100 };

      let currentYear = 2025;

      const svg = d3
        .select('#population-pyramid')
        .append('svg')
        .attr('width', width)
        .attr('height', height)
        .attr('viewBox', `0 0 ${width} ${height}`);

      const pyramidGroup = svg
        .append('g')
        .attr('transform', `translate(${margin.left}, ${margin.top})`);

      const chartWidth = width - margin.left - margin.right;
      const chartHeight = height - margin.top - margin.bottom;

      // Scales
      const xScale = d3.scaleLinear()
        .range([0, chartWidth / 2]);

      const yScale = d3.scaleBand()
        .domain(ageGroups)
        .range([chartHeight, 0])
        .padding(0.1);

      // Create gradient colors for age groups
      const ageColorScale = d3.scaleSequential()
        .domain([0, ageGroups.length - 1])
        .interpolator(d3.interpolateViridis);

      // Y axis (age groups)
      const yAxis = pyramidGroup
        .append('g')
        .attr('class', 'y-axis')
        .attr('transform', `translate(${chartWidth / 2}, 0)`);

      // Male bars (left side)
      const maleBars = pyramidGroup
        .selectAll('.male-bar')
        .data(ageGroups)
        .join('rect')
        .attr('class', 'male-bar')
        .attr('y', d => yScale(d))
        .attr('height', yScale.bandwidth())
        .attr('fill', (d, i) => ageColorScale(i))
        .attr('opacity', 0.8);

      // Female bars (right side)
      const femaleBars = pyramidGroup
        .selectAll('.female-bar')
        .data(ageGroups)
        .join('rect')
        .attr('class', 'female-bar')
        .attr('x', chartWidth / 2)
        .attr('y', d => yScale(d))
        .attr('height', yScale.bandwidth())
        .attr('fill', (d, i) => ageColorScale(i))
        .attr('opacity', 0.8);

      // Labels for male/female
      pyramidGroup
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('x', chartWidth / 4)
        .attr('y', -5)
        .attr('fill', '#cbd5e1')
        .attr('font-weight', 'bold')
        .text('男性 Male');

      pyramidGroup
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('x', (chartWidth / 4) * 3)
        .attr('y', -5)
        .attr('fill', '#cbd5e1')
        .attr('font-weight', 'bold')
        .text('女性 Female');

      // Population info box
      const infoBox = pyramidGroup
        .append('g')
        .attr('class', 'info-box')
        .attr('transform', `translate(${chartWidth - 200}, 20)`);

      infoBox
        .append('rect')
        .attr('width', 180)
        .attr('height', 100)
        .attr('fill', 'rgba(255, 255, 255, 0.05)')
        .attr('stroke', 'rgba(255, 255, 255, 0.1)')
        .attr('rx', 8);

      const infoText = infoBox
        .append('text')
        .attr('x', 10)
        .attr('y', 20)
        .attr('fill', '#e2e8f0')
        .attr('font-size', '12px');

      function updatePyramid(year) {
        const data = populationData[year];
        const maxPop = Math.max(...data.male, ...data.female);
        
        xScale.domain([0, maxPop]);

        // Update male bars
        maleBars
          .transition()
          .duration(500)
          .attr('x', (d, i) => chartWidth / 2 - xScale(data.male[i]))
          .attr('width', (d, i) => xScale(data.male[i]));

        // Update female bars
        femaleBars
          .transition()
          .duration(500)
          .attr('width', (d, i) => xScale(data.female[i]));

        // Update Y axis
        yAxis
          .selectAll('text')
          .remove();
        
        yAxis
          .selectAll('.age-label')
          .data(ageGroups)
          .join('text')
          .attr('class', 'age-label')
          .attr('text-anchor', 'middle')
          .attr('x', 0)
          .attr('y', d => yScale(d) + yScale.bandwidth() / 2)
          .attr('dy', '0.35em')
          .attr('fill', '#cbd5e1')
          .attr('font-size', '11px')
          .text(d => d);

        // Update info box
        infoText.selectAll('*').remove();
        
        infoText
          .append('tspan')
          .attr('x', 10)
          .attr('dy', 0)
          .attr('font-weight', 'bold')
          .attr('fill', '#60a5fa')
          .text(`${year} 年`);
        
        infoText
          .append('tspan')
          .attr('x', 10)
          .attr('dy', 18)
          .text(`總人口：${(data.totalPop / 10000).toFixed(0)}萬人`);
        
        infoText
          .append('tspan')
          .attr('x', 10)
          .attr('dy', 15)
          .text(`中位數年齡：${data.medianAge}歲`);
        
        infoText
          .append('tspan')
          .attr('x', 10)
          .attr('dy', 15)
          .text(`老年佔比：${data.elderlyRatio}%`);
        
        infoText
          .append('tspan')
          .attr('x', 10)
          .attr('dy', 15)
          .text(`幼年佔比：${data.youthRatio}%`);
      }

      // Initialize with 2025 data
      updatePyramid(currentYear);

      // Slider implementation
      const slider = document.querySelector('.slider-track');
      const thumb = document.getElementById('yearThumb');
      const currentYearLabel = document.getElementById('currentYear');
      const years = [2000, 2010, 2025, 2050];
      
      let isDragging = false;
      let sliderRect;

      function updateSliderPosition() {
        const yearIndex = years.indexOf(currentYear);
        const percentage = yearIndex / (years.length - 1);
        thumb.style.left = `calc(${percentage * 100}% - 12px)`;
        currentYearLabel.textContent = currentYear;
      }

      function handleSliderUpdate(clientX) {
        const rect = sliderRect || slider.getBoundingClientRect();
        const percentage = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
        const yearIndex = Math.round(percentage * (years.length - 1));
        const newYear = years[yearIndex];
        
        if (newYear !== currentYear) {
          currentYear = newYear;
          updateSliderPosition();
          updatePyramid(currentYear);
        }
      }

      thumb.addEventListener('mousedown', (e) => {
        isDragging = true;
        sliderRect = slider.getBoundingClientRect();
        document.addEventListener('mousemove', onMouseMove);
        document.addEventListener('mouseup', onMouseUp);
        e.preventDefault();
      });

      function onMouseMove(e) {
        if (isDragging) {
          handleSliderUpdate(e.clientX);
        }
      }

      function onMouseUp() {
        isDragging = false;
        document.removeEventListener('mousemove', onMouseMove);
        document.removeEventListener('mouseup', onMouseUp);
      }

      slider.addEventListener('click', (e) => {
        if (e.target !== thumb) {
          sliderRect = slider.getBoundingClientRect();
          handleSliderUpdate(e.clientX);
        }
      });

      // Touch events for mobile
      thumb.addEventListener('touchstart', (e) => {
        isDragging = true;
        sliderRect = slider.getBoundingClientRect();
        e.preventDefault();
      });

      document.addEventListener('touchmove', (e) => {
        if (isDragging) {
          const touch = e.touches[0];
          handleSliderUpdate(touch.clientX);
          e.preventDefault();
        }
      });

      document.addEventListener('touchend', () => {
        isDragging = false;
      });

      updateSliderPosition();

      // Responsive handling
      window.addEventListener('resize', () => {
        sliderRect = null;
      });
    }
  </script>

  <!-- SVG Copy Function -->
  <script is:inline define:vars={{ lang }}>
    async function copySVG(filename, btn) {
      const currentLang = lang;
      try {
        const res = await fetch('/assets/svg/' + filename);
        const text = await res.text();
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = currentLang === 'zh-TW' ? '✅ 已複製' : '✅ Copied';
        setTimeout(() => (btn.textContent = orig), 2000);
      } catch (e) {
        btn.textContent = currentLang === 'zh-TW' ? '❌ 複製失敗' : '❌ Failed';
        setTimeout(
          () =>
            (btn.textContent =
              currentLang === 'zh-TW' ? '複製代碼' : 'Copy SVG'),
          2000,
        );
      }
    }
  </script>

