      margin-bottom: 1.5rem;
    }

    .insight-card {
      background: rgba(255, 255, 255, 0.04);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .insight-number {
      font-size: 1.8rem;
      font-weight: 800;
      color: #60a5fa;
      margin-bottom: 0.3rem;
    }

    .insight-label {
      font-weight: 600;
      color: #e2e8f0;
      font-size: 0.9rem;
      margin-bottom: 0.3rem;
    }

    .insight-detail {
      font-size: 0.8rem;
      color: #94a3b8;
    }

    .explore-more {
      text-align: center;
    }

    .explore-link {
      display: inline-block;
      color: #60a5fa;
      text-decoration: none;
      font-weight: 600;
      padding: 0.5rem 1rem;
      border-radius: 8px;
      transition: all 0.2s;
    }

    .explore-link:hover {
      background: rgba(96, 165, 250, 0.1);
      color: #93c5fd;
    }

    /* Taiwan Shape Section */
    .taiwan-shape-section {
      padding: 2rem 0 4rem;
    }

    .svg-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .svg-card {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.3s;
    }

    .svg-card:hover {
      border-color: rgba(255, 255, 255, 0.2);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .svg-preview {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      background: rgba(255, 255, 255, 0.95);
      height: 140px;
    }

    .svg-preview img {
      max-height: 100px;
      max-width: 80px;
      filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.1));
    }

    .svg-info {
      padding: 1.5rem;
    }

    .svg-info h3 {
      font-family: 'Courier New', monospace;
      font-size: 0.9rem;
      color: #e2e8f0;
      margin-bottom: 0.5rem;
    }

    .svg-desc {
      color: #cbd5e1;
      margin-bottom: 0.25rem;
      font-size: 0.9rem;
    }

    .svg-meta {
      color: #94a3b8;
      font-size: 0.8rem;
      margin-bottom: 1rem;
    }

    .svg-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-block;
      padding: 0.4rem 1rem;
      border-radius: 8px;
      font-size: 0.85rem;
      text-decoration: none;
      cursor: pointer;
      border: none;
      font-family: inherit;
      transition: all 0.2s;
      font-weight: 600;
    }

    .btn-primary {
      background: #3b82f6;
      color: #fff;
    }

    .btn-primary:hover {
      background: #2563eb;
    }

    .btn-outline {
      background: transparent;
      color: #60a5fa;
      border: 1px solid #60a5fa;
    }

    .btn-outline:hover {
      background: rgba(96, 165, 250, 0.1);
    }

    .usage-example {
      max-width: 1400px;
      margin: 3rem auto 0;
      padding: 0 2rem;
    }

    .usage-example h3 {
      color: #f8fafc;
      margin-bottom: 1rem;
      font-size: 1.2rem;
    }

    .code-block {
      background: #1e293b;
      border-radius: 12px;
      padding: 1.5rem;
      overflow-x: auto;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .code-block code {
      color: #e2e8f0;
      font-size: 0.85rem;
      line-height: 1.6;
      white-space: pre;
    }

    .license-note {
      margin-top: 1rem;
      color: #94a3b8;
      font-size: 0.9rem;
    }

    .license-note a {
      color: #60a5fa;
      text-decoration: none;
    }

    .license-note a:hover {
      text-decoration: underline;
    }

    /* Population Pyramid Section */
    .population-section {
      padding: 2rem 0 4rem;
    }

    .pyramid-container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    #population-pyramid {
      width: 100%;
      min-height: 600px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      overflow: hidden;
    }

    .year-slider-container {
      margin: 2rem auto 0;
      max-width: 400px;
      text-align: center;
    }

    .slider-track {
      position: relative;
      width: 100%;
      height: 8px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      margin-bottom: 1rem;
      cursor: pointer;
    }

    .slider-track::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ec4899, #f59e0b);
      border-radius: 4px;
      opacity: 0.6;
    }

    .slider-thumb {
      position: absolute;
      width: 24px;
      height: 24px;
      background: #60a5fa;
      border: 3px solid #0f172a;
      border-radius: 50%;
      top: -8px;
      cursor: grab;
      transition: all 0.2s ease;
      box-shadow: 0 2px 12px rgba(96, 165, 250, 0.4);
    }

    .slider-thumb:hover {
      transform: scale(1.1);
      box-shadow: 0 4px 20px rgba(96, 165, 250, 0.6);
    }

    .slider-thumb:active {
      cursor: grabbing;
      transform: scale(1.05);
    }

    .year-labels {
      display: flex;
      justify-content: space-between;
      color: #94a3b8;
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }

    .current-year {
      font-size: 1.5rem;
      font-weight: bold;
      color: #60a5fa;
      margin-top: 0.5rem;
    }

    .population-section .insights {
      max-width: 1000px;
      margin: 3rem auto 0;
      padding: 0 2rem;
    }

    .population-section .insight-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .population-section .insight-card {
      background: rgba(255, 255, 255, 0.04);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: all 0.3s ease;
    }

    .population-section .insight-card:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.15);
      transform: translateY(-2px);
    }

    .population-section .insight-number {
      font-size: 1.6rem;
      font-weight: 800;
      color: #60a5fa;
      margin-bottom: 0.3rem;
      line-height: 1.2;
    }

    .population-section .insight-label {
      font-weight: 600;
      color: #e2e8f0;
      font-size: 0.95rem;
      margin-bottom: 0.3rem;
    }

    .population-section .insight-detail {
      font-size: 0.8rem;
      color: #94a3b8;
      line-height: 1.4;
    }

    /* Taiwan vs World Section */
    .taiwan-vs-world-section {
      padding: 2rem 0 4rem;
    }

    .comparison-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .comparison-card {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 2rem;
      text-align: center;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .comparison-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 255, 255, 0.15);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }

    .comparison-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ec4899);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .comparison-card:hover::before {
      opacity: 1;
    }

    .card-emoji {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      display: block;
    }

    .card-number {
      font-size: 2.2rem;
      font-weight: 900;
      color: #60a5fa;
      margin-bottom: 0.5rem;
      line-height: 1;
    }

    .card-label {
      font-size: 1.1rem;
      font-weight: 600;
      color: #e2e8f0;
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }

    .card-context {
      font-size: 0.9rem;
      color: #cbd5e1;
      line-height: 1.5;
    }

    /* Digital Democracy Timeline Section */
    .digital-democracy-section {
      padding: 2rem 0 4rem;
    }

    .timeline-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem 2rem;
    }

    /* Horizontal Timeline for Desktop */
    .timeline-horizontal {
      position: relative;
      padding: 6rem 0 2rem;
      overflow: visible;
    }

    .timeline-horizontal::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 5%;
      right: 5%;
      height: 3px;
      background: linear-gradient(to right, #3b82f6, #8b5cf6, #ec4899);
      transform: translateY(-50%);
      z-index: 1;
    }

    .timeline-horizontal .timeline-item {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
    }

    .timeline-horizontal .timeline-item[data-year="1997"] { left: 5%; }
    .timeline-horizontal .timeline-item[data-year="2003"] { left: 14%; }
    .timeline-horizontal .timeline-item[data-year="2012"] { left: 23%; }
    .timeline-horizontal .timeline-item[data-year="2013"] { left: 32%; }
    .timeline-horizontal .timeline-item[data-year="2014"] { left: 41%; }
    .timeline-horizontal .timeline-item[data-year="2015"] { left: 50%; }
    .timeline-horizontal .timeline-item[data-year="2016"] { left: 59%; }
    .timeline-horizontal .timeline-item[data-year="2020"] { left: 68%; }
    .timeline-horizontal .timeline-item[data-year="2022"] { left: 77%; }
    .timeline-horizontal .timeline-item[data-year="2023"] { left: 86%; }
    .timeline-horizontal .timeline-item[data-year="2024"] { left: 95%; }

    .timeline-dot {
      width: 12px;
      height: 12px;
      background: #3b82f6;
      border: 3px solid #0f172a;
      border-radius: 50%;
      position: relative;
      transition: all 0.3s ease;
      z-index: 2;
    }

    .timeline-item:hover .timeline-dot {
      background: #60a5fa;
      transform: scale(1.3);
      box-shadow: 0 0 15px rgba(96, 165, 250, 0.6);
    }

    .timeline-content {
      position: absolute;
      bottom: 100%;
      left: 50%;
      transform: translateX(-50%);
      margin-bottom: 15px;
      background: rgba(30, 41, 59, 0.9);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 0.5rem 0.75rem;
      min-width: 140px;
      max-width: 200px;
      text-align: center;
      opacity: 1;
      pointer-events: auto;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
      z-index: 10;
    }

    .timeline-item:hover .timeline-content {
      transform: translateX(-50%) translateY(-5px);
      background: rgba(30, 41, 59, 0.95);
      box-shadow: 0 8px 25px rgba(96, 165, 250, 0.2);
    }

    .timeline-year {
      font-size: 0.85rem;
      font-weight: 700;
      color: #3b82f6;
      margin-bottom: 0.25rem;
    }

    .timeline-title {
      font-size: 0.75rem;
      font-weight: 600;
      color: #e2e8f0;
      margin-bottom: 0.25rem;
      line-height: 1.3;
    }

    .timeline-desc {
      font-size: 0.65rem;
      color: #94a3b8;
      line-height: 1.4;
    }

    /* Alternate above/below layout */
    .timeline-horizontal .timeline-item:nth-child(odd) .timeline-content {
      bottom: 100%;
      top: auto;
      margin-bottom: 15px;
    }

    .timeline-horizontal .timeline-item:nth-child(even) .timeline-content {
      top: 100%;
      bottom: auto;
      margin-top: 15px;
      margin-bottom: 0;
    }

    /* Open Data 3-Column Grid */
    .data-categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .data-categories-grid .data-category-card:nth-child(4),
    .data-categories-grid .data-category-card:nth-child(5) {
      grid-column: span 1;
      margin: 0 auto;
      max-width: 400px;
    }

    /* Open Data Section (now part of digital democracy) */
    .digital-democracy-section .data-categories {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .data-categories {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .data-category-card {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 2rem;
      transition: border-color 0.2s ease;
    }

    .data-category-card:hover {
      border-color: rgba(255, 255, 255, 0.15);
    }

    .category-header {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .category-icon {
      font-size: 2rem;
      line-height: 1;
      flex-shrink: 0;
    }

    .category-title {
      font-size: 1.3rem;
      font-weight: 700;
      color: #f1f5f9;
      margin-bottom: 0.25rem;
    }

    .category-desc {
      font-size: 0.9rem;
      color: #94a3b8;
      line-height: 1.5;
    }

    .item-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .item {
      padding: 0.6rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      line-height: 1.6;
    }

    .item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .item-link {
      color: #7dd3fc !important;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      border-bottom: 1px solid transparent;
      transition: all 0.2s ease;
    }

    .item-link:hover {
      color: #bae6fd !important;
      border-bottom-color: #bae6fd;
    }

    .item-desc {
      color: #cbd5e1;
      font-size: 0.85rem;
    }

    /* Knowledge Graph Section */
    .knowledge-graph-section {
      padding: 2rem 0 4rem;
    }

    .graph-cta {
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .graph-btn {
      display: inline-flex;
      align-items: center;
      gap: 1.5rem;
      padding: 1.5rem 2rem;
      background: rgba(255, 255, 255, 0.06);
      color: #e2e8f0;
      text-decoration: none;
      border-radius: 16px;
      font-weight: 600;
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: all 0.3s ease;
      min-width: 320px;
    }

    .graph-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.2);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }

    .graph-icon {
      font-size: 2rem;
      flex-shrink: 0;
    }

    .graph-text {
      flex: 1;
      text-align: left;
    }

    .graph-title {
      display: block;
      font-size: 1.1rem;
      color: #f1f5f9;
      margin-bottom: 0.2rem;
    }

    .graph-desc {
      display: block;
      font-size: 0.85rem;
      color: #94a3b8;
      font-weight: normal;
    }

    .graph-arrow {
      font-size: 1.5rem;
      color: #60a5fa;
      flex-shrink: 0;
    }

    /* Footer */
    .data-footer {
      padding: 2rem 0 4rem;
    }

    .footer-title {
      text-align: center;
      color: #f8fafc;
      margin-bottom: 2rem;
      font-size: 1.5rem;
    }

    .footer-links {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1rem;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .footer-link {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.5rem;
      background: rgba(255, 255, 255, 0.04);
      color: #cbd5e1;
      text-decoration: none;
      border-radius: 12px;
      transition: all 0.2s;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .footer-link:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.2);
      color: #e2e8f0;
    }

    .footer-icon {
      font-size: 1.5rem;
      flex-shrink: 0;
    }

    .footer-text {
      flex: 1;
    }

    .footer-name {
      display: block;
      font-weight: 600;
      margin-bottom: 0.2rem;
    }

    .footer-desc {
      display: block;
      font-size: 0.85rem;
      color: #94a3b8;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero {
        padding: 2.5rem 1rem 2rem;
      }

      .story-intro {
        padding: 0 1rem 1.5rem;
      }

      .story-text {
        padding: 1.5rem;
      }

      .section-title {
        font-size: 1.6rem;
      }

      .bubble-controls {
        padding: 0 1rem;
      }

      .svg-grid {
        grid-template-columns: 1fr;
        padding: 0 1rem;
      }

      .data-categories {
        padding: 0 1rem;
      }

      .data-category-card {
        padding: 1.5rem;
      }

      .category-header {
        gap: 0.75rem;
      }

      .category-icon {
        font-size: 1.5rem;
      }

      .category-title {
        font-size: 1.2rem;
      }

      .insight-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
      }

      .graph-btn {
        flex-direction: column;
        text-align: center;
        gap: 1rem;
        min-width: auto;
      }

      .graph-text {
        text-align: center;
      }

      .footer-links {
        grid-template-columns: 1fr;
        padding: 0 1rem;
      }

      /* Taiwan vs World responsive */
      .comparison-cards {
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1rem;
        padding: 0 1rem;
      }

      .comparison-card {
        padding: 1.5rem;
      }

      .card-emoji {
        font-size: 2rem;
      }

      .card-number {
        font-size: 1.8rem;
      }

      /* Timeline responsive - Mobile: Vertical layout */
      .timeline-container {
        padding: 0 1rem 2rem;
      }

      .timeline-horizontal {
        padding: 1rem 0;
        max-height: none;
        overflow: visible;
      }

      .timeline-horizontal::before {
        top: 0;
        bottom: 0;
        left: 2rem;
        right: auto;
        width: 3px;
        height: auto;
        background: linear-gradient(to bottom, #3b82f6, #8b5cf6, #ec4899);
        transform: none;
      }

      .timeline-horizontal .timeline-item {
        position: relative;
        top: auto;
        left: auto !important;
        transform: none;
        margin-bottom: 2rem;
        display: block;
      }

      .timeline-horizontal .timeline-item .timeline-dot {
        position: absolute;
        left: 2rem;
        top: 1rem;
        transform: translateX(-50%);
      }

      .timeline-horizontal .timeline-item .timeline-content {
        position: static;
        opacity: 1;
        pointer-events: auto;
        transform: none;
        margin-left: 4rem;
        margin-bottom: 0;
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: none;
        border: 1px solid rgba(255, 255, 255, 0.08);
        text-align: left;
        min-width: auto;
        max-width: none;
        padding: 1.25rem;
      }

      .timeline-horizontal .timeline-item:hover .timeline-content {
        transform: none;
      }

      .timeline-horizontal .timeline-item .timeline-year {
        font-size: 1rem;
        color: #60a5fa;
      }

      .timeline-horizontal .timeline-item .timeline-title {
        font-size: 0.9rem;
        color: #f1f5f9;
      }

      .timeline-horizontal .timeline-item .timeline-desc {
        font-size: 0.8rem;
        color: #cbd5e1;
      }

      /* Open Data Grid - Mobile: Single column */
      .data-categories-grid {
        grid-template-columns: 1fr;
        padding: 0 1rem;
      }

      .data-categories-grid .data-category-card:nth-child(4),
      .data-categories-grid .data-category-card:nth-child(5) {
        grid-column: auto;
        margin: 0;
        max-width: none;
      }

      /* Population Pyramid responsive */
      .pyramid-container {
        padding: 0 1rem;
      }

      #population-pyramid {
        min-height: 500px;
      }

      .year-slider-container {
        max-width: 300px;
      }

      .year-labels {
        font-size: 0.8rem;
      }

      .current-year {
        font-size: 1.3rem;
      }

      .population-section .insights {
        padding: 0 1rem;
      }

      .population-section .insight-grid {
        grid-template-columns: repeat(2, 1fr);
