---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Fetch commit history from GitHub API (works in shallow clone CI/CD environments)
let commits: { hash: string; date: string; message: string; author: string }[] =
  [];
try {
  const res = await fetch(
    'https://api.github.com/repos/frank890417/taiwan-md/commits?per_page=100',
  );
  if (res.ok) {
    const data = await res.json();
    commits = data.map((c: any) => ({
      hash: c.sha,
      date: c.commit.author.date,
      message: c.commit.message.split('\n')[0],
      author: c.commit.author.name,
    }));
  }
} catch (e) {
  console.warn('Failed to fetch commits from GitHub API:', e);
}

// Group commits by date
const grouped: Record<string, typeof commits> = {};
for (const commit of commits) {
  const day = commit.date.slice(0, 10); // YYYY-MM-DD
  if (!grouped[day]) grouped[day] = [];
  grouped[day].push(commit);
}
const sortedDays = Object.keys(grouped).sort((a, b) => b.localeCompare(a));

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString(t('changelog.locale'), {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    weekday: 'short',
  });
}

function commitIcon(msg: string) {
  if (msg.startsWith('feat')) return '✨';
  if (msg.startsWith('fix')) return '🐛';
  if (msg.startsWith('content')) return '📝';
  if (msg.startsWith('docs')) return '📖';
  if (msg.startsWith('style')) return '🎨';
  if (msg.startsWith('refactor')) return '♻️';
  if (msg.startsWith('chore')) return '🔧';
  return '📌';
}

// Pass translations to the inline script
const translations = {
  justNow: t('changelog.time.just-now'),
  minutesAgo: t('changelog.time.minutes-ago'),
  hoursAgo: t('changelog.time.hours-ago'),
  daysAgo: t('changelog.time.days-ago'),
};
---

<Layout
  title={t('changelog.meta.title')}
  description={t('changelog.meta.description')}
  lang={lang}
>
  <div class="changelog-page">
    <header class="changelog-header">
      <h1>{t('changelog.header.title')}</h1>
      <p class="changelog-subtitle">
        {t('changelog.header.subtitle')}
      </p>
      <p class="changelog-meta">
        {lang === 'zh-TW' ? '共 ' : ''}{commits.length}
        {t('changelog.header.meta.updates')} · {
          t('changelog.header.meta.synced')
        }
        <a
          href="https://github.com/frank890417/taiwan-md/commits/main"
          target="_blank">GitHub</a
        >
      </p>
    </header>

    <div class="changelog-timeline">
      {
        sortedDays.map((day) => (
          <div class="changelog-day">
            <div class="day-header">
              <span class="day-dot" />
              <h2>{formatDate(day)}</h2>
              <span class="day-count">
                {grouped[day].length} {t('changelog.day.updates')}
              </span>
            </div>
            <div class="day-commits">
              {grouped[day].map((commit) => (
                <div class="commit-item">
                  <span class="commit-icon">{commitIcon(commit.message)}</span>
                  <div class="commit-content">
                    <p class="commit-message">{commit.message}</p>
                    <div class="commit-meta">
                      <span class="commit-author">{commit.author}</span>
                      <span class="commit-time" data-date={commit.date}>
                        {new Date(commit.date).toLocaleTimeString([], {
                          hour: '2-digit',
                          minute: '2-digit',
                        })}
                      </span>
                      <a
                        href={`https://github.com/frank890417/taiwan-md/commit/${commit.hash}`}
                        target="_blank"
                        class="commit-hash"
                      >
                        {commit.hash.slice(0, 7)}
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <script is:inline define:vars={{ translations }}>
    function updateRelativeTimes() {
      const timeElements = document.querySelectorAll('.commit-time');
      const now = new Date();

      timeElements.forEach((el) => {
        const date = new Date(el.getAttribute('data-date'));
        const diffInSeconds = Math.floor((now - date) / 1000);

        let relativeTime = '';
        if (diffInSeconds < 60) {
          relativeTime = translations.justNow;
        } else if (diffInSeconds < 3600) {
          relativeTime = `${Math.floor(diffInSeconds / 60)} ${translations.minutesAgo}`;
        } else if (diffInSeconds < 86400) {
          relativeTime = `${Math.floor(diffInSeconds / 3600)} ${translations.hoursAgo}`;
        } else if (diffInSeconds < 2592000) {
          relativeTime = `${Math.floor(diffInSeconds / 86400)} ${translations.daysAgo}`;
        } else {
          relativeTime = date.toLocaleDateString();
        }

        el.textContent = relativeTime;
      });
    }

    // Update on load and then every minute
    updateRelativeTimes();
    setInterval(updateRelativeTimes, 60000);
  </script>
</Layout>

<style>
  .changelog-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .changelog-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .changelog-header h1 {
    font-size: 2.5rem;
    font-weight: 900;
    color: #1a1a2e;
    margin-bottom: 0.75rem;
    font-family:
      'jf-jinxuanlatte', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
    letter-spacing: 0.05em;
  }

  .changelog-subtitle {
    font-size: 1.15rem;
    color: #64748b;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .changelog-meta {
    font-size: 0.9rem;
    color: #94a3b8;
  }

  .changelog-meta a {
    color: #3b82f6;
    text-decoration: none;
  }

  .changelog-meta a:hover {
    text-decoration: underline;
  }

  /* Timeline */
  .changelog-timeline {
    position: relative;
    padding-left: 2rem;
  }

  .changelog-timeline::before {
    content: '';
    position: absolute;
    left: 0.45rem;
    top: 0.5rem;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, #22c55e, #3b82f6, #e2e8f0);
  }

  .changelog-day {
    margin-bottom: 2.5rem;
  }

  .day-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    position: relative;
  }

  .day-dot {
    position: absolute;
    left: -1.7rem;
    width: 12px;
    height: 12px;
    background: #22c55e;
    border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 0 0 2px #22c55e;
  }

  .day-header h2 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0;
  }

  .day-count {
    font-size: 0.8rem;
    color: #94a3b8;
    background: #f1f5f9;
    padding: 0.15rem 0.6rem;
    border-radius: 10px;
    font-weight: 500;
  }

  .day-commits {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .commit-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: #fafbfc;
    border-radius: 10px;
    border: 1px solid #f1f5f9;
    transition: all 0.2s ease;
  }

  .commit-item:hover {
    background: #f0fdf4;
    border-color: #d1fae5;
  }

  .commit-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .commit-content {
    flex: 1;
    min-width: 0;
  }

  .commit-message {
    font-size: 0.95rem;
    color: #1f2937;
    margin: 0 0 0.3rem;
    line-height: 1.5;
    font-weight: 600;
    word-break: break-word;
  }

  .commit-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: #94a3b8;
  }

  .commit-author {
    font-weight: 500;
  }

  .commit-hash {
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: #3b82f6;
    text-decoration: none;
    font-size: 0.78rem;
  }

  .commit-hash:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .changelog-page {
      padding: 3rem 1rem 4rem;
    }

    .changelog-header h1 {
      font-size: 2rem;
    }

    .changelog-timeline {
      padding-left: 1.5rem;
    }

    .day-dot {
      left: -1.2rem;
      width: 10px;
      height: 10px;
    }

    .commit-item {
      padding: 0.6rem 0.75rem;
    }
  }

  .commit-time {
    color: #94a3b8;
    margin: 0 0.5rem;
    font-size: 0.85rem;
  }
</style>
