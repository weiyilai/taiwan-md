{
  "name": "taiwan-md",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/core/generate-api.js && node scripts/core/generate-map-markers.js && node scripts/core/build-search-index.mjs && node scripts/core/generate-dashboard-data.js",
    "build": "astro build",
    "test": "node scripts/core/test-frontmatter.mjs",
    "test:ci": "node scripts/core/test-frontmatter.mjs --ci",
    "postbuild": "node scripts/core/post-build-check.mjs",
    "preview": "astro preview",
    "sync": "bash scripts/core/sync.sh",
    "sync:build": "bash scripts/core/sync.sh && astro build",
    "check-images": "node scripts/utils/check-images.mjs",
    "check-links": "bash scripts/utils/check-links.sh",
    "astro": "astro",
    "format::check": "prettier --check .",
    "format::write": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "astro": "^6.0.5",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.4",
    "minisearch": "^7.2.0",
    "rehype-external-links": "^3.0.0",
    "remark-wiki-link": "^2.0.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "0.14.1"
  }
}
