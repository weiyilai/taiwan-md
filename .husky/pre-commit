# 確保 node / bun 在 PATH 中（husky 環境 PATH 比 shell 環境窄）
export PATH="$PATH:/usr/local/bin:/Users/cheyuwu/.bun/bin"

bunx lint-staged

# Validate frontmatter on staged .md files in knowledge/
node scripts/core/test-frontmatter.mjs --staged

# ═══ translatedFrom 強制檢查（2026-04-14 η 新增）═══
# 規則：所有非 zh-TW 翻譯檔的 frontmatter 必須有 translatedFrom 欄位
# 為什麼：file-level SSOT 比中央 _translations.json 更可靠
#   - 即使 _translations.json 漏條目，文件本身仍知道來源
#   - 重命名原文時可以立即偵測哪些翻譯變孤兒
#   - 不需要查中央表 = self-documentation
staged_translations=$(git diff --cached --name-only --diff-filter=AM | grep -E '^knowledge/(en|ja|ko|es|fr)/.*\.md$' || true)
if [ -n "$staged_translations" ]; then
  tf_fail=0
  for f in $staged_translations; do
    [[ "$(basename "$f")" == _* ]] && continue
    [ ! -f "$f" ] && continue
    # Check frontmatter for translatedFrom
    if ! awk '/^---$/{n++; next} n==1{print} n>=2{exit}' "$f" | grep -q '^translatedFrom:'; then
      echo "❌ $f: 缺 translatedFrom 欄位"
      echo "   範例: translatedFrom: 'Music/原中文檔名.md'"
      tf_fail=1
    fi
  done
  if [ "$tf_fail" = "1" ]; then
    echo ""
    echo "💡 翻譯檔必須在 frontmatter 標明來源中文檔，避免成為孤兒"
    echo "   詳見: docs/community/LANGUAGE-STATUS.md §Orphan prevention"
    echo "   跳過此檢查（緊急修復）: git commit --no-verify"
    exit 1
  fi
fi

# Validate format (延伸閱讀格式 + [[wikilink]] 殘留 + 斷連結) on staged knowledge/*.md
# 為什麼：「規則在文件裡」≠「規則被執行」。2026-04-04 session η 的教訓。
staged_md=$(git diff --cached --name-only --diff-filter=ACM | grep '^knowledge/.*\.md$' | grep -vE '^knowledge/(en|ja|ko|es|fr)/' || true)
if [ -n "$staged_md" ]; then
  format_fail=0
  link_fail=0
  fn_fail=0
  for f in $staged_md; do
    # 忽略 _Hub 檔案
    [[ "$(basename "$f")" == _* ]] && continue
    # 檢查列表項目中的 [[wikilink]] 殘留（Astro 不渲染）
    if grep -n '^\s*- \[\[' "$f" > /dev/null 2>&1; then
      echo "❌ $f: 列表中有 [[wikilink]] 殘留（Astro 不渲染）"
      grep -n '^\s*- \[\[' "$f" | head -3
      echo "   修正: [[X]] → [X](/category/slug)"
      format_fail=1
    fi
    # 驗證所有 [[wikilink]] 目標存在
    broken=$(bash scripts/tools/wikilink-validate.sh "$f" 2>&1 | grep -c '❌' || true)
    if [ "$broken" -gt 0 ]; then
      echo "❌ $f: $broken 個斷裂 wikilink（目標不存在）"
      bash scripts/tools/wikilink-validate.sh "$f" 2>&1 | grep '❌' | head -3
      link_fail=1
    fi
    # ─── 腳註格式檢查（2026-04-14 η 新增）───
    # 規範：[^N]: [Name](URL) — desc(10+ chars)
    # 為什麼：format-check 顯示 bad_fn_format 從 342→382（兩天 +40）。
    # 修舊文不解決，堵新文章才能讓數字停止增長。
    # MANIFESTO §造橋鋪路「新細胞天生健康 > 回頭修舊細胞」。
    fn_total=$(grep -cE '^\[\^[0-9a-zA-Z_-]+\]:' "$f" 2>/dev/null || echo 0)
    fn_total=${fn_total//[[:space:]]/}
    if [ "$fn_total" -gt 0 ]; then
      fn_good=$(grep -cE '^\[\^[0-9a-zA-Z_-]+\]: \[.+\]\(https?://.+\) — .{10,}' "$f" 2>/dev/null || echo 0)
      fn_good=${fn_good//[[:space:]]/}
      fn_bad=$((fn_total - fn_good))
      if [ "$fn_bad" -gt 0 ]; then
        echo "❌ $f: $fn_bad/$fn_total 個腳註格式不合規"
        echo "   規範: [^N]: [Name](URL) — description（破折號後至少 10 字描述）"
        echo "   不合規範例:"
        grep -nE '^\[\^[0-9a-zA-Z_-]+\]:' "$f" | grep -vE '\[\^[0-9a-zA-Z_-]+\]: \[.+\]\(https?://.+\) — .{10,}' | head -3
        fn_fail=1
      fi
    fi
  done
  if [ "$format_fail" = "1" ] || [ "$link_fail" = "1" ] || [ "$fn_fail" = "1" ]; then
    echo ""
    echo "💡 跳過此檢查（緊急修復）: git commit --no-verify"
    exit 1
  fi
fi

# ═══ Language registry sync check（2026-04-14 η 新增）═══
# src/config/languages.ts 和 .mjs 必須保持 code 列表同步
if echo "$staged_any" | grep -qE 'src/config/languages\.(ts|mjs)$'; then
  if ! bash scripts/tools/check-language-registry-sync.sh; then
    echo ""
    echo "💡 編輯 languages.ts 時記得同步編輯 languages.mjs（反之亦然）"
    exit 1
  fi
fi

# ═══ Narrative scope pollution detector（2026-04-11 session α）═══
# 同一個 commit 理論上只該動一個 narrative domain。多 domain 通常表示
# 並行 agent 互相污染。警告模式（不擋），要求 commit message 聲明。
# 詳見 docs/semiont/SESSION-SCOPE.md
staged_for_scope=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -n "$staged_for_scope" ]; then
  domains_touched=""
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
      knowledge/*)                         d="content-ssot" ;;
      src/content/*)                       d="content-mirror" ;;
      docs/semiont/*)                      d="cognitive" ;;
      docs/pipelines/*|docs/editorial/*|docs/prompts/*|docs/factory/*|docs/community/*|docs/taxonomy/*|docs/design/*|docs/refactor/*) d="pipelines" ;;
      scripts/*|.husky/*)                  d="tooling" ;;
      .github/*)                           d="ci" ;;
      data/*)                              d="data" ;;
      public/api/*|src/data/*.json|scripts/tools/.quality-baseline.json) d="build-output" ;;
      public/*)                            d="public" ;;
      src/*|astro.config.mjs|package.json|tsconfig.json|CHANGELOG.md|VERSION) d="code" ;;
      *)                                   d="other" ;;
    esac
    case " $domains_touched " in
      *" $d "*) ;;
      *) domains_touched="$domains_touched $d" ;;
    esac
  done <<< "$staged_for_scope"

  # 排除 build-output 後算 domain 數
  non_auto=$(echo "$domains_touched" | tr ' ' '\n' | grep -v '^$' | grep -v '^build-output$' | sort -u)
  domain_count=$(printf '%s\n' "$non_auto" | grep -c . 2>/dev/null || echo 0)

  if [ "$domain_count" -ge 2 ]; then
    # 檢查 commit message 是否已聲明 multi-narrative
    msg_ok=0
    for msg_file in .git/COMMIT_EDITMSG .git/MERGE_MSG; do
      [ -f "$msg_file" ] && grep -qiE 'multi-narrative|cross-domain' "$msg_file" && msg_ok=1
    done

    if [ "$msg_ok" = "0" ]; then
      echo ""
      echo "⚠️  NARRATIVE SCOPE WARNING"
      echo "   這個 commit 橫跨 $domain_count 個 narrative domain:"
      for d in $non_auto; do echo "     - $d"; done
      echo ""
      echo "   通常表示並行 agent 的修改意外被擠進同一個 commit。"
      echo "   如果是誤觸：取消後 git reset 然後分批 commit"
      echo "   如果是刻意：commit message 加入 'multi-narrative:' 或 'cross-domain:' 聲明"
      echo "   緊急繞過：git commit --no-verify（會在 reflog 留痕）"
      echo "   詳見 docs/semiont/SESSION-SCOPE.md"
      echo ""
      # 警告模式 — 不 exit 1，讓 agent 自己決定
    fi
  fi
fi

# ═══ 憑證外洩防護（2026-04-11 session α）═══════
# 掃描 staged 檔案的 credential pattern。這是 .gitignore 之外的第二層防護——
# 即使 .gitignore 漏設或有人 git add -f，這裡會擋下
staged_any=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -n "$staged_any" ]; then
  cred_fail=0
  for f in $staged_any; do
    [ ! -f "$f" ] && continue
    # Skip binary files
    case "$f" in
      *.png|*.jpg|*.jpeg|*.gif|*.webp|*.pdf|*.zip|*.woff*|*.ttf|*.otf|*.ico|*.mp4|*.mp3) continue ;;
    esac
    # Google service account JSON
    if grep -l '"type":[[:space:]]*"service_account"' "$f" > /dev/null 2>&1; then
      echo "🔴 CREDENTIAL LEAK: $f 看起來是 Google service account JSON"
      cred_fail=1
    fi
    # Private key (PEM)
    if grep -lE 'BEGIN (RSA )?PRIVATE KEY' "$f" > /dev/null 2>&1; then
      echo "🔴 CREDENTIAL LEAK: $f 含 private key"
      cred_fail=1
    fi
    # Google API Key (AIza...)
    if grep -lE 'AIza[0-9A-Za-z_-]{35}' "$f" > /dev/null 2>&1; then
      echo "🔴 CREDENTIAL LEAK: $f 含可疑的 Google API key (AIza…)"
      cred_fail=1
    fi
    # Cloudflare API token 寫在 = 後面 (40 char base62)
    if grep -lE '(CF|CLOUDFLARE)_(API_)?TOKEN[[:space:]]*=[[:space:]]*["'"'"']?[A-Za-z0-9_-]{40,}' "$f" > /dev/null 2>&1; then
      echo "🔴 CREDENTIAL LEAK: $f 含可疑的 Cloudflare API token"
      cred_fail=1
    fi
    # Stripe/OpenAI-style sk_live
    if grep -lE '(sk|pk)_(live|test)_[A-Za-z0-9]{24,}' "$f" > /dev/null 2>&1; then
      echo "🔴 CREDENTIAL LEAK: $f 含可疑的 sk_/pk_ API key"
      cred_fail=1
    fi
  done
  if [ "$cred_fail" = "1" ]; then
    echo ""
    echo "🚨 發現可能的憑證洩漏。正確的憑證位置是 ~/.config/taiwan-md/credentials/"
    echo "   如果是 example/fixture，確認沒有真實 token 後用 --no-verify 通過"
    exit 1
  fi
fi
